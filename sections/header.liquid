{%- comment -%}
  Header – Dr. Schär México
  ✔ Mobile: drill-down navigation (páginas deslizantes)
  ✔ Desktop: dropdowns con hover
  ✔ Menú desde link_list (con sub-menús automáticos)
  ✔ Overlay se inyecta en <body> via JS
  ✔ Íconos sociales PNG
{%- endcomment -%}

{%- liquid
  assign layout = section.settings.layout | default: 'menu-logo-icons'
  assign is_transparent = section.settings.transparent_header
  assign transparent_class = ''
  if is_transparent and template.name == 'index'
    assign transparent_class = ' schar-header--transparent'
  endif
  assign main_menu = linklists[section.settings.menu]
-%}

<style>
  :root {
    --schar-bg-beige: #E8DDD0;
    --schar-red: #C41E3A;
    --schar-yellow: #F5C842;
    --schar-dark: #2C1A0E;
    --schar-white: #FFFFFF;
    --schar-font-body: 'Inter', 'Poppins', sans-serif;
    --schar-transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* =============================================
     HEADER
     ============================================= */
  .schar-header {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    background-color: var(--schar-white);
    z-index: var(--z-index-menu, 999);
    transition: background-color var(--schar-transition), box-shadow var(--schar-transition);
  }

  .schar-header--transparent {
    position: fixed;
    background-color: transparent;
    box-shadow: none;
  }

  .schar-header--transparent .schar-header__desktop-link,
  .schar-header--transparent .schar-header__icon-btn svg {
    color: var(--schar-white);
    stroke: var(--schar-white);
  }

  .schar-header--transparent .schar-header__hamburger span {
    background-color: var(--schar-white);
  }

  .schar-header--transparent.is-scrolled {
    background-color: var(--schar-white);
    box-shadow: 0 2px 12px rgba(44,26,14,0.08);
  }

  .schar-header--transparent.is-scrolled .schar-header__desktop-link,
  .schar-header--transparent.is-scrolled .schar-header__icon-btn svg {
    color: var(--schar-dark);
    stroke: var(--schar-dark);
  }

  .schar-header--transparent.is-scrolled .schar-header__hamburger span {
    background-color: var(--schar-dark);
  }

  .schar-header:not(.schar-header--transparent).is-scrolled {
    box-shadow: 0 2px 12px rgba(44,26,14,0.08);
  }

  .schar-header.is-scrolled .schar-header__inner {
    padding-top: 10px;
    padding-bottom: 10px;
  }

  /* ── INNER ── */
  .schar-header__inner {
    display: grid;
    align-items: center;
    padding: 14px var(--header-mobile-padding, 22px);
    transition: padding var(--schar-transition);
    grid-template-columns: auto 1fr auto;
  }

  .schar-header__zone-nav   { order: 1; justify-self: start; }
  .schar-header__zone-logo  { order: 2; justify-self: center; }
  .schar-header__zone-icons { order: 3; justify-self: end; }

  /* ── HAMBURGER ── */
  .schar-header__menu-toggle {
    display: flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; padding: 0; border: none;
    background: transparent; cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .schar-header__hamburger { width: 22px; height: 16px; position: relative; }

  .schar-header__hamburger span {
    display: block; width: 100%; height: 2px;
    background-color: var(--schar-dark); border-radius: 1px;
    position: absolute; left: 0; transition: var(--schar-transition);
  }

  .schar-header__hamburger span:nth-child(1) { top: 0; }
  .schar-header__hamburger span:nth-child(2) { top: 7px; }
  .schar-header__hamburger span:nth-child(3) { top: 14px; }

  /* ── DESKTOP NAV ── */
  .schar-header__desktop-nav {
    display: none; align-items: center; gap: 28px;
    list-style: none; margin: 0; padding: 0;
  }

  .schar-header__desktop-link {
    font-family: var(--schar-font-body); font-size: 15px; font-weight: 500;
    color: var(--schar-dark); text-decoration: none; padding: 4px 0;
    position: relative; transition: color var(--schar-transition);
  }

  .schar-header__desktop-link::after {
    content: ''; position: absolute; bottom: -2px; left: 0;
    width: 0; height: 2px; background-color: var(--schar-red);
    transition: width 0.3s ease;
  }

  .schar-header__desktop-link:hover { color: var(--schar-red); }
  .schar-header__desktop-link:hover::after { width: 100%; }

  .schar-header__desktop-link--has-sub {
    display: inline-flex; align-items: center; gap: 4px;
  }

  .schar-header__dropdown { position: relative; }

  /* Bridge invisible: cubre el hueco entre el link y el submenú
     para que el hover NO se pierda al mover el mouse hacia abajo */
  .schar-header__dropdown::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    height: 18px;
    /* transparente, solo mantiene el hover activo */
  }

  .schar-header__dropdown-arrow {
    transition: transform 0.25s ease; flex-shrink: 0;
  }

  .schar-header__dropdown:hover .schar-header__dropdown-arrow {
    transform: rotate(180deg);
  }

  .schar-header__submenu {
    position: absolute; top: 100%; left: 50%;
    transform: translateX(-50%) translateY(6px);
    min-width: 220px; padding: 10px 0;
    margin-top: 12px;
    background-color: var(--schar-white); border-radius: 10px;
    box-shadow: 0 12px 36px rgba(44,26,14,0.14);
    list-style: none;
    opacity: 0; visibility: hidden;
    transition: opacity 0.22s ease, visibility 0.22s ease, transform 0.22s ease;
    z-index: 100;
  }

  /* Flechita decorativa arriba del submenú */
  .schar-header__submenu::before {
    content: '';
    position: absolute;
    top: -6px; left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 12px; height: 12px;
    background-color: var(--schar-white);
    border-radius: 2px 0 0 0;
  }

  .schar-header__dropdown:hover .schar-header__submenu,
  .schar-header__dropdown:focus-within .schar-header__submenu {
    opacity: 1; visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .schar-header__submenu-link {
    display: block; padding: 11px 22px;
    font-family: var(--schar-font-body); font-size: 14px;
    color: var(--schar-dark); text-decoration: none;
    transition: color 0.2s ease, background-color 0.2s ease;
    white-space: nowrap;
  }

  .schar-header__submenu-link:hover {
    color: var(--schar-red); background-color: rgba(232,221,208,0.35);
  }

  /* ── LOGO ── */
  .schar-header__zone-logo { display: flex; align-items: center; }

  .schar-header__logo-link {
    display: flex; align-items: center; text-decoration: none;
  }

  .schar-header__logo-wrapper {
    background-color: var(--schar-yellow); padding: 8px 12px;
    border-radius: 12px; display: flex; align-items: center; justify-content: center;
  }

  .schar-header__logo-img { width: auto; height: 34px; display: block; }

  .schar-header__logo-fallback {
    font-size: 18px; font-weight: 700; color: var(--schar-red);
  }

  /* ── ICONS ── */
  .schar-header__zone-icons { display: flex; align-items: center; }
  .schar-header__actions { display: flex; align-items: center; gap: 12px; }

  .schar-header__icon-btn {
    display: flex; align-items: center; justify-content: center;
    padding: 0; border: none; background: transparent;
    cursor: pointer; position: relative; text-decoration: none;
  }

  .schar-header__icon-btn svg {
    display: block; width: 20px; height: 20px;
    stroke: var(--schar-dark); fill: none; stroke-width: 1.8;
    stroke-linecap: round; stroke-linejoin: round;
    transition: stroke var(--schar-transition);
  }

  .schar-header__icon-btn:hover svg { stroke: var(--schar-red); }

  .schar-header__cart-count {
    position: absolute; top: -6px; right: -10px; z-index: 2;
    display: flex; align-items: center; justify-content: center;
    width: 18px; height: 18px;
    background-color: var(--schar-red); border-radius: 50%;
  }

  .schar-header__cart-count-number {
    font-family: var(--schar-font-body); font-size: 10px;
    font-weight: 600; color: var(--schar-white); line-height: 1;
  }

  .schar-header__cart-count:empty { display: none; }

  /* =============================================
     MOBILE NAV DRAWER (drill-down)
     ============================================= */
  .schar-drawer {
    position: fixed; top: 0; left: 0; width: 100%; height: auto;
    background-color: var(--schar-bg-beige);
    z-index: 999999;
    display: none; flex-direction: column;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(44,26,14,0.18);
  }

  .schar-drawer.is-open { display: flex; animation: scharDrawerIn 0.3s ease forwards; }

  @keyframes scharDrawerIn {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Viewport que recorta las páginas ── */
  .schar-drawer__viewport {
    position: relative;
    overflow: hidden;
    width: 100%;
    transition: height 0.35s ease;
  }

  /* ── Slider de páginas ── */
  .schar-drawer__slider {
    display: flex;
    width: 200%;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .schar-drawer__slider.is-sub {
    transform: translateX(-50%);
  }

  /* ── Cada página ocupa 50% del slider ── */
  .schar-drawer__page {
    width: 50%;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
  }

  /* ── Close ── */
  .schar-drawer__close {
    position: absolute; top: 16px; left: 22px;
    display: flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; padding: 0;
    border: none; background: transparent; cursor: pointer; z-index: 2;
  }

  .schar-drawer__close svg {
    width: 24px; height: 24px;
    stroke: var(--schar-dark); stroke-width: 2; stroke-linecap: round;
  }

  /* ── Logo ── */
  .schar-drawer__logo-area {
    display: flex; align-items: center; justify-content: center;
    padding: 24px 0 16px;
  }

  .schar-drawer__logo-wrapper {
    background-color: var(--schar-yellow);
    padding: 14px 18px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
  }

  .schar-drawer__logo-img {
    width: 80px; height: auto; display: block; object-fit: contain;
  }

  /* ── Links ── */
  .schar-drawer__links {
    list-style: none; margin: 0; padding: 8px 28px 0;
  }

  .schar-drawer__item {
    border-bottom: 1px solid rgba(44,26,14,0.1);
  }

  .schar-drawer__item:last-child { border-bottom: none; }

  .schar-drawer__link {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 0;
    font-family: var(--schar-font-body); font-size: 18px; font-weight: 400;
    color: var(--schar-dark); text-decoration: none;
    cursor: pointer; transition: color 0.2s ease;
    border: none; background: none; width: 100%; text-align: left;
  }

  .schar-drawer__link:hover { color: var(--schar-red); }

  .schar-drawer__chevron {
    width: 18px; height: 18px; flex-shrink: 0;
  }

  .schar-drawer__chevron polyline {
    stroke: var(--schar-dark); stroke-width: 2.5;
    stroke-linecap: round; stroke-linejoin: round; fill: none;
  }

  /* Los links simples (sin submenú) no muestran chevron */
  a.schar-drawer__link .schar-drawer__chevron { opacity: 0.35; }

  /* ── Social ── */
  .schar-drawer__social {
    display: flex; align-items: center; justify-content: center;
    gap: 14px; padding: 28px 0 36px;
  }

  .schar-drawer__social-link {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; text-decoration: none;
    transition: transform 0.2s ease;
  }

  .schar-drawer__social-link:hover { transform: scale(1.1); }

  .schar-drawer__social-link img {
    width: 100%; height: 100%; object-fit: contain;
    display: block; border-radius: 50%;
  }

  /* ── SUB PAGE ── */
  .schar-drawer__back {
    display: flex; align-items: center; gap: 8px;
    padding: 20px 28px 12px;
    font-family: var(--schar-font-body); font-size: 14px; font-weight: 500;
    color: var(--schar-dark); opacity: 0.6;
    border: none; background: none; cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .schar-drawer__back:hover { opacity: 1; }

  .schar-drawer__back svg {
    width: 16px; height: 16px; flex-shrink: 0;
  }

  .schar-drawer__back svg polyline {
    stroke: var(--schar-dark); stroke-width: 2.5;
    stroke-linecap: round; stroke-linejoin: round; fill: none;
  }

  .schar-drawer__sub-title {
    font-family: var(--schar-font-body); font-size: 28px; font-weight: 700;
    color: var(--schar-dark); margin: 0;
    padding: 0 28px 8px;
    line-height: 1.2;
  }

  .schar-drawer__sublinks {
    list-style: none; margin: 0; padding: 0 28px;
  }

  .schar-drawer__sublink {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 0;
    font-family: var(--schar-font-body); font-size: 16px; font-weight: 400;
    color: var(--schar-dark); text-decoration: none;
    border-bottom: 1px solid rgba(44,26,14,0.08);
    transition: color 0.2s ease;
  }

  .schar-drawer__sublink:hover { color: var(--schar-red); }

  .schar-drawer__sublinks li:last-child .schar-drawer__sublink {
    border-bottom: none;
  }

  .schar-drawer__sublink-chevron {
    width: 16px; height: 16px; flex-shrink: 0;
  }

  .schar-drawer__sublink-chevron polyline {
    stroke: var(--schar-dark); stroke-width: 2.5;
    stroke-linecap: round; stroke-linejoin: round; fill: none;
  }

  /* ── Sub page social (duplicado) ── */
  .schar-drawer__sub-social {
    display: flex; align-items: center; justify-content: center;
    gap: 14px; padding: 28px 0 36px;
  }

  .schar-drawer__sub-social a {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; text-decoration: none;
    transition: transform 0.2s ease;
  }

  .schar-drawer__sub-social a:hover { transform: scale(1.1); }

  .schar-drawer__sub-social img {
    width: 100%; height: 100%; object-fit: contain;
    display: block; border-radius: 50%;
  }

  /* Lock scroll */
  html.schar-nav-open,
  html.schar-nav-open body {
    overflow: hidden !important;
  }

  /* =============================================
     DESKTOP
     ============================================= */
  @media (min-width: 681px) {
    .schar-drawer { display: none !important; }
    .schar-header__menu-toggle { display: none; }
    .schar-header__desktop-nav { display: flex; }

    .schar-header__inner {
      padding: 18px var(--header-desktop-padding, 63px);
    }

    .schar-header__inner--menu-logo-icons {
      grid-template-columns: 1fr auto 1fr;
    }

    .schar-header__inner--logo-menu-icons {
      grid-template-columns: auto 1fr auto; gap: 0 24px;
    }
    .schar-header__inner--logo-menu-icons .schar-header__zone-logo  { order: 1; justify-self: start; }
    .schar-header__inner--logo-menu-icons .schar-header__zone-nav   { order: 2; justify-self: start; }
    .schar-header__inner--logo-menu-icons .schar-header__zone-icons { order: 3; justify-self: end; }

    .schar-header__inner--menu-icons-logo {
      grid-template-columns: 1fr 1fr auto; gap: 0 24px;
    }
    .schar-header__inner--menu-icons-logo .schar-header__zone-nav   { order: 1; justify-self: start; }
    .schar-header__inner--menu-icons-logo .schar-header__zone-icons { order: 2; justify-self: end; }
    .schar-header__inner--menu-icons-logo .schar-header__zone-logo  { order: 3; justify-self: end; }

    .schar-header__logo-img { height: 48px; }
    .schar-header__logo-wrapper { padding: 10px 14px; }
    .schar-header__icon-btn svg { width: 22px; height: 22px; }
    .schar-header__actions { gap: 18px; }
  }

  @media (min-width: 681px) and (max-width: 1439px) {
    .schar-header__inner { padding: 16px var(--header-laptop-padding, 46px); }
    .schar-header__logo-img { height: 42px; }
  }
  /* =============================================
     BÚSQUEDA (overlay desplegable)
     ============================================= */
  .schar-search {
    position: fixed; inset: 0; z-index: 1000000;
    visibility: hidden; pointer-events: none;
  }
  .schar-search.is-open { visibility: visible; pointer-events: auto; }
  .schar-search__overlay {
    position: absolute; inset: 0;
    background-color: rgba(44,26,14,0.5);
    backdrop-filter: blur(3px); -webkit-backdrop-filter: blur(3px);
    opacity: 0; transition: opacity 0.25s ease;
  }
  .schar-search.is-open .schar-search__overlay { opacity: 1; }
  .schar-search__panel {
    position: absolute; top: 0; left: 0; right: 0;
    background-color: var(--schar-white);
    padding: 18px var(--header-mobile-padding, 22px);
    box-shadow: 0 12px 36px rgba(44,26,14,0.18);
    transform: translateY(-100%);
    transition: transform 0.32s cubic-bezier(0.2,0.9,0.2,1);
  }
  .schar-search.is-open .schar-search__panel { transform: translateY(0); }
  .schar-search__form {
    display: flex; align-items: center; gap: 12px;
    max-width: 1200px; margin: 0 auto;
  }
  .schar-search__icon {
    width: 22px; height: 22px; flex-shrink: 0;
    stroke: var(--schar-dark); fill: none; stroke-width: 1.8;
    stroke-linecap: round; stroke-linejoin: round;
  }
  .schar-search__input {
    flex: 1; min-width: 0;
    border: none; outline: none; background: transparent;
    font-family: var(--schar-font-body); font-size: 17px;
    color: var(--schar-dark); padding: 10px 0;
  }
  .schar-search__input::placeholder { color: #B8AA9C; }
  .schar-search__submit {
    flex-shrink: 0;
    padding: 11px 24px;
    background-color: var(--schar-dark); color: var(--schar-white);
    border: none; border-radius: 50px;
    font-family: var(--schar-font-body); font-size: 13px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer;
    transition: background-color 0.2s ease;
  }
  .schar-search__submit:hover { background-color: var(--schar-red); }
  .schar-search__close {
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; padding: 0;
    background: transparent; border: none; cursor: pointer;
    color: var(--schar-dark); border-radius: 50%;
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  .schar-search__close:hover { background-color: var(--schar-bg-beige); color: var(--schar-red); }
  .schar-search__close svg {
    width: 22px; height: 22px;
    stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round;
  }
  html.schar-search-open, html.schar-search-open body { overflow: hidden; }
  @media (min-width: 681px) {
    .schar-search__panel { padding: 24px var(--header-desktop-padding, 63px); }
    .schar-search__input { font-size: 19px; }
  }
  @media (max-width: 680px) {
    .schar-search__submit { padding: 11px 16px; }
  }
</style>

<!-- ============================================= -->
<!-- HEADER                                        -->
<!-- ============================================= -->
<header class="schar-header{{ transparent_class }}" id="schar-header" role="banner">
  <div class="schar-header__inner schar-header__inner--{{ layout }}">

    <div class="schar-header__zone-nav">
      <button class="schar-header__menu-toggle" id="schar-menu-toggle" aria-label="Abrir menú" type="button">
        <span class="schar-header__hamburger"><span></span><span></span><span></span></span>
      </button>

      <nav class="schar-header__desktop-nav" aria-label="Navegación principal">
        {%- for link in main_menu.links -%}
          {%- if link.links.size > 0 -%}
            <div class="schar-header__dropdown">
              <a href="{{ link.url }}" class="schar-header__desktop-link schar-header__desktop-link--has-sub">
                {{ link.title }}
                <svg class="schar-header__dropdown-arrow" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </a>
              <ul class="schar-header__submenu">
                {%- for child in link.links -%}
                  <li><a href="{{ child.url }}" class="schar-header__submenu-link">{{ child.title }}</a></li>
                {%- endfor -%}
              </ul>
            </div>
          {%- else -%}
            <a href="{{ link.url }}" class="schar-header__desktop-link">{{ link.title }}</a>
          {%- endif -%}
        {%- endfor -%}
      </nav>
    </div>

    <div class="schar-header__zone-logo">
      <a href="{{ section.settings.logo_link | default: '/' }}" class="schar-header__logo-link" aria-label="{{ shop.name }}">
        <span class="schar-header__logo-wrapper">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ section.settings.logo_alt | default: shop.name }}" class="schar-header__logo-img" width="68" height="48" loading="eager">
          {%- else -%}
            <span class="schar-header__logo-fallback">{{ shop.name }}</span>
          {%- endif -%}
        </span>
      </a>
    </div>

    <div class="schar-header__zone-icons">
      <div class="schar-header__actions">
        {%- if section.settings.show_search -%}
          <button class="schar-header__icon-btn" aria-label="Buscar" type="button" data-search-toggle>
            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </button>
        {%- endif -%}
        {%- if section.settings.show_account -%}
          <a href="{{ routes.account_url }}" class="schar-header__icon-btn" aria-label="Mi cuenta">
            <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </a>
        {%- endif -%}
        <a href="{{ routes.cart_url }}" class="schar-header__icon-btn" aria-label="Carrito">
          <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          {%- if cart.item_count > 0 -%}
            <span class="schar-header__cart-count"><span class="schar-header__cart-count-number">{{ cart.item_count }}</span></span>
          {%- endif -%}
        </a>
      </div>
    </div>

  </div>
</header>
