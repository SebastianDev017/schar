<!-- ============================================= -->
<!-- MOBILE DRAWER (template → body via JS)        -->
<!-- ============================================= -->
<template id="schar-drawer-tpl">
  <div class="schar-drawer" id="schar-drawer">
    <button class="schar-drawer__close" id="schar-drawer-close" aria-label="Cerrar menú" type="button">
      <svg viewBox="0 0 24 24" fill="none"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <div class="schar-drawer__viewport" id="schar-drawer-viewport">
      <div class="schar-drawer__slider" id="schar-drawer-slider">

        {%- comment -%} ── PÁGINA 1: Menú principal ── {%- endcomment -%}
        <div class="schar-drawer__page" id="schar-page-main">
          <div class="schar-drawer__logo-area">
            <a href="{{ section.settings.logo_link | default: '/' }}" aria-label="{{ shop.name }}">
              <span class="schar-drawer__logo-wrapper">
                {%- if section.settings.logo != blank -%}
                  <img src="{{ section.settings.logo | image_url: width: 300 }}" alt="{{ section.settings.logo_alt | default: shop.name }}" class="schar-drawer__logo-img" loading="lazy">
                {%- else -%}
                  <span class="schar-header__logo-fallback" style="font-size:24px;">{{ shop.name }}</span>
                {%- endif -%}
              </span>
            </a>
          </div>

          <ul class="schar-drawer__links">
            {%- for link in main_menu.links -%}
              <li class="schar-drawer__item">
                {%- if link.links.size > 0 -%}
                  <button class="schar-drawer__link" type="button" data-sub-menu="{{ link.title | handleize }}">
                    <span>{{ link.title }}</span>
                    <svg class="schar-drawer__chevron" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
                  </button>
                {%- else -%}
                  <a href="{{ link.url }}" class="schar-drawer__link">
                    <span>{{ link.title }}</span>
                    <svg class="schar-drawer__chevron" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
                  </a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>

          <div class="schar-drawer__social">
            {%- if section.settings.social_facebook != blank -%}
              <a href="{{ section.settings.social_facebook }}" class="schar-drawer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
                <img src="{{ 'facebook-dark.png' | asset_url }}" alt="Facebook" width="32" height="32" loading="lazy">
              </a>
            {%- endif -%}
            {%- if section.settings.social_instagram != blank -%}
              <a href="{{ section.settings.social_instagram }}" class="schar-drawer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
                <img src="{{ 'instagram-dark.png' | asset_url }}" alt="Instagram" width="32" height="32" loading="lazy">
              </a>
            {%- endif -%}
            {%- if section.settings.social_tiktok != blank -%}
              <a href="{{ section.settings.social_tiktok }}" class="schar-drawer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
                <img src="{{ 'tiktok-dark.png' | asset_url }}" alt="TikTok" width="32" height="32" loading="lazy">
              </a>
            {%- endif -%}
            {%- if section.settings.social_youtube != blank -%}
              <a href="{{ section.settings.social_youtube }}" class="schar-drawer__social-link" aria-label="YouTube" target="_blank" rel="noopener">
                <img src="{{ 'youtube-dark.png' | asset_url }}" alt="YouTube" width="32" height="32" loading="lazy">
              </a>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} ── PÁGINA 2: Sub-menú (contenido dinámico via JS) ── {%- endcomment -%}
        <div class="schar-drawer__page" id="schar-page-sub">
          <div class="schar-drawer__logo-area">
            <a href="{{ section.settings.logo_link | default: '/' }}" aria-label="{{ shop.name }}">
              <span class="schar-drawer__logo-wrapper">
                {%- if section.settings.logo != blank -%}
                  <img src="{{ section.settings.logo | image_url: width: 300 }}" alt="{{ section.settings.logo_alt | default: shop.name }}" class="schar-drawer__logo-img" loading="lazy">
                {%- else -%}
                  <span class="schar-header__logo-fallback" style="font-size:24px;">{{ shop.name }}</span>
                {%- endif -%}
              </span>
            </a>
          </div>

          <button class="schar-drawer__back" id="schar-drawer-back" type="button">
            <svg viewBox="0 0 24 24" fill="none"><polyline points="15 18 9 12 15 6"/></svg>
            <span>Atrás</span>
          </button>
          <h3 class="schar-drawer__sub-title" id="schar-sub-title"></h3>
          <ul class="schar-drawer__sublinks" id="schar-sub-links"></ul>

          <div class="schar-drawer__sub-social">
            {%- if section.settings.social_facebook != blank -%}
              <a href="{{ section.settings.social_facebook }}" aria-label="Facebook" target="_blank" rel="noopener">
                <img src="{{ 'facebook-dark.png' | asset_url }}" alt="Facebook" width="32" height="32" loading="lazy">
              </a>
            {%- endif -%}
            {%- if section.settings.social_instagram != blank -%}
              <a href="{{ section.settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
                <img src="{{ 'instagram-dark.png' | asset_url }}" alt="Instagram" width="32" height="32" loading="lazy">
              </a>
            {%- endif -%}
            {%- if section.settings.social_tiktok != blank -%}
              <a href="{{ section.settings.social_tiktok }}" aria-label="TikTok" target="_blank" rel="noopener">
                <img src="{{ 'tiktok-dark.png' | asset_url }}" alt="TikTok" width="32" height="32" loading="lazy">
              </a>
            {%- endif -%}
            {%- if section.settings.social_youtube != blank -%}
              <a href="{{ section.settings.social_youtube }}" aria-label="YouTube" target="_blank" rel="noopener">
                <img src="{{ 'youtube-dark.png' | asset_url }}" alt="YouTube" width="32" height="32" loading="lazy">
              </a>
            {%- endif -%}
          </div>
        </div>

      </div>
    </div>
  </div>
</template>

{%- comment -%} Sub-menú data para JS {%- endcomment -%}
<script type="application/json" id="schar-menu-data">
  {
    {%- assign sub_count = 0 -%}
    {%- for link in main_menu.links -%}
      {%- if link.links.size > 0 -%}
        {%- if sub_count > 0 -%},{%- endif -%}
        "{{ link.title | handleize }}": {
          "title": {{ link.title | json }},
          "links": [
            {%- for child in link.links -%}
              { "title": {{ child.title | json }}, "url": {{ child.url | json }} }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ]
        }
        {%- assign sub_count = sub_count | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}
  }
</script>

<!-- ============================================= -->
<!-- JS                                            -->
<!-- ============================================= -->
<script>
(function() {
  var toggle = document.getElementById('schar-menu-toggle');
  var header = document.getElementById('schar-header');
  var tpl = document.getElementById('schar-drawer-tpl');
  var menuDataEl = document.getElementById('schar-menu-data');
  if (!toggle || !header || !tpl) return;

  var menuData = {};
  try { menuData = JSON.parse(menuDataEl.textContent); } catch(e) {}

  var drawer, slider, viewport, closeBtn, backBtn, subTitle, subLinks;
  var isTransparent = header.classList.contains('schar-header--transparent');
  var ready = false;

  function ensureDrawer() {
    if (ready) return;
    var clone = tpl.content.cloneNode(true);
    document.body.appendChild(clone);
    drawer = document.getElementById('schar-drawer');
    slider = document.getElementById('schar-drawer-slider');
    viewport = document.getElementById('schar-drawer-viewport');
    closeBtn = document.getElementById('schar-drawer-close');
    backBtn = document.getElementById('schar-drawer-back');
    subTitle = document.getElementById('schar-sub-title');
    subLinks = document.getElementById('schar-sub-links');

    closeBtn.addEventListener('click', closeDrawer);
    backBtn.addEventListener('click', goBack);

    /* Sub-menú buttons */
    drawer.querySelectorAll('[data-sub-menu]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var key = this.getAttribute('data-sub-menu');
        openSub(key);
      });
    });

    /* Close on real link click */
    drawer.addEventListener('click', function(e) {
      var a = e.target.closest('a');
      if (a && a.getAttribute('href') && a.getAttribute('href') !== '#') {
        closeDrawer();
      }
    });

    ready = true;
  }

  function updateHeight() {
    var isSub = slider.classList.contains('is-sub');
    var page = isSub
      ? document.getElementById('schar-page-sub')
      : document.getElementById('schar-page-main');
    viewport.style.height = page.scrollHeight + 'px';
  }

  function openDrawer() {
    ensureDrawer();
    slider.classList.remove('is-sub');
    drawer.classList.add('is-open');
    document.documentElement.classList.add('schar-nav-open');
    if (isTransparent) header.classList.add('is-scrolled');
    requestAnimationFrame(updateHeight);
  }

  function closeDrawer() {
    if (!drawer) return;
    drawer.classList.remove('is-open');
    slider.classList.remove('is-sub');
    document.documentElement.classList.remove('schar-nav-open');
    if (isTransparent && window.scrollY <= 50) header.classList.remove('is-scrolled');
  }

  function openSub(key) {
    var data = menuData[key];
    if (!data) return;

    subTitle.textContent = data.title;
    subLinks.innerHTML = '';

    data.links.forEach(function(item) {
      var li = document.createElement('li');
      li.innerHTML = '<a href="' + item.url + '" class="schar-drawer__sublink">' +
        '<span>' + item.title + '</span>' +
        '<svg class="schar-drawer__sublink-chevron" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>' +
        '</a>';
      subLinks.appendChild(li);
    });

    slider.classList.add('is-sub');
    requestAnimationFrame(updateHeight);
  }

  function goBack() {
    slider.classList.remove('is-sub');
    requestAnimationFrame(updateHeight);
  }

  toggle.addEventListener('click', function() {
    if (drawer && drawer.classList.contains('is-open')) {
      closeDrawer();
    } else {
      openDrawer();
    }
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && drawer && drawer.classList.contains('is-open')) {
      closeDrawer();
      toggle.focus();
    }
  });

  window.addEventListener('scroll', function() {
    var y = window.scrollY || window.pageYOffset;
    if (y > 50) {
      header.classList.add('is-scrolled');
    } else if (!drawer || !drawer.classList.contains('is-open')) {
      header.classList.remove('is-scrolled');
    }
  }, { passive: true });

  window.matchMedia('(min-width: 681px)').addEventListener('change', function(e) {
    if (e.matches) closeDrawer();
  });
})();
</script>
<!-- ============================================= -->
<!-- JS BUSQUEDA                                   -->
<!-- ============================================= -->
<script>
(function() {
  var search = document.querySelector('[data-schar-search]');
  if (!search) return;
  var input = search.querySelector('[data-schar-search-input]');
  var form = search.querySelector('form');
  var toggles = document.querySelectorAll('[data-search-toggle]');

  function openSearch() {
    search.classList.add('is-open');
    search.setAttribute('aria-hidden', 'false');
    document.documentElement.classList.add('schar-search-open');
    setTimeout(function() { if (input) input.focus(); }, 90);
  }
  function closeSearch() {
    search.classList.remove('is-open');
    search.setAttribute('aria-hidden', 'true');
    document.documentElement.classList.remove('schar-search-open');
  }

  toggles.forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      openSearch();
    });
  });

  search.querySelectorAll('[data-schar-search-close]').forEach(function(el) {
    el.addEventListener('click', closeSearch);
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && search.classList.contains('is-open')) closeSearch();
  });

  /* No enviar busquedas vacias */
  if (form) {
    form.addEventListener('submit', function(e) {
      if (!input || !input.value.trim()) {
        e.preventDefault();
        if (input) input.focus();
      }
    });
  }
})();
</script>

