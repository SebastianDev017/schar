      <input class="schar-search__input" type="search" name="q" placeholder="Buscar productos..." autocomplete="off" autocapitalize="off" spellcheck="false" aria-label="Buscar" data-schar-search-input>
      <button class="schar-search__submit" type="submit">Buscar</button>
      <button class="schar-search__close" type="button" data-schar-search-close aria-label="Cerrar busqueda">
        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
