{% liquid
  assign note_enabled = section.settings.note_enabled
  assign button_link = settings.continue_shopping_button_link
  assign button_label = settings.continue_shopping_button_label
%}

{{- 'theme-cart.css' | asset_url | stylesheet_tag -}}
{{- 'css-main-cart.css' | asset_url | stylesheet_tag -}}
<script src="{{ 'js-main-cart.js' | asset_url }}" defer></script>

{% unless cart == empty %}
  <div class="cart-container" data-section-id="{{- section.id -}}" data-section-type="template-cart">
    
    <div class="page-header">
      <h1 class="page-title">{{- 'sections.cart.title' | t -}}</h1>
    </div>

    <form class="cart-form" action="{{- routes.cart_url -}}" method="post" novalidate>
      
      <div class="cart-content">
        <div class="cart-header">
          <div class="cart-header-label cart-header-label-product">
            <p class="cart-header-label-text page-text">{{- 'sections.cart.headings.product' | t -}}</p>
          </div>
          <div class="cart-header-label cart-header-label-price">
            <p class="cart-header-label-text page-text">{{- 'sections.cart.headings.price' | t -}}</p>
          </div>
          <div class="cart-header-label cart-header-label-total">
            <p class="cart-header-label-text page-text">{{- 'sections.cart.headings.total' | t -}}</p>
          </div>
        </div>

        <div class="cart-items">
          {% for item in cart.items %}
            {% render "main-cart-item" item: item, forloop: forloop %}
          {% endfor %}
        </div>
      </div>

      <div class="cart-footer">

        {% if section.settings.cart_notes_enable %}
          <div class="cart-notes">
            <div class="cart-notes-wrapper form">
              <label class="form-label cart-notes-label" for="cartSpecialInstructions">{{- 'sections.cart.note' | t -}}</label>
              <textarea class="form-input cart-notes-textarea" name="note" id="cartSpecialInstructions">{{- cart.note -}}</textarea>
            </div>
          </div>
        {% endif %}

        <div class="cart-footer-content">
          
          <div class="cart-subtotal-box">
            {% if cart.total_discounts > 0 %}
                <span class="cart-savings-label">{{- 'sections.cart.savings' | t -}}</span>
                <span class="cart-savings-amount cart-number">{{- cart.total_discounts | money -}}</span>
            {% endif %}
            <p class="cart-subtotal-title">{{- 'sections.cart.subtotal' | t -}}</p>
            <p class="cart-subtotal-price cart-number">{{- cart.total_price | money -}}</p>
          </div>
          
          <div class="cart-taxes page-text">
            <p class="cart-taxes-text">
              {%- if shop.taxes_included and shop.shipping_policy.body != blank -%}
                {{- 'sections.cart.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url -}}
              {%- elsif shop.taxes_included -%}
                {{- 'sections.cart.taxes_included_but_shipping_at_checkout' | t -}}
              {%- elsif shop.shipping_policy.body != blank -%}
                {{- 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url -}}
              {%- else -%}
                {{- 'sections.cart.taxes_and_shipping_at_checkout' | t -}}
              {%- endif -%}
            </p>
          </div>

          {%- if note_enabled -%}
            <div class="cart-note form">
              <div class="form-field">
                <label class="form-label" for="cart-note">{{- 'sections.cart.note' | t -}}</label>
                <textarea
                  class="form-input" 
                  rows="4" 
                  id="cart-note" 
                  name="note" 
                  form="cart"
                >{{- cart.note -}}</textarea>
              </div>
              <br>
            </div>
          {%- endif -%}

          <div class="cart-buttons buttons-column"> 
            <button class="button" type="submit" name="checkout">
              {{- 'sections.cart.checkout' | t -}}
            </button>
            <a class="cart-continue-button button-underline" href="{{- button_link -}}">
              {{- button_label -}}
            </a>
          </div>

        </div>
      </div>
      
    </form>
  </div>
  
{% else %}

  <div class="page">
    <div class="page-content">
      <div class="page-header">
        <h1 class="page-title">{{- 'sections.cart.title' | t -}}</h1>
      </div>
  
      <div class="page-text page-text-fit text-center">
        <p>{{- 'sections.cart.empty' | t -}}</p>
      </div>
  
      {%- if button_link != blank and button_label != blank -%}
        <div class="button-container center page-button-wrapper">
          <a class="button" href="{{- button_link -}}">{{- button_label -}}</a>
        </div>
      {%- endif -%}
    </div>
  </div>

{% endunless %}

{% comment %}
---------------------------------------------------------------------
SCHEMA
---------------------------------------------------------------------
{% endcomment %}

{% schema %}
{
  "name": "t:sections.main-cart.name",
  "class": "cart",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "note_enabled",
      "label": "t:sections.main-cart-footer.settings.show_cart_note.label",
      "default": false
    }
  ]
}
{% endschema %}

{%- comment -%} ════════ DR. SCHÄR – Overrides de marca del carrito ════════ {%- endcomment -%}
<style>
  /* ── Título de página ("Tu carrito") ── */
  .cart .page-title {
    font-family: 'Cabin', 'Inter', sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: #2C1A0E;
  }

  /* ── Texto del carrito vacío ── */
  .cart .page-text p {
    font-family: 'Cabin', 'Inter', sans-serif;
    color: #8A7A6C;
  }

  /* ── Encabezados de columna (Producto / Precio / Total) ── */
  .cart .cart-header-label-text {
    font-family: 'Cabin', 'Inter', sans-serif;
    font-weight: 700;
    color: #2C1A0E;
  }

  /* ── Producto: título + variantes + propiedades ── */
  .cart .cart-item-title {
    font-family: 'Cabin', 'Inter', sans-serif;
    font-weight: 700;
    color: #2C1A0E;
  }
  .cart .cart-item-variant-label,
  .cart .cart-item-variant-value,
  .cart .cart-item-line-propertie-label,
  .cart .cart-item-line-propertie-value {
    font-family: 'Cabin', 'Inter', sans-serif;
    color: #8A7A6C;
  }

  /* ── Precios ── */
  .cart .cart-number,
  .cart .cart-item-info-price-text,
  .cart .cart-item-price-total-text,
  .cart .cart-item-price-unit-text {
    font-family: 'Cabin', 'Inter', sans-serif;
    color: #2C1A0E;
  }
  .cart .cart-item-old-price {
    color: #B8AA9C;
  }

  /* ── Subtotal / ahorro ── */
  .cart .cart-subtotal-title,
  .cart .cart-savings-label {
    font-family: 'Cabin', 'Inter', sans-serif;
    font-weight: 700;
    color: #2C1A0E;
  }
  .cart .cart-subtotal-price,
  .cart .cart-savings-amount {
    font-family: 'Cabin', 'Inter', sans-serif;
    font-weight: 600;
    color: #2C1A0E;
  }

  /* ── Inputs de cantidad ── */
  .cart .cart-item-info-quantity-input,
  .cart .cart-item-quantity-input {
    font-family: 'Cabin', 'Inter', sans-serif;
    color: #2C1A0E;
    border-color: #D5CBC0;
    background-color: #FFFFFF;
  }

  /* ── Botón quitar ── */
  .cart .button-cart-remove {
    font-family: 'Cabin', 'Inter', sans-serif;
    font-weight: 600;
    color: #2C1A0E;
  }
  .cart .button-cart-remove:hover {
    color: #C41E3A;
  }

  /* ── Impuestos / envío ── */
  .cart .cart-taxes-text {
    font-family: 'Cabin', 'Inter', sans-serif;
    color: #2C1A0E;
    opacity: 0.7;
  }

  /* ── Notas ── */
  .cart .cart-notes-label,
  .cart .cart-notes-textarea {
    font-family: 'Cabin', 'Inter', sans-serif;
    color: #2C1A0E;
  }
  .cart .cart-notes-textarea {
    border-color: #D5CBC0;
  }

  /* ── Bordes ── */
  .cart .cart-items {
    border-top-color: #2C1A0E;
  }
  .cart .cart-item {
    border-bottom-color: rgba(44, 26, 14, 0.15);
  }

  /* ── BOTÓN PRINCIPAL ──
     Finalizar compra (carrito con items)
     + Seguir comprando (carrito vacío) ── */
  .cart .cart-buttons .button,
  .cart .page-button-wrapper .button,
  .cart .button-container .button {
    background-color: #2C1A0E !important;
    color: #FFFFFF !important;
    border: none !important;
    border-radius: 50px !important;
    font-family: 'Cabin', 'Inter', sans-serif !important;
    font-weight: 600 !important;
    letter-spacing: 0.08em !important;
    text-transform: uppercase !important;
  }
  .cart .cart-buttons .button:hover,
  .cart .page-button-wrapper .button:hover,
  .cart .button-container .button:hover {
    background-color: #C41E3A !important;
  }

  /* ── Link "Seguir comprando" (carrito con items) ── */
  .cart .cart-continue-button {
    font-family: 'Cabin', 'Inter', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #2C1A0E;
  }
  .cart .cart-continue-button:hover,
  .cart .cart-continue-button:active {
    color: #C41E3A;
  }
</style>