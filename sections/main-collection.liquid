{%- paginate collection.products by 36 -%}

  <section class="collection {{ collection_empty_class }}" data-section-id="{{- section.id -}}" data-section-type="main-collection">

    <div class="collection-container">

      {%- if has_products -%}
        <div class="collection-header">
          {%- render "main-collection-custom-sort", collection: collection, has_products: has_products -%}
        </div>
      {%- endif -%}

      <div class="collection-content-wrapper">
        <div class="collection-content section-content" id="ProductGridContainer">

          {%- if has_products -%}
						<div class="collection-grid products-grid js-product-cards-grid">
							{%- render "product-card" for collection.products as product -%}
						</div>
						{%- render "pagination", paginate: paginate, custom_class: "collection-pagination" -%}
          {%- else -%}
						<p class="collection-message page-text page-text-fit text-center">
							{{- "sections.collection_template.empty" | t -}}
						</p>
          {%- endif -%}

        </div>
      </div>

    </div>

  </section>

{%- endpaginate -%}

{%- schema -%}
  {
    "name": "Colección",
    "class": "collection-section content-hidden"
  }
{% endschema %}
