{%- comment -%}theme-check-disable LiquidTag{%- endcomment -%}
{{- "css-main-collection.css" | asset_url | stylesheet_tag -}}

{%- liquid
	assign image = collection.image
	assign title = collection.title
	assign description = collection.description
	assign has_products = false
	assign collection_empty_class = "is-empty"

	if collection.products.size > 0
		assign has_products = true
		assign collection_empty_class = nil
	endif
-%}

{% capture collection_title %}
  {% assign splitted_title = title | split: ' ' %}

  {% for word in splitted_title %}
    {% unless forloop.last %}
      {{- word -}}
    {% endunless %}
    {% if forloop.last %}
      {% if forloop.index > 1 %}
        <span class="secondary-font-bold">{{- word -}}</span>
      {% else %}
        {{- word -}}
      {% endif %}
    {% endif %}
  {% endfor %}
{% endcapture %}

