{%- liquid 
  assign title = section.settings.title
  assign text = section.settings.text
-%}

{{- "css-page-origen-text-with-cards-blue.css" | asset_url | stylesheet_tag -}}
<script defer src="{{- 'js-page-origen-text-with-cards-blue.js' | asset_url -}}"></script>

<text-with-cards class="po-txt-cards-blue-container">
  <div class="po-txt-cards-blue-wrap">
    <div class="po-txt-cards-blue-head">
      <h1 class="po-txt-cards-blue-head-title">{{ title }}</h1>
      <div class="po-txt-cards-blue-head-text">{{ text }}</div>
    </div>
    <div class="po-txt-cards-blue-card-list">
      {%- for block in section.blocks -%}
        <div class="po-text-cards-blue-card">
          <div class="po-text-card-blue-image-wrap">
            {%- if block.settings.card_image != blank -%}
              <img src="{{ block.settings.card_image | image_url}}" alt="{{ block.settings.card_image.alt }}" loading="lazy">
            {%- endif -%}
          </div>
          <div class="po-text-card-blue-card-wrap">
            <div class="po-text-card-blue-card-title">
              <div>{{ block.settings.card_title | newline_to_br }}</div>
            </div>
            <div class="po-text-card-blue-card-text">{{ block.settings.card_text }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</text-with-cards>

{%- schema -%}
  {
    "name": "Origen - Txt y Tarjetas",
    "tag": "section",
    "class": "po-txt-cards-blue",
    "max_blocks": 2,
    "settings": [
      {
        "type": "header",
        "content": "Contenido"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Título"
      },
      {
        "type": "richtext",
        "id": "text",
        "label": "Texto"
      }
    ],
    "blocks": [
      {
        "name": "Tarjeta",
        "type": "card",
        "settings": [
          {
            "type": "image_picker",
            "id": "card_image",
            "label": "Imagen"
          },
          {
            "type": "textarea",
            "id": "card_title",
            "label": "Título"
          },
          {
            "type": "richtext",
            "id": "card_text",
            "label": "Texto"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Origen - Txt y Tarjetas",
        "category": "Origen"
      }
    ]
  }
{% endschema %}
