{{- "css-page-hallazgos-tabs.css" | asset_url | stylesheet_tag -}}
<script defer src="{{- 'js-page-hallazgos-tabs.js' | asset_url -}}"></script>
{{- 'css-image-with-form.css' | asset_url | stylesheet_tag -}}
{{- "css-page-about-us-cards-with-icons.css" | asset_url | stylesheet_tag -}}
