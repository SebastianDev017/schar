{%- liquid 
	assign title = section.settings.title
	assign text = section.settings.text
	assign image = section.settings.image
	assign form_title = section.settings.form_title
-%}

{%- liquid 
  assign section_title = section.settings.title
  assign section_text = section.settings.text
  assign blocks_size = section.blocks | size
-%}

{%- liquid 
  assign title_1 = section.settings.title_1
  assign title = section.settings.title
  assign text = section.settings.text
-%}

<div class="ings-h" data-section-id="{{- section.id -}}" data-section-type="page-hallazgos-tabs">

  <div class="ings-h-section-head">
    <h1 class="ings-h-main-title">{{ section_title }}</h1>
    <div class="ings-h-main-text">{{ section_text }}</div>
  </div>

  {%- if blocks_size > 0 -%}


    <div class="ings-h-tabs">
      <div class="ings-h-tabs-carousel-wrapper">
        <div class="ings-h-tabs-carousel swiper" data-slides="{{- blocks_size -}}">
          <div class="swiper-wrapper">
            {%- for block in section.blocks -%}
              {%- assign title = block.settings.title -%}
              {%- assign block_id = title | handleize | append: "-" | append: block.id -%}

              {%- if title != blank -%}
                <div class="ings-h-tab swiper-slide">
                  <button class="ings-h-tab-button" data-block="{{- block_id -}}" role="tab" type="button">
                    <div class="ings-h-tab-button-content">
                      <span class="ings-h-tab-title">{{- title -}}</span>
                    </div>
                  </button>
                </div>
              {%- endif -%}

            {%- endfor -%}
          </div>
        </div>
        <button class="ings-h-tabs-swiper-button swiper-button prev">
          {%- render "icon", icon: "arrow-prev-rounded" -%}
        </button>
        <button class="ings-h-tabs-swiper-button swiper-button next">
          {%- render "icon", icon: "arrow-next-rounded" -%}
        </button>
      </div>
    </div>

    <div class="ings-h-blocks">
      {%- for block in section.blocks -%}
        {%- liquid 
          assign sections_quantity = block.settings.sections_quantity
          assign title = block.settings.title
          assign section_title = block.settings.section_title
          assign block_id = title | handleize | append: "-" | append: block.id
        -%}

