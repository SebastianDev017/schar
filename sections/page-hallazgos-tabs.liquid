            <div class="ings-h-header">
              <img src="https://cdn.shopify.com/s/files/1/0272/7218/3945/files/path212.png?v=1740654179" class="ings-h-deco-img">
              <h2 class="ings-h-title"> {{ block.settings.title }}</h2>
              <img src="https://cdn.shopify.com/s/files/1/0272/7218/3945/files/path21.png?v=1740654179" class="ings-h-deco-img">
            </div>
            <div class="ings-h-main-div-description">

              <div class="ings-h-div-description">

              <p class="ings-h-description"> {{ block.settings.tab_description }}</p>

              </div>

            </div>
            <div class="ings-h-main-grid-articles">
              <h2 class="ings-h-title"> {{ block.settings.articles_heading }}</h2>
              <div class="ings-h-grid-articles">
                {%- if block.settings.article_img_1 != blank or block.settings.article_text_1 != blank -%}
                  {% render 'article-tab-content', article_image: block.settings.article_img_1, article_text: block.settings.article_text_1, article_link: block.settings.article_link_1 %}
