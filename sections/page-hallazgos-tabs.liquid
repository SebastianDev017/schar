/* ===========================================
   Estilos principales para iOS/Safari
=========================================== */
.iwf {
  position: relative; /* necesario para márgenes negativos */
  margin-top: -65px !important;
  padding-top: 0 !important;
}

@media (max-width: 680px) {
  .iwf {
    margin-top: 85px !important;
    padding-top: 0 !important;
  }
}

/* Contenedores de imágenes/formularios */
.iwf-image-form,
.iwf-form-wrapper-form,
.iwf-image-wrapper-form {
  position: relative !important; /* reemplaza unset */
  overflow: visible !important;   /* reemplaza unset */
  max-width: 500px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-right: 0;
  height: auto;
}

.iwf-form-button {
  margin-top: 15px;
}

.iwf-image-wrapper-form {
  padding: 50px;
}

/* Ajuste de la imagen dentro del wrapper */
.iwf-image-wrapper-form img {
  margin-left: -35px; /* quitar márgenes negativos problemáticos en Safari */
  height: 320px;
  max-width: 100%;
  object-fit: contain; /* asegura que no se sobreponga el texto */
}

/* Títulos con borde redondeado */
.pau-cwi-item-title-wrapper_background {
  width: 100%;
  background: #2C1A0E;
  position: relative;
  height: 40px;
  border-radius: 0 0 30px 30px;
  display: flex;
  align-items: center;
  justify-content: center;
}

@media (max-width: 1439px) {
  .pau-cwi-item-title-wrapper_background {
    border-radius: 0 0 10px 10px;
  }
}

/* ===========================================
   Ajustes solo para Safari/iOS
=========================================== */
@supports (-webkit-touch-callout: none) {
  /* Corrige márgenes negativos en iPhone */
  .iwf-image-wrapper-form img {
    margin-left: 0 !important;
  }

  /* Ajuste extra para textos sobre imágenes */
  .ings-h-article-text {
    z-index: 2;
    position: relative;
  }

  /* Evita que se peguen bloques */
  .iwf {
    margin-top: -30px !important;
  }
}


