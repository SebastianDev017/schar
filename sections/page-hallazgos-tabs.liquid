{%- schema -%}
  {
    "name": "Hallazgos - Pestañas",
    "tag": "section",
    "class": "ings-h-section",
    "max_blocks": 3,
    "settings": [
      {
        "type": "richtext",
        "id": "title",
        "label": "Título"
      },
      {
        "type": "richtext",
        "id": "text",
        "label": "Texto"
      },
    ],
    "blocks": [
      {
        "type": "text",
        "name": "Pestaña",
        "settings": [
          {
            "type": "checkbox",
            "label": "Habilitar formulario?",
            "id": "form_check"
          },
          {
            "type": "checkbox",
            "label": "Habilitar casillas de webinars y clases?",
            "id": "tabs_check"
          },
          {
            "type": "text",
            "id": "title",
            "label": "Título de la pestaña"
          },
          {
            "type": "richtext",
            "id": "tab_description",
            "label": "Breve descripción de la pestaña",
            "default": "<p></p>"
          },
          {
            "type": "text",
            "id": "articles_heading",
            "label": "Título de los artículos",
            "default": "Hallazgos Schär"
          },
          {
            "type":"header",
            "content":"Artículo 1",
          },
          {
            "type":"image_picker",
            "id":"article_img_1",
            "label":"Imagen 1",
          },
          {
            "type": "richtext",
            "id": "article_text_1",
            "label": "Texto 1"
          },
          {
            "type": "url",
            "id": "article_link_1",
            "label": "Enlace 1"
          },
          {
            "type":"header",
            "content":"Artículo 2",
          },
          {
            "type":"image_picker",
            "id":"article_img_2",
            "label":"Imagen 2",
          },
          {
            "type": "richtext",
            "id": "article_text_2",
            "label": "Texto 2"
          },
          {
            "type": "url",
            "id": "article_link_2",
            "label": "Enlace 2"
          },
          {
            "type":"header",
            "content":"Artículo 3",
          },
          {
            "type":"image_picker",
            "id":"article_img_3",
            "label":"Imagen 3",
          },
          {
            "type": "richtext",
            "id": "article_text_3",
            "label": "Texto 3"
          },
          {
            "type": "url",
            "id": "article_link_3",
            "label": "Enlace 3"
          },
          {
            "type":"header",
            "content":"Artículo 4",
          },
          {
            "type":"image_picker",
            "id":"article_img_4",
            "label":"Imagen 4",
          },
          {
            "type": "richtext",
            "id": "article_text_4",
            "label": "Texto 4"
          },
          {
            "type": "url",
            "id": "article_link_4",
            "label": "Enlace 4"
          },
          {
            "type":"header",
            "content":"Artículo 5",
          },
          {
            "type":"image_picker",
            "id":"article_img_5",
            "label":"Imagen 5",
