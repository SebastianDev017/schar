{% style %}
  @font-face {
    font-family: 'Times ExtraBold';
    src: url('https://cdn.shopify.com/s/files/1/0991/5082/3710/files/Times-ExtraBold.otf?v=1777160115') format('opentype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} {
    --ft-font-heading: 'Times ExtraBold', 'Playfair Display', serif;
    --ft-font-body: 'Inter', 'Poppins', sans-serif;
    --ft-bg: {{ bg_color }};
    --ft-text: {{ text_color }};
    --ft-heading: {{ heading_color }};
    --ft-link: {{ link_color }};
    --ft-link-hover: {{ link_hover_color }};
    --ft-input-bg: {{ input_bg }};
    --ft-input-text: {{ input_text }};
    --ft-btn-bg: {{ btn_bg }};
    --ft-btn-text: {{ btn_text }};
    --ft-btn-bg-hover: {{ btn_bg_hover }};
    --ft-social-bg: {{ social_bg }};
    --ft-social-icon: {{ social_icon_color }};
    --ft-social-bg-hover: {{ social_bg_hover }};
    --ft-legal: {{ legal_color }};
    --ft-copyright: {{ copyright_color }};
    --ft-pt: {{ padding_top }}px;
    --ft-pb: {{ padding_bottom }}px;
  }

  /* =============================================
     BASE
     ============================================= */
  .schar-footer {
    background-color: var(--ft-bg);
    padding: var(--ft-pt) var(--header-mobile-padding, 22px) var(--ft-pb);
  }

  .schar-footer__inner {
    max-width: 1314px;
    margin: 0 auto;
  }

  /* =============================================
     MENÚS – mobile: stacked, desktop: 2 cols
     ============================================= */
  .schar-footer__menus {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px 40px;
  }

  .schar-footer__menu-title {
    font-family: var(--ft-font-body);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ft-heading);
    margin: 0 0 16px 0;
  }

  .schar-footer__menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .schar-footer__menu-item {
    margin-bottom: 10px;
  }

  .schar-footer__menu-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--ft-font-body);
    font-size: 15px;
    font-weight: 400;
    color: var(--ft-link);
    text-decoration: none;
    transition: color 0.2s ease;
    line-height: 1.4;
  }

  .schar-footer__menu-link:hover {
    color: var(--ft-link-hover);
  }

  .schar-footer__menu-link.is-active {
    font-weight: 600;
  }

  .schar-footer__chevron {
    flex-shrink: 0;
    opacity: 0.6;
  }

  /* =============================================
     NEWSLETTER
     ============================================= */
  .schar-footer__newsletter {
    margin-top: 32px;
  }

  .schar-footer__newsletter-title {
    font-family: var(--ft-font-body);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ft-heading);
    margin: 0 0 12px 0;
  }

  .schar-footer__newsletter-text {
    font-family: var(--ft-font-body);
    font-size: 14px;
    color: var(--ft-text);
    margin: 0 0 16px 0;
    line-height: 1.5;
  }

  .schar-footer__newsletter-form {
    display: flex;
    width: 100%;
    max-width: 480px;
    height: 52px;
    border-radius: 50px;
    overflow: hidden;
    background-color: var(--ft-input-bg);
  }

  .schar-footer__newsletter-input {
    flex: 1;
    height: 100%;
    padding: 0 24px;
    border: none;
    background: transparent;
    font-family: var(--ft-font-body);
    font-size: 15px;
    color: var(--ft-input-text);
    outline: none;
    min-width: 0;
  }

  .schar-footer__newsletter-input::placeholder {
    color: var(--ft-input-text);
    opacity: 0.6;
  }

  .schar-footer__newsletter-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 100%;
    padding: 0 24px;
    background-color: var(--ft-btn-bg);
    color: var(--ft-btn-text);
    border: none;
    border-radius: 50px;
    font-family: var(--ft-font-body);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.3s ease;
    flex-shrink: 0;
  }

  .schar-footer__newsletter-btn:hover {
    background-color: var(--ft-btn-bg-hover);
  }

  .schar-footer__newsletter-btn-icon {
    flex-shrink: 0;
  }

  .schar-footer__newsletter-success {
    margin-top: 8px;
    font-family: var(--ft-font-body);
    font-size: 13px;
    color: #2ABCB4;
  }

  .schar-footer__newsletter-error {
    margin-top: 8px;
    font-family: var(--ft-font-body);
    font-size: 13px;
    color: #d20000;
  }

  /* =============================================
     SOCIAL
     ============================================= */
  .schar-footer__social {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 24px;
  }

  .schar-footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    text-decoration: none;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .schar-footer__social-link:hover {
    transform: scale(1.1);
    opacity: 0.85;
  }

  .schar-footer__social-link img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    border-radius: 50%;
  }

  /* =============================================
     LEGAL
     ============================================= */
  .schar-footer__legal {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid rgba(44, 26, 14, 0.12);
  }

  .schar-footer__legal-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 40px;
  }

  .schar-footer__legal-link {
    font-family: var(--ft-font-body);
    font-size: 14px;
    font-weight: 400;
    color: var(--ft-legal);
    text-decoration: none;
    transition: color 0.2s ease;
    line-height: 1.4;
  }

  .schar-footer__legal-link:hover {
    color: var(--ft-link-hover);
  }

  /* =============================================
     COPYRIGHT
     ============================================= */
  .schar-footer__copyright {
    margin-top: 24px;
    text-align: center;
  }

  .schar-footer__copyright-text {
    font-family: var(--ft-font-body);
    font-size: 12px;
    color: var(--ft-copyright);
    line-height: 1.5;
    opacity: 0.7;
    margin: 0;
  }

  /* =============================================
     PAYMENT
     ============================================= */
  .schar-footer__payment {
    margin-top: 20px;
    text-align: center;
  }

  .schar-footer__payment-icons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .schar-footer__payment-icon {
    height: 24px;
    width: auto;
  }

  /* =============================================
     RESPONSIVE
     ============================================= */

  /* Tablet */
  @media (min-width: 681px) {
    .schar-footer {
      padding-left: var(--header-tablet-padding, 46px);
      padding-right: var(--header-tablet-padding, 46px);
    }

    .schar-footer__menus {
      gap: 24px 60px;
    }
  }

  /* Desktop */
  @media (min-width: 835px) {
    .schar-footer {
      padding-left: var(--header-desktop-padding, 63px);
      padding-right: var(--header-desktop-padding, 63px);
    }

    .schar-footer__menus {
      grid-template-columns: repeat(auto-fit, minmax(180px, max-content));
      gap: 0 60px;
      justify-content:space-between;
    }

    .schar-footer__newsletter {
      margin-top: 36px;
    }

    .schar-footer__legal-list {
      grid-template-columns: repeat(auto-fill, minmax(180px, max-content));
      gap: 8px 40px;
    }
  }

  @media (max-width: 480px) {
    .schar-footer__newsletter-form {
      height: 48px;
    }

    .schar-footer__newsletter-input {
      padding: 0 18px;
      font-size: 14px;
    }

    .schar-footer__newsletter-btn {
      padding: 0 18px;
      font-size: 14px;
    }

    .schar-footer__social-link {
      width: 38px;
      height: 38px;
    }

    .schar-footer__social-link svg {
      width: 18px;
      height: 18px;
    }
  }

  @media (hover: hover) {
    .schar-footer__menu-link:hover { color: var(--ft-link-hover); }
