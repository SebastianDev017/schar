{%- comment -%}
  Footer – Schar México
  ✔ Mobile-first
  ✔ 2 columnas de menú + newsletter + social + legales + copyright
  ✔ Formulario de newsletter nativo Shopify
  ✔ Máxima personalización (30+ controles)
  ✔ Times ExtraBold headings, Inter body
{%- endcomment -%}

{%- liquid
  assign legal_menu = section.settings.legal_menu
  assign legal_menu_links = linklists[legal_menu].links
  assign copyright_text = section.settings.copyright_text | default: shop.name
  assign bg_color = section.settings.bg_color | default: '#F5C842'
  assign text_color = section.settings.text_color | default: '#2C1A0E'
  assign link_color = section.settings.link_color | default: '#2C1A0E'
  assign link_hover_color = section.settings.link_hover_color | default: '#C41E3A'
  assign heading_color = section.settings.heading_color | default: '#2C1A0E'
  assign input_bg = section.settings.input_bg_color | default: '#FFFFFF'
  assign input_text = section.settings.input_text_color | default: '#2C1A0E'
  assign btn_bg = section.settings.button_bg_color | default: '#6D6560'
  assign btn_text = section.settings.button_text_color | default: '#FFFFFF'
  assign btn_bg_hover = section.settings.button_bg_hover | default: '#2C1A0E'
  assign social_bg = section.settings.social_bg_color | default: '#2C1A0E'
  assign social_icon_color = section.settings.social_icon_color | default: '#FFFFFF'
  assign social_bg_hover = section.settings.social_bg_hover | default: '#C41E3A'
  assign legal_color = section.settings.legal_color | default: '#2C1A0E'
  assign copyright_color = section.settings.copyright_color | default: '#2C1A0E'
  assign padding_top = section.settings.padding_top | default: 60
  assign padding_bottom = section.settings.padding_bottom | default: 40
  assign show_payment = section.settings.show_payment_icons
-%}

<footer class="schar-footer" id="schar-footer">
  <div class="schar-footer__inner">

    {%- comment -%} ── MENÚS ── {%- endcomment -%}
    <div class="schar-footer__menus">
      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          {%- assign menu_handle = block.settings.menu -%}
          {%- assign menu_links = linklists[menu_handle].links -%}
          <div class="schar-footer__menu-col" {{ block.shopify_attributes }}>
            {%- unless block.settings.title == blank -%}
              <p class="schar-footer__menu-title">{{ block.settings.title }}</p>
            {%- endunless -%}
            {%- if menu_links.size > 0 -%}
              <ul class="schar-footer__menu-list">
                {%- for link in menu_links -%}
                  <li class="schar-footer__menu-item">
                    <a
                      href="{{ link.url }}"
                      class="schar-footer__menu-link{% if link.current %} is-active{% endif %}"
                      {%- if link.url contains 'http' %} target="_blank" rel="noopener"{% endif -%}
                    >
                      {{ link.title }}
                      {%- if block.settings.show_chevron -%}
                        <svg class="schar-footer__chevron" viewBox="0 0 24 24" width="16" height="16"><polyline points="9 18 15 12 9 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      {%- endif -%}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} ── NEWSLETTER ── {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'newsletter' -%}
        <div class="schar-footer__newsletter" {{ block.shopify_attributes }}>
          {%- unless block.settings.title == blank -%}
            <p class="schar-footer__newsletter-title">{{ block.settings.title }}</p>
          {%- endunless -%}
          {%- unless block.settings.text == blank -%}
            <p class="schar-footer__newsletter-text">{{ block.settings.text }}</p>
          {%- endunless -%}

          {%- form 'customer', id: 'schar-footer-newsletter' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="schar-footer__newsletter-form">
              <input
                type="email"
                name="contact[email]"
                class="schar-footer__newsletter-input"
                placeholder="{{ block.settings.placeholder | default: 'Correo electrónico' }}"
                required
                autocomplete="email"
                aria-label="{{ block.settings.placeholder | default: 'Correo electrónico' }}"
              >
              <button type="submit" class="schar-footer__newsletter-btn">
                <span class="schar-footer__newsletter-btn-text">{{ block.settings.button_text | default: 'Enviar' }}</span>
                <svg class="schar-footer__newsletter-btn-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
            {%- if form.posted_successfully? -%}
              <p class="schar-footer__newsletter-success">¡Gracias por suscribirte!</p>
            {%- endif -%}
            {%- if form.errors -%}
              <p class="schar-footer__newsletter-error">{{ form.errors.messages['email'] }}</p>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} ── SOCIAL ── {%- endcomment -%}
    <div class="schar-footer__social">
      {%- if section.settings.social_facebook != blank -%}
        <a href="{{ section.settings.social_facebook }}" class="schar-footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
          <img src="{{ 'facebook-light.png' | asset_url }}" alt="Facebook" width="42" height="42" loading="lazy">
        </a>
      {%- endif -%}
      {%- if section.settings.social_instagram != blank -%}
        <a href="{{ section.settings.social_instagram }}" class="schar-footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
          <img src="{{ 'instagram-light.png' | asset_url }}" alt="Instagram" width="42" height="42" loading="lazy">
        </a>
      {%- endif -%}
      {%- if section.settings.social_tiktok != blank -%}
        <a href="{{ section.settings.social_tiktok }}" class="schar-footer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
          <img src="{{ 'tiktok-light.png' | asset_url }}" alt="TikTok" width="42" height="42" loading="lazy">
        </a>
      {%- endif -%}
      {%- if section.settings.social_youtube != blank -%}
        <a href="{{ section.settings.social_youtube }}" class="schar-footer__social-link" aria-label="YouTube" target="_blank" rel="noopener">
          <img src="{{ 'youtube-light.png' | asset_url }}" alt="YouTube" width="42" height="42" loading="lazy">
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} ── LEGALES ── {%- endcomment -%}
    {%- unless legal_menu == blank -%}
      <div class="schar-footer__legal">
        <ul class="schar-footer__legal-list">
          {%- for link in legal_menu_links -%}
            <li class="schar-footer__legal-item">
              <a href="{{ link.url }}" class="schar-footer__legal-link" {%- if link.url contains 'http' %} target="_blank" rel="noopener"{% endif -%}>
                {{ link.title }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endunless -%}

    {%- comment -%} ── COPYRIGHT ── {%- endcomment -%}
    <div class="schar-footer__copyright">
      <p class="schar-footer__copyright-text">
        {{ copyright_text }}, {{ 'now' | date: '%Y' }}
      </p>
    </div>

    {%- comment -%} ── PAYMENT ICONS ── {%- endcomment -%}
    {%- if show_payment -%}
      <div class="schar-footer__payment">
        {%- unless shop.enabled_payment_types == empty -%}
          <div class="schar-footer__payment-icons">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'schar-footer__payment-icon' }}
            {%- endfor -%}
          </div>
        {%- endunless -%}
      </div>
    {%- endif -%}

  </div>
</footer>

