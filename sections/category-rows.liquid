{%- comment -%}
  Section 7: Descubre el Libre de Gluten – Dr. Schär México
  ✔ Título arriba + filas de categorías con imagen de fondo
  ✔ Cada fila es un enlace clickeable
  ✔ Imágenes full-width, overlay oscuro, texto centrado
  ✔ Máxima personalización (35+ controles)
{%- endcomment -%}

{%- liquid
  assign heading = section.settings.heading
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign heading_size_desktop = section.settings.heading_size_desktop | default: 56
  assign heading_size_mobile = section.settings.heading_size_mobile | default: 32
  assign heading_color = section.settings.heading_color | default: '#2C1A0E'
  assign heading_line_height = section.settings.heading_line_height | default: 110
  assign heading_margin_bottom = section.settings.heading_margin_bottom | default: 0
  assign bg_color = section.settings.bg_color | default: '#F5F0EB'
  assign padding_top = section.settings.padding_top | default: 60
  assign padding_bottom = section.settings.padding_bottom | default: 0
  assign row_height_desktop = section.settings.row_height_desktop | default: 120
  assign row_height_mobile = section.settings.row_height_mobile | default: 80
  assign overlay_color = section.settings.overlay_color | default: '#2C1A0E'
  assign overlay_opacity = section.settings.overlay_opacity | default: 35
  assign overlay_opacity_decimal = overlay_opacity | divided_by: 100.0
  assign row_text_size_desktop = section.settings.row_text_size_desktop | default: 40
  assign row_text_size_mobile = section.settings.row_text_size_mobile | default: 24
  assign row_text_color = section.settings.row_text_color | default: '#F5C842'
  assign row_gap = section.settings.row_gap | default: 0
  assign text_alignment = section.settings.text_alignment | default: 'center'
  assign heading_padding = section.settings.heading_padding | default: 40
-%}

<section class="schar-discover" data-section-id="{{ section.id }}">

  {%- comment -%} TÍTULO {%- endcomment -%}
  {%- unless heading == blank -%}
    <div class="schar-discover__header" style="text-align: {{ text_alignment }};">
      <{{ heading_tag }} class="schar-discover__heading" data-aos="fade-up">{{ heading }}</{{ heading_tag }}>
    </div>
  {%- endunless -%}

  {%- comment -%} FILAS DE CATEGORÍAS {%- endcomment -%}
  <div class="schar-discover__rows">
    {%- for block in section.blocks -%}
      {%- liquid
        assign row_label = block.settings.label | default: 'Categoría'
        assign row_link = block.settings.link
        assign row_image = block.settings.image
      -%}

      {%- if row_link != blank -%}
        <a href="{{ row_link }}" class="schar-discover__row" {{ block.shopify_attributes }} data-aos="fade-up" data-aos-delay="{{ forloop.index | times: 80 }}">
      {%- else -%}
        <div class="schar-discover__row" {{ block.shopify_attributes }} data-aos="fade-up" data-aos-delay="{{ forloop.index | times: 80 }}">
      {%- endif -%}

        <div class="schar-discover__row-bg">
          {%- if row_image != blank -%}
            <img
              src="{{ row_image | image_url: width: 1920 }}"
              alt="{{ row_label | escape }}"
              class="schar-discover__row-img"
              loading="lazy"
            >
          {%- else -%}
            {%- comment -%} Placeholder images from Pixabay {%- endcomment -%}
            {%- case forloop.index -%}
              {%- when 1 -%}
                <img src="https://cdn.pixabay.com/photo/2017/06/23/23/57/bread-2436370_1280.jpg" alt="{{ row_label }}" class="schar-discover__row-img" loading="lazy">
              {%- when 2 -%}
                <img src="https://cdn.pixabay.com/photo/2017/09/05/17/18/pretzel-2718477_1280.jpg" alt="{{ row_label }}" class="schar-discover__row-img" loading="lazy">
              {%- when 3 -%}
                <img src="https://cdn.pixabay.com/photo/2016/12/20/18/44/cookies-1921621_1280.jpg" alt="{{ row_label }}" class="schar-discover__row-img" loading="lazy">
              {%- when 4 -%}
                <img src="https://cdn.pixabay.com/photo/2018/02/25/07/15/food-3179853_1280.jpg" alt="{{ row_label }}" class="schar-discover__row-img" loading="lazy">
              {%- when 5 -%}
                <img src="https://cdn.pixabay.com/photo/2017/01/16/17/45/pasta-1984528_1280.jpg" alt="{{ row_label }}" class="schar-discover__row-img" loading="lazy">
              {%- else -%}
                <img src="https://cdn.pixabay.com/photo/2014/07/22/09/59/bread-399286_1280.jpg" alt="{{ row_label }}" class="schar-discover__row-img" loading="lazy">
            {%- endcase -%}
          {%- endif -%}
        </div>

        <div class="schar-discover__row-overlay"></div>

        <span class="schar-discover__row-label">{{ row_label }}</span>

      {%- if row_link != blank -%}
        </a>
      {%- else -%}
        </div>
      {%- endif -%}

    {%- endfor -%}
  </div>

</section>

{% schema %}
{
  "name": "Categorías con Imagen",
  "tag": "section",
  "class": "schar-discover-section",
  "settings": [
    {
      "type": "header",
      "content": "── TÍTULO ──"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Título",
      "default": "<p>descubre el<br><strong>libre de gluten</strong></p>"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Etiqueta HTML",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ]
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Tamaño título desktop (px)",
      "min": 24,
      "max": 120,
      "step": 2,
      "default": 56,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Tamaño título mobile (px)",
      "min": 20,
      "max": 72,
      "step": 2,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "label": "Line-height título (%)",
      "min": 80,
      "max": 160,
      "step": 5,
      "default": 110,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color del título",
      "default": "#2C1A0E"
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "label": "Margen inferior título (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_padding",
      "label": "Padding del área de título (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alineación del título",
      "default": "center",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Derecha" }
      ]
    },
    {
      "type": "header",
      "content": "── SECCIÓN ──"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo (título)",
      "default": "#F5F0EB"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "── FILAS ──"
    },
    {
      "type": "range",
      "id": "row_height_desktop",
      "label": "Altura fila desktop (px)",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 120,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "row_height_mobile",
      "label": "Altura fila mobile (px)",
      "min": 50,
      "max": 200,
      "step": 10,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "row_gap",
      "label": "Espacio entre filas (px)",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "── OVERLAY ──"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Color del overlay",
      "default": "#2C1A0E"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacidad overlay (%)",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 35,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "── TEXTO DE FILAS ──"
    },
    {
      "type": "range",
      "id": "row_text_size_desktop",
      "label": "Tamaño desktop (px)",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "row_text_size_mobile",
      "label": "Tamaño mobile (px)",
      "min": 18,
      "max": 48,
      "step": 2,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "row_text_color",
      "label": "Color del texto",
      "default": "#F5C842"
    }
  ],
  "max_blocks": 10,
  "blocks": [
    {
      "name": "Categoría",
      "type": "category_row",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Nombre de la categoría",
          "default": "Categoría"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen de fondo",
          "info": "Si no subes imagen, se usa un placeholder."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categorías con Imagen",
      "category": "Homepage",
      "blocks": [
        { "type": "category_row", "settings": { "label": "pan y crujientes" } },
        { "type": "category_row", "settings": { "label": "snacks dulces y salado" } },
        { "type": "category_row", "settings": { "label": "harinas" } },
        { "type": "category_row", "settings": { "label": "cereales" } },
        { "type": "category_row", "settings": { "label": "pasta" } }
      ]
    }
  ]
}
{% endschema %}

{% style %}
  @font-face {
    font-family: 'Times ExtraBold';
    src: url('https://cdn.shopify.com/s/files/1/0991/5082/3710/files/Times-ExtraBold.otf?v=1777160115') format('opentype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} {
    --disc-font-heading: 'Times ExtraBold', 'Playfair Display', serif;
    --disc-font-body: 'Inter', 'Poppins', sans-serif;
    --disc-bg: {{ bg_color }};
    --disc-pt: {{ padding_top }}px;
    --disc-pb: {{ padding_bottom }}px;
    --disc-h-desktop: {{ heading_size_desktop }}px;
    --disc-h-mobile: {{ heading_size_mobile }}px;
    --disc-h-color: {{ heading_color }};
    --disc-h-lh: {{ heading_line_height }}%;
    --disc-h-mb: {{ heading_margin_bottom }}px;
    --disc-h-padding: {{ heading_padding }}px;
    --disc-row-h-desktop: {{ row_height_desktop }}px;
    --disc-row-h-mobile: {{ row_height_mobile }}px;
    --disc-row-gap: {{ row_gap }}px;
    --disc-overlay-color: {{ overlay_color }};
    --disc-overlay-opacity: {{ overlay_opacity_decimal }};
    --disc-row-text-desktop: {{ row_text_size_desktop }}px;
    --disc-row-text-mobile: {{ row_text_size_mobile }}px;
    --disc-row-text-color: {{ row_text_color }};
  }

  /* =============================================
     BASE
     ============================================= */
  .schar-discover {
    padding-bottom: var(--disc-pb);
  }

  /* =============================================
     HEADER (título)
     ============================================= */
  .schar-discover__header {
    background-color: var(--disc-bg);
    padding: var(--disc-pt) var(--header-mobile-padding, 22px) var(--disc-h-padding);
  }

  .schar-discover__heading,
  .schar-discover__heading * {
    font-family: var(--disc-font-heading) !important;
    font-style: normal;
    font-weight: 400 !important;
    color: var(--disc-h-color);
    font-size: clamp(
      var(--disc-h-mobile),
      calc(var(--disc-h-mobile) + ({{ heading_size_desktop }} - {{ heading_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--disc-h-desktop)
    );
    line-height: var(--disc-h-lh);
    margin: 0 0 var(--disc-h-mb) 0;
  }

  .schar-discover__heading strong,
  .schar-discover__heading strong *,
  .schar-discover__heading b,
  .schar-discover__heading b * {
    font-weight: 400 !important;
    color: #C41E3A;
  }

  /* =============================================
     ROWS
     ============================================= */
  .schar-discover__rows {
    display: flex;
    flex-direction: column;
    gap: var(--disc-row-gap);
  }

  .schar-discover__row {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: var(--disc-row-h-mobile);
    overflow: hidden;
    text-decoration: none;
    cursor: pointer;
  }

  /* Background image */
  .schar-discover__row-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .schar-discover__row-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.5s ease;
  }

  .schar-discover__row:hover .schar-discover__row-img {
    transform: scale(1.05);
  }

  /* Overlay */
  .schar-discover__row-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-color: var(--disc-overlay-color);
    opacity: var(--disc-overlay-opacity);
    transition: opacity 0.3s ease;
  }

  .schar-discover__row:hover .schar-discover__row-overlay {
    opacity: calc(var(--disc-overlay-opacity) + 0.1);
  }

  /* Label */
  .schar-discover__row-label {
    position: relative;
    z-index: 2;
    font-family: var(--disc-font-heading);
    font-size: clamp(
      var(--disc-row-text-mobile),
      calc(var(--disc-row-text-mobile) + ({{ row_text_size_desktop }} - {{ row_text_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--disc-row-text-desktop)
    );
    font-weight: 400;
    color: var(--disc-row-text-color);
    text-align: center;
    line-height: 1.2;
    padding: 0 20px;
    transition: transform 0.3s ease;
  }

  .schar-discover__row:hover .schar-discover__row-label {
    transform: translateY(-2px);
  }

  /* =============================================
     DESKTOP
     ============================================= */
  @media (min-width: 681px) {
    .schar-discover__header {
      padding-left: var(--header-tablet-padding, 46px);
      padding-right: var(--header-tablet-padding, 46px);
    }

    .schar-discover__row {
      height: var(--disc-row-h-desktop);
    }
  }

  @media (min-width: 835px) {
    .schar-discover__header {
      padding-left: var(--header-desktop-padding, 63px);
      padding-right: var(--header-desktop-padding, 63px);
    }
  }

  @media (hover: hover) {
    .schar-discover__row:hover .schar-discover__row-img {
      transform: scale(1.05);
    }
    .schar-discover__row:hover .schar-discover__row-overlay {
      opacity: calc(var(--disc-overlay-opacity) + 0.1);
    }
    .schar-discover__row:hover .schar-discover__row-label {
      transform: translateY(-2px);
    }
  }
{% endstyle %}
