<section class="page">
  <article class="page-content">
    <header class="page-header">
      <h1 class="page-title">{{- page.title -}}</h1>
    </header>
  
    <div class="page-text page-text-fit">
      {{- page.content -}}
    </div>
  </article>
</section>

{% schema %}
{
  "name": "t:sections.main-page.name"
}
{% endschema %}
