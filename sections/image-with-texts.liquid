    {
      "type": "header",
      "content": "── FONDO Y ESPACIADO ──"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#E8DDD0"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "── TÍTULO ──"
    },
    {
