{%- comment -%}
  Sección: Imagen con Texto – Dr. Schär México
  ✔ 2 columnas desktop: texto izq + imagen der (invertible)
  ✔ 1 columna mobile: imagen arriba, texto abajo
  ✔ Aspect ratio de imagen seleccionable
  ✔ Máxima personalización (40+ controles)
{%- endcomment -%}

{%- liquid
  assign image = section.settings.image
  assign mobile_image = section.settings.mobile_image
  assign heading = section.settings.heading
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign text_content = section.settings.text_content
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
  assign has_button = false
  if button_label != blank and button_link != blank
    assign has_button = true
  endif

  assign image_position = section.settings.image_position | default: 'right'
  assign image_ratio = section.settings.image_ratio | default: 'portrait'
  assign image_custom_ratio = section.settings.image_custom_ratio | default: 75
  assign vertical_align = section.settings.vertical_align | default: 'center'

  assign heading_size_desktop = section.settings.heading_size_desktop | default: 48
  assign heading_size_mobile = section.settings.heading_size_mobile | default: 32
  assign heading_color = section.settings.heading_color | default: '#2C1A0E'
  assign heading_line_height = section.settings.heading_line_height | default: 110
  assign text_size_desktop = section.settings.text_size_desktop | default: 16
  assign text_size_mobile = section.settings.text_size_mobile | default: 15
  assign text_color = section.settings.text_color | default: '#2C1A0E'
  assign bg_color = section.settings.bg_color | default: '#E8DDD0'
  assign padding_top = section.settings.padding_top | default: 0
  assign padding_bottom = section.settings.padding_bottom | default: 0
  assign content_gap = section.settings.content_gap | default: 60
  assign image_col_width = section.settings.image_col_width | default: 50
  assign text_padding = section.settings.text_padding | default: 40

  assign btn_bg = section.settings.button_bg_color | default: '#2C1A0E'
  assign btn_text = section.settings.button_text_color | default: '#FFFFFF'
  assign btn_bg_hover = section.settings.button_bg_hover | default: '#C41E3A'
  assign btn_text_hover = section.settings.button_text_hover | default: '#FFFFFF'
  assign btn_radius = section.settings.button_border_radius | default: 50
  assign btn_size_desktop = section.settings.button_size_desktop | default: 14
  assign btn_size_mobile = section.settings.button_size_mobile | default: 13
  assign btn_margin_top = section.settings.button_margin_top | default: 28
-%}

{%- capture ratio_class -%}
  {%- case image_ratio -%}
    {%- when 'portrait' -%}schar-iwt__img-wrap--portrait
    {%- when 'square' -%}schar-iwt__img-wrap--square
    {%- when 'landscape' -%}schar-iwt__img-wrap--landscape
    {%- when 'auto' -%}schar-iwt__img-wrap--auto
    {%- when 'custom' -%}schar-iwt__img-wrap--custom
  {%- endcase -%}
{%- endcapture -%}

<section class="schar-iwt schar-iwt--img-{{ image_position }}" data-section-id="{{ section.id }}">
  <div class="schar-iwt__inner schar-iwt__valign--{{ vertical_align }}">

    {%- comment -%} COLUMNA DE TEXTO {%- endcomment -%}
    <div class="schar-iwt__text-col" data-aos="fade-up">
      {%- unless heading == blank -%}
        <{{ heading_tag }} class="schar-iwt__heading">{{ heading }}</{{ heading_tag }}>
      {%- endunless -%}

      {%- unless text_content == blank -%}
        <div class="schar-iwt__text">{{ text_content }}</div>
      {%- endunless -%}

      {%- if has_button -%}
        <div class="schar-iwt__btn-wrap">
          <a class="schar-iwt__btn" href="{{ button_link }}" {%- if button_link contains 'http' %} target="_blank" rel="noopener"{% endif -%}>
            {{ button_label }}
          </a>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} COLUMNA DE IMAGEN {%- endcomment -%}
    {%- if image != blank -%}
      <div class="schar-iwt__img-col" data-aos="fade-up" data-aos-delay="150">
        <div class="schar-iwt__img-wrap {{ ratio_class }}">
          <picture>
            {%- if mobile_image != blank -%}
              <source media="(max-width: 680px)" srcset="{{ mobile_image | image_url: width: 800 }}">
            {%- endif -%}
            <img
              src="{{ image | image_url: width: 1200 }}"
              alt="{{ image.alt | escape | default: heading | strip_html | escape }}"
              class="schar-iwt__img"
              loading="lazy"
            >
          </picture>
        </div>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Imagen con Texto",
  "tag": "section",
  "class": "schar-iwt-section",
  "settings": [
    {
      "type": "header",
      "content": "── IMAGEN ──"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Imagen mobile (opcional)"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Proporción de imagen",
      "default": "portrait",
      "options": [
        { "value": "portrait", "label": "Retrato (3:4)" },
        { "value": "square", "label": "Cuadrado (1:1)" },
        { "value": "landscape", "label": "Paisaje (4:3)" },
        { "value": "auto", "label": "Ajustado a imagen" },
        { "value": "custom", "label": "Personalizado" }
      ]
    },
    {
      "type": "range",
      "id": "image_custom_ratio",
      "label": "Ratio personalizado (%)",
      "min": 40,
      "max": 160,
      "step": 5,
      "default": 75,
      "unit": "%",
      "info": "Solo aplica con proporción 'Personalizado'. Alto relativo al ancho."
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Posición de la imagen",
      "default": "right",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "right", "label": "Derecha" }
      ]
    },
    {
      "type": "range",
      "id": "image_col_width",
      "label": "Ancho columna imagen (%)",
      "min": 30,
      "max": 70,
      "step": 5,
      "default": 50,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "── CONTENIDO ──"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Título",
      "default": "<p><strong>calidad</strong></p>"
    },
    {
      "type": "richtext",
      "id": "text_content",
      "label": "Texto",
      "default": "<p>La calidad ha sido, y siempre será, el pilar de todo lo que hacemos.</p><p>Desde la selección de los mejores cereales sin gluten hasta el tiempo que dedicamos a nuestros clientes, la calidad se refleja en el esfuerzo invertido.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón"
    },
    {
      "type": "header",
      "content": "── LAYOUT ──"
    },
    {
      "type": "select",
      "id": "vertical_align",
      "label": "Alineación vertical",
      "default": "center",
      "options": [
        { "value": "top", "label": "Arriba" },
        { "value": "center", "label": "Centro" },
        { "value": "bottom", "label": "Abajo" }
      ]
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Espacio entre columnas (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px"
