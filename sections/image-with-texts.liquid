{% style %}
  @font-face {
    font-family: 'Times ExtraBold';
    src: url('https://cdn.shopify.com/s/files/1/0991/5082/3710/files/Times-ExtraBold.otf?v=1777160115') format('opentype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} {
    --iwt-font-heading: 'Times ExtraBold', 'Playfair Display', serif;
    --iwt-font-body: 'Cabin', 'Inter', 'Poppins', sans-serif;
    --iwt-bg: {{ bg_color }};
    --iwt-pt: {{ padding_top }}px;
    --iwt-pb: {{ padding_bottom }}px;
    --iwt-gap: {{ content_gap }}px;
    --iwt-img-col: {{ image_col_width }}%;
    --iwt-text-pad: {{ text_padding }}px;
    --iwt-custom-ratio: {{ image_custom_ratio }}%;

    --iwt-h-desktop: {{ heading_size_desktop }}px;
    --iwt-h-mobile: {{ heading_size_mobile }}px;
    --iwt-h-color: {{ heading_color }};
    --iwt-h-lh: {{ heading_line_height }}%;
    --iwt-t-desktop: {{ text_size_desktop }}px;
    --iwt-t-mobile: {{ text_size_mobile }}px;
    --iwt-t-color: {{ text_color }};

    --iwt-btn-bg: {{ btn_bg }};
    --iwt-btn-text: {{ btn_text }};
    --iwt-btn-bg-hover: {{ btn_bg_hover }};
    --iwt-btn-text-hover: {{ btn_text_hover }};
    --iwt-btn-radius: {{ btn_radius }}px;
    --iwt-btn-desktop: {{ btn_size_desktop }}px;
    --iwt-btn-mobile: {{ btn_size_mobile }}px;
    --iwt-btn-mt: {{ btn_margin_top }}px;
  }

  /* =============================================
     BASE
     ============================================= */
  .schar-iwt {
    background-color: var(--iwt-bg);
    padding: var(--iwt-pt) 0 var(--iwt-pb);
    margin-bottom: 0;
    position: relative;
    z-index: 1;
  }

  .schar-iwt__inner {
    display: grid;
    grid-template-columns: 1fr var(--iwt-img-col);
    gap: var(--iwt-gap);
    max-width: 1440px;
    margin: 0 auto;
  }

  /* Vertical alignment */
  .schar-iwt__valign--top    { align-items: start; }
  .schar-iwt__valign--center { align-items: center; }
  .schar-iwt__valign--bottom { align-items: end; }

  /* Imagen a la izquierda: invertir orden */
  .schar-iwt--img-left .schar-iwt__inner {
    grid-template-columns: var(--iwt-img-col) 1fr;
  }

  .schar-iwt--img-left .schar-iwt__text-col { order: 2; }
  .schar-iwt--img-left .schar-iwt__img-col  { order: 1; }

  /* =============================================
     TEXTO
     ============================================= */
  .schar-iwt__text-col {
    padding: var(--iwt-text-pad) var(--header-desktop-padding, 63px);
  }

  .schar-iwt__heading,
  .schar-iwt__heading * {
    font-family: var(--iwt-font-heading) !important;
    font-style: normal;
    font-weight: 400 !important;
    color: var(--iwt-h-color);
    font-size: clamp(
      var(--iwt-h-mobile),
      calc(var(--iwt-h-mobile) + ({{ heading_size_desktop }} - {{ heading_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--iwt-h-desktop)
    );
    line-height: var(--iwt-h-lh);
    margin: 0 0 20px 0;
  }

  .schar-iwt__heading strong,
  .schar-iwt__heading b {
    font-weight: 400 !important;
  }

  .schar-iwt__text,
  .schar-iwt__text * {
    font-family: var(--iwt-font-body);
    font-size: clamp(
      var(--iwt-t-mobile),
      calc(var(--iwt-t-mobile) + ({{ text_size_desktop }} - {{ text_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--iwt-t-desktop)
    );
    line-height: 1.7;
    color: var(--iwt-t-color);
  }

  .schar-iwt__text p { margin: 0; }
  .schar-iwt__text p + p { margin-top: 16px; }

  .schar-iwt__text strong,
  .schar-iwt__text b {
    font-weight: 600;
  }

  .schar-iwt__text a {
    color: var(--iwt-h-color);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .schar-iwt__text a:hover {
    color: var(--iwt-btn-bg-hover);
  }

  /* =============================================
     BOTÓN
     ============================================= */
  .schar-iwt__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    padding: 0 32px;
    background-color: var(--iwt-btn-bg);
    color: var(--iwt-btn-text);
    border: none;
    border-radius: var(--iwt-btn-radius);
    font-family: var(--iwt-font-body);
    font-size: clamp(
      var(--iwt-btn-mobile),
      calc(var(--iwt-btn-mobile) + ({{ btn_size_desktop }} - {{ btn_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--iwt-btn-desktop)
    );
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.3s ease, color 0.3s ease, transform 0.2s ease;
  }

  .schar-iwt__btn:hover {
    background-color: var(--iwt-btn-bg-hover);
    color: var(--iwt-btn-text-hover);
    transform: translateY(-1px);
  }

  .schar-iwt__btn-wrap {
    margin-top: var(--iwt-btn-mt);
  }

  /* =============================================
     IMAGEN
     ============================================= */
  .schar-iwt__img-col {
    position: relative;
    overflow: hidden;
  }

  .schar-iwt__img-wrap {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 24px;
  }

  .schar-iwt__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Ratios */
  .schar-iwt__img-wrap--portrait {
    aspect-ratio: 3 / 4;
  }

  .schar-iwt__img-wrap--square {
    aspect-ratio: 1 / 1;
  }

  .schar-iwt__img-wrap--landscape {
    aspect-ratio: 4 / 3;
  }

  .schar-iwt__img-wrap--auto {
    aspect-ratio: unset;
  }

  .schar-iwt__img-wrap--auto .schar-iwt__img {
    height: auto;
    object-fit: contain;
  }

  .schar-iwt__img-wrap--custom {
    aspect-ratio: unset;
    padding-bottom: var(--iwt-custom-ratio);
  }

  .schar-iwt__img-wrap--custom .schar-iwt__img {
    position: absolute;
    top: 0;
    left: 0;
  }

  /* =============================================
     MOBILE
     ============================================= */
  @media (max-width: 680px) {
    .schar-iwt__inner {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    /* Imagen siempre arriba en mobile */
    .schar-iwt__img-col { order: 1; }
    .schar-iwt__text-col { order: 2; }

    .schar-iwt__text-col {
      padding: 28px var(--header-mobile-padding, 22px) 36px;
    }

    /* Sin border-radius en mobile (full-width) */
    .schar-iwt__img-wrap {
      border-radius: 0;
    }

    .schar-iwt__img-wrap--portrait,
    .schar-iwt__img-wrap--square,
    .schar-iwt__img-wrap--landscape {
      aspect-ratio: unset;
      max-height: 400px;
    }

    .schar-iwt__heading {
      margin-bottom: 16px;
    }
  }

  @media (min-width: 681px) and (max-width: 834px) {
    .schar-iwt__text-col {
      padding: var(--iwt-text-pad) var(--header-tablet-padding, 46px);
    }
  }

  @media (min-width: 835px) and (max-width: 1439px) {
    .schar-iwt__text-col {
      padding: var(--iwt-text-pad) var(--header-laptop-padding, 46px);
    }
  }

  @media (hover: hover) {
    .schar-iwt__btn:hover {
      background-color: var(--iwt-btn-bg-hover);
      color: var(--iwt-btn-text-hover);
    }
  }

  @media screen and (max-width: 760px) {
  .schar-iwt {
    padding: 0;
  }
}
{% endstyle %}
