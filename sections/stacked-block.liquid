{%- comment -%}
  Section 5: Bloque Vertical – Dr. Schär México
  ✔ Imagen FULL-WIDTH (sangre completa, borde a borde)
  ✔ Título y botón centrados dentro de contenedor
  ✔ Altura de imagen editable, ancho siempre 100vw
  ✔ Máxima personalización (42+ controles)
{%- endcomment -%}

{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign image = section.settings.image
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign text_alignment = section.settings.text_alignment | default: 'center'

  assign has_button = false
  if button_label != blank and button_link != blank
    assign has_button = true
  endif

  assign has_image = false
  if image != blank
    assign has_image = true
  endif

  assign heading_size_desktop = section.settings.heading_size_desktop | default: 56
  assign heading_size_mobile = section.settings.heading_size_mobile | default: 32
  assign subheading_size_desktop = section.settings.subheading_size_desktop | default: 16
  assign subheading_size_mobile = section.settings.subheading_size_mobile | default: 14
  assign btn_size_desktop = section.settings.button_size_desktop | default: 14
  assign btn_size_mobile = section.settings.button_size_mobile | default: 13

  assign bg_color = section.settings.bg_color | default: '#E8DDD0'
  assign heading_color = section.settings.heading_color | default: '#C41E3A'
  assign subheading_color = section.settings.subheading_color | default: '#2C1A0E'
  assign btn_bg = section.settings.button_bg_color | default: '#C41E3A'
  assign btn_text = section.settings.button_text_color | default: '#FFFFFF'
  assign btn_bg_hover = section.settings.button_bg_hover | default: '#2C1A0E'
  assign btn_text_hover = section.settings.button_text_hover | default: '#FFFFFF'
  assign btn_radius = section.settings.button_border_radius | default: 50
  assign btn_height = section.settings.button_height | default: 52
  assign btn_padding_x = section.settings.button_padding_x | default: 40

  assign content_max_width = section.settings.content_max_width | default: 800
  assign padding_top = section.settings.padding_top | default: 60
  assign padding_bottom = section.settings.padding_bottom | default: 60
  assign heading_line_height = section.settings.heading_line_height | default: 110
  assign heading_margin_bottom = section.settings.heading_margin_bottom | default: 24
  assign subheading_margin_bottom = section.settings.subheading_margin_bottom | default: 16
  assign image_height_desktop = section.settings.image_height_desktop | default: 450
  assign image_height_mobile = section.settings.image_height_mobile | default: 280
  assign button_margin_top = section.settings.button_margin_top | default: 28
  assign subheading_position = section.settings.subheading_position | default: 'above'
  assign button_position = section.settings.button_position | default: 'below_image'
-%}

<section class="schar-stacked" data-section-id="{{ section.id }}">

  {%- comment -%} ZONA DE TEXTO (con padding) {%- endcomment -%}
  <div class="schar-stacked__text-zone" style="text-align: {{ text_alignment }};">

    {%- if subheading_position == 'above' -%}
      {%- unless subheading == blank -%}
        <p class="schar-stacked__subheading" data-aos="fade-up">{{ subheading }}</p>
      {%- endunless -%}
    {%- endif -%}

    {%- unless heading == blank -%}
      <{{ heading_tag }} class="schar-stacked__heading" data-aos="fade-up">{{ heading }}</{{ heading_tag }}>
    {%- endunless -%}

    {%- if subheading_position == 'below' -%}
      {%- unless subheading == blank -%}
        <p class="schar-stacked__subheading" data-aos="fade-up">{{ subheading }}</p>
      {%- endunless -%}
    {%- endif -%}

    {%- if has_button and button_position == 'above_image' -%}
      <div class="schar-stacked__btn-wrap" data-aos="fade-up">
        <a class="schar-stacked__btn" href="{{ button_link }}" {%- if button_link contains 'http' or button_link contains 'mailto:' %} target="_blank" rel="noopener"{% endif -%}>
          {{ button_label }}
        </a>
      </div>
    {%- endif -%}

  </div>

  {%- comment -%} IMAGEN FULL-WIDTH (sin padding, borde a borde) {%- endcomment -%}
  {%- if has_image -%}
    <div class="schar-stacked__image-fullwidth" data-aos="fade-up">
      <img
        src="{{ image | image_url: width: 2400 }}"
        alt="{{ image.alt | escape | default: heading | strip_html | escape }}"
        class="schar-stacked__image"
        loading="lazy"
      >
    </div>
  {%- endif -%}

  {%- comment -%} BOTÓN DEBAJO DE IMAGEN (con padding) {%- endcomment -%}
  {%- if has_button and button_position == 'below_image' -%}
    <div class="schar-stacked__text-zone" style="text-align: {{ text_alignment }};">
      <div class="schar-stacked__btn-wrap" data-aos="fade-up">
        <a class="schar-stacked__btn" href="{{ button_link }}" {%- if button_link contains 'http' or button_link contains 'mailto:' %} target="_blank" rel="noopener"{% endif -%}>
          {{ button_label }}
        </a>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} BOTÓN OVERLAY SOBRE IMAGEN {%- endcomment -%}
  {%- if has_button and button_position == 'over_image' and has_image -%}
    <div class="schar-stacked__btn-overlay" style="text-align: {{ text_alignment }};">
      <a class="schar-stacked__btn" href="{{ button_link }}" {%- if button_link contains 'http' or button_link contains 'mailto:' %} target="_blank" rel="noopener"{% endif -%}>
        {{ button_label }}
      </a>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
