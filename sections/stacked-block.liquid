    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón",
      "default": "Conoce más"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón"
    },
    {
      "type": "select",
      "id": "button_position",
      "label": "Posición del botón",
      "default": "below_image",
      "options": [
        { "value": "above_image", "label": "Arriba de la imagen" },
        { "value": "below_image", "label": "Abajo de la imagen" },
        { "value": "over_image", "label": "Sobre la imagen (overlay)" }
