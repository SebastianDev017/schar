  "tag": "section",
  "class": "schar-stacked-section",
  "settings": [
    {
      "type": "header",
      "content": "── CONTENIDO ──"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo"
    },
    {
      "type": "select",
      "id": "subheading_position",
      "label": "Posición del subtítulo",
      "default": "above",
      "options": [
        { "value": "above", "label": "Arriba del título" },
        { "value": "below", "label": "Abajo del título" }
      ]
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Título",
      "default": "<p><strong>guía para comprar<br>gluten-free</strong></p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen (full-width)",
