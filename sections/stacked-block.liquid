{% style %}
  @font-face {
    font-family: 'Times ExtraBold';
    src: url('https://cdn.shopify.com/s/files/1/0991/5082/3710/files/Times-ExtraBold.otf?v=1777160115') format('opentype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} {
    --schar-font-heading: 'Times ExtraBold', 'Playfair Display', serif;
    --schar-font-body: 'Inter', 'Poppins', sans-serif;

    --stk-bg: {{ bg_color }};
    --stk-pt: {{ padding_top }}px;
    --stk-pb: {{ padding_bottom }}px;
    --stk-max-w: {{ content_max_width }}px;

    --stk-h-desktop: {{ heading_size_desktop }}px;
    --stk-h-mobile: {{ heading_size_mobile }}px;
    --stk-h-color: {{ heading_color }};
    --stk-h-lh: {{ heading_line_height }}%;
    --stk-h-mb: {{ heading_margin_bottom }}px;

    --stk-sh-desktop: {{ subheading_size_desktop }}px;
    --stk-sh-mobile: {{ subheading_size_mobile }}px;
    --stk-sh-color: {{ subheading_color }};
    --stk-sh-mb: {{ subheading_margin_bottom }}px;

    --stk-img-h-desktop: {{ image_height_desktop }}px;
    --stk-img-h-mobile: {{ image_height_mobile }}px;

    --stk-btn-bg: {{ btn_bg }};
    --stk-btn-text: {{ btn_text }};
    --stk-btn-bg-hover: {{ btn_bg_hover }};
    --stk-btn-text-hover: {{ btn_text_hover }};
    --stk-btn-radius: {{ btn_radius }}px;
    --stk-btn-height: {{ btn_height }}px;
    --stk-btn-px: {{ btn_padding_x }}px;
    --stk-btn-desktop: {{ btn_size_desktop }}px;
    --stk-btn-mobile: {{ btn_size_mobile }}px;
    --stk-btn-mt: {{ button_margin_top }}px;
  }

  /* =============================================
     BASE
     ============================================= */
  .schar-stacked {
    background-color: var(--stk-bg);
    padding-top: var(--stk-pt);
    padding-bottom: var(--stk-pb);
    position: relative;
  }

  /* =============================================
     ZONA DE TEXTO (con padding lateral)
     ============================================= */
  .schar-stacked__text-zone {
    max-width: var(--stk-max-w);
    margin: 0 auto;
    padding-left: var(--header-desktop-padding, 63px);
    padding-right: var(--header-desktop-padding, 63px);
  }

  /* =============================================
     IMAGEN FULL-WIDTH (sin padding, 100vw)
     ============================================= */
  .schar-stacked__image-fullwidth {
    width: 100%;
    height: var(--stk-img-h-desktop);
    overflow: hidden;
  }

  .schar-stacked__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* =============================================
     SUBHEADING
     ============================================= */
  .schar-stacked__subheading {
    font-family: var(--schar-font-body);
    font-size: clamp(
      var(--stk-sh-mobile),
      calc(var(--stk-sh-mobile) + ({{ subheading_size_desktop }} - {{ subheading_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--stk-sh-desktop)
    );
    font-weight: 500;
    color: var(--stk-sh-color);
    margin: 0 0 var(--stk-sh-mb) 0;
    line-height: 1.4;
  }

  /* =============================================
     HEADING – Times ExtraBold
     ============================================= */
  .schar-stacked__heading,
  .schar-stacked__heading * {
    font-family: var(--schar-font-heading) !important;
    font-style: normal;
    font-weight: 400 !important;
    color: var(--stk-h-color);
    font-size: clamp(
      var(--stk-h-mobile),
      calc(var(--stk-h-mobile) + ({{ heading_size_desktop }} - {{ heading_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--stk-h-desktop)
    );
    line-height: var(--stk-h-lh);
    margin: 0 0 var(--stk-h-mb) 0;
  }

  .schar-stacked__heading strong,
  .schar-stacked__heading b {
    font-weight: 400 !important;
  }

  /* =============================================
     BOTÓN
     ============================================= */
  .schar-stacked__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--stk-btn-height);
    padding: 0 var(--stk-btn-px);
    background-color: var(--stk-btn-bg);
    color: var(--stk-btn-text);
    border: none;
    border-radius: var(--stk-btn-radius);
    font-family: var(--schar-font-body);
    font-size: clamp(
      var(--stk-btn-mobile),
      calc(var(--stk-btn-mobile) + ({{ btn_size_desktop }} - {{ btn_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--stk-btn-desktop)
    );
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.3s ease, color 0.3s ease, transform 0.2s ease;
  }

  .schar-stacked__btn-wrap {
    margin-top: var(--stk-btn-mt);
  }

  .schar-stacked__btn:hover {
    background-color: var(--stk-btn-bg-hover);
    color: var(--stk-btn-text-hover);
    transform: translateY(-1px);
  }

  .schar-stacked__btn:active {
    transform: translateY(0);
  }

  /* Botón overlay */
  .schar-stacked__btn-overlay {
    margin-top: calc(var(--stk-btn-height) * -1 - 20px);
    position: relative;
    z-index: 2;
    padding: 0 var(--header-desktop-padding, 63px) 0;
  }

  /* =============================================
     RESPONSIVE
     ============================================= */
  @media (max-width: 1439px) {
    .schar-stacked__text-zone {
      padding-left: var(--header-laptop-padding, 46px);
      padding-right: var(--header-laptop-padding, 46px);
    }
    .schar-stacked__btn-overlay {
      padding-left: var(--header-laptop-padding, 46px);
      padding-right: var(--header-laptop-padding, 46px);
    }
  }

  @media (max-width: 834px) {
    .schar-stacked__text-zone {
      padding-left: var(--header-tablet-padding, 46px);
      padding-right: var(--header-tablet-padding, 46px);
    }
    .schar-stacked__btn-overlay {
      padding-left: var(--header-tablet-padding, 46px);
      padding-right: var(--header-tablet-padding, 46px);
    }
  }

  @media (max-width: 680px) {
    .schar-stacked__text-zone {
      padding-left: var(--header-mobile-padding, 22px);
      padding-right: var(--header-mobile-padding, 22px);
    }
    .schar-stacked__btn-overlay {
      padding-left: var(--header-mobile-padding, 22px);
      padding-right: var(--header-mobile-padding, 22px);
    }

    .schar-stacked__image-fullwidth {
      height: var(--stk-img-h-mobile);
    }
  }

  @media (hover: hover) {
    .schar-stacked__btn:hover {
      background-color: var(--stk-btn-bg-hover);
      color: var(--stk-btn-text-hover);
      transform: translateY(-1px);
    }
  }
{% endstyle %}
