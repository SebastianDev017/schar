{%- comment -%}
  Section 6: Carrusel de Productos – Dr. Schär México
  ✔ Modo carrusel (Swiper) o grilla estática
  ✔ Loop infinito opcional
  ✔ Máximo 10 productos
  ✔ Navegación se oculta si no hay suficientes productos
  ✔ Slides por vista correctos vía JS (no CSS calc)
  ✔ Máxima personalización (55+ controles)
{%- endcomment -%}

{%- comment -%} Swiper CSS + tema base para product-card {%- endcomment -%}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

{%- liquid
  assign collection = section.settings.collection
  assign max_products = section.settings.max_products | default: 10
  assign use_carousel = section.settings.use_carousel
  assign enable_loop = section.settings.enable_loop
  assign title = section.settings.title
  assign subtitle = section.settings.subtitle
  assign text = section.settings.text
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign text_alignment = section.settings.text_alignment | default: 'center'
  assign has_button = false

  if button_label != blank and button_link != blank
    assign has_button = true
  endif

  assign collection_size = 0
  if collection != blank
    assign total = collection.products | size
    if total > max_products
      assign collection_size = max_products
    else
      assign collection_size = total
    endif
  endif

  assign heading_size_desktop = section.settings.heading_size_desktop | default: 56
  assign heading_size_mobile = section.settings.heading_size_mobile | default: 32
  assign subtitle_size_desktop = section.settings.subtitle_size_desktop | default: 13
  assign subtitle_size_mobile = section.settings.subtitle_size_mobile | default: 11
  assign text_size_desktop = section.settings.text_size_desktop | default: 18
  assign text_size_mobile = section.settings.text_size_mobile | default: 15
  assign btn_size_desktop = section.settings.button_size_desktop | default: 13
  assign btn_size_mobile = section.settings.button_size_mobile | default: 12

  assign bg_color = section.settings.bg_color | default: '#E8DDD0'
  assign heading_color = section.settings.heading_color | default: '#2C1A0E'
  assign subtitle_color = section.settings.subtitle_color | default: '#C41E3A'
  assign text_color = section.settings.text_color | default: '#2C1A0E'
  assign arrow_bg = section.settings.arrow_bg_color | default: '#2C1A0E'
  assign arrow_icon = section.settings.arrow_icon_color | default: '#FFFFFF'
  assign arrow_bg_hover = section.settings.arrow_bg_hover | default: '#C41E3A'
  assign dot_color = section.settings.dot_color | default: '#2C1A0E'
  assign dot_active_color = section.settings.dot_active_color | default: '#C41E3A'
  assign btn_bg = section.settings.button_bg_color | default: '#2C1A0E'
  assign btn_text = section.settings.button_text_color | default: '#FFFFFF'
  assign btn_bg_hover = section.settings.button_bg_hover | default: '#C41E3A'
  assign btn_text_hover = section.settings.button_text_hover | default: '#FFFFFF'
  assign btn_radius = section.settings.button_border_radius | default: 50
  assign btn_height = section.settings.button_height | default: 48
  assign btn_padding_x = section.settings.button_padding_x | default: 32

  assign padding_top = section.settings.padding_top | default: 80
  assign padding_bottom = section.settings.padding_bottom | default: 80
  assign heading_line_height = section.settings.heading_line_height | default: 110
  assign heading_margin_bottom = section.settings.heading_margin_bottom | default: 32
  assign subtitle_margin_bottom = section.settings.subtitle_margin_bottom | default: 12
  assign text_margin_top = section.settings.text_margin_top | default: 16
  assign carousel_margin_top = section.settings.carousel_margin_top | default: 40
  assign button_margin_top = section.settings.button_margin_top | default: 32
  assign slides_gap = section.settings.slides_gap | default: 20
  assign arrow_size = section.settings.arrow_size | default: 40
  assign show_dots = section.settings.show_dots
  assign show_arrows = section.settings.show_arrows
  assign slides_desktop = section.settings.slides_per_view_desktop | default: 4
  assign slides_tablet = section.settings.slides_per_view_tablet | default: 3
  assign slides_mobile = section.settings.slides_per_view_mobile | default: 2
  assign coming_soon_text = section.settings.coming_soon_text | default: 'Próximamente...'
  assign show_coming_soon = false
  if collection == blank or collection_size == 0
    assign show_coming_soon = true
  endif
-%}

<section
  class="schar-fc"
  id="schar-fc-{{ section.id }}"
  data-section-id="{{ section.id }}"
>

  {%- comment -%} TÍTULO + INFO {%- endcomment -%}
  <div class="schar-fc__info" style="text-align: {{ text_alignment }};" data-aos="fade-up">
    {%- unless subtitle == blank -%}
      <p class="schar-fc__subtitle">{{ subtitle }}</p>
    {%- endunless -%}
    {%- unless title == blank -%}
      <{{ heading_tag }} class="schar-fc__heading">{{ title }}</{{ heading_tag }}>
    {%- endunless -%}
    {%- unless text == blank -%}
      <div class="schar-fc__text">{{ text }}</div>
    {%- endunless -%}
    {%- if has_button -%}
      <div class="schar-fc__btn-wrap">
        <a class="schar-fc__btn" href="{{ button_link }}" {%- if button_link contains 'http' or button_link contains 'mailto:' %} target="_blank" rel="noopener"{% endif -%}>{{ button_label }}</a>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ======== COMING SOON ======== {%- endcomment -%}
  {%- if show_coming_soon -%}
    <div class="schar-fc__coming-soon" data-aos="fade-up" data-aos-delay="200">
      <p class="schar-fc__coming-soon-text">{{ coming_soon_text }}</p>
    </div>

  {%- comment -%} ======== MODO CARRUSEL ======== {%- endcomment -%}
  {%- elsif use_carousel -%}
    <div class="schar-fc__stage" data-aos="fade-up" data-aos-delay="200">

      {%- if show_arrows -%}
        <button class="schar-fc__arrow schar-fc__arrow--prev" id="schar-prev-{{ section.id }}" type="button" aria-label="Anterior">
          <svg width="10" height="18" viewBox="0 0 10 18" fill="none"><path d="M9 1L1 9L9 17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="schar-fc__arrow schar-fc__arrow--next" id="schar-next-{{ section.id }}" type="button" aria-label="Siguiente">
          <svg width="10" height="18" viewBox="0 0 10 18" fill="none"><path d="M1 1L9 9L1 17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      {%- endif -%}

      <div class="schar-fc__carousel-wrap">
        <div class="swiper" id="schar-swiper-{{ section.id }}">
          <div class="swiper-wrapper">
            {%- for product in collection.products limit: max_products -%}
              <div class="swiper-slide schar-fc__slide">
                {%- render 'product-card', product: product -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>

      {%- if show_dots -%}
        <div class="schar-fc__dots" id="schar-dots-{{ section.id }}"></div>
      {%- endif -%}

    </div>

  {%- comment -%} ======== MODO GRILLA ESTÁTICA ======== {%- endcomment -%}
  {%- else -%}
    <div class="schar-fc__grid" data-aos="fade-up" data-aos-delay="200">
      {%- for product in collection.products limit: max_products -%}
        <div class="schar-fc__grid-item">
          {%- render 'product-card', product: product -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

</section>

{%- comment -%} ======== SWIPER INIT ======== {%- endcomment -%}
{%- if use_carousel and show_coming_soon == false -%}
<script>
(function(){
  var sid = '{{ section.id }}';
  var cfg = {
    total: {{ collection_size | default: 6 }},
    desktop: {{ slides_desktop }},
    tablet: {{ slides_tablet }},
    mobile: {{ slides_mobile }},
    gap: {{ slides_gap }},
    loop: {% if enable_loop %}true{% else %}false{% endif %},
    arrows: {% if show_arrows %}true{% else %}false{% endif %},
    dots: {% if show_dots %}true{% else %}false{% endif %}
  };

  var attempts = 0;

  function init() {
    attempts++;
    if (typeof Swiper === 'undefined') {
      if (attempts < 50) return setTimeout(init, 200);
      console.warn('Swiper no se cargó');
      return;
    }

    var el = document.getElementById('schar-swiper-' + sid);
    if (!el) return;

    /* Destruir instancia previa si existe */
    if (el.swiper) el.swiper.destroy(true, true);

    var prevBtn = document.getElementById('schar-prev-' + sid);
    var nextBtn = document.getElementById('schar-next-' + sid);
    var dotsEl = document.getElementById('schar-dots-' + sid);

    /* Loop solo si hay más productos que el mayor slidesPerView */
    var canLoop = cfg.loop && cfg.total > cfg.desktop;

    var swiper = new Swiper(el, {
      slidesPerView: cfg.mobile,
      spaceBetween: cfg.gap,
      loop: canLoop,
      grabCursor: true,
      watchOverflow: true,
      navigation: (cfg.arrows && prevBtn && nextBtn) ? {
        prevEl: prevBtn,
        nextEl: nextBtn
      } : false,
      pagination: (cfg.dots && dotsEl) ? {
        el: dotsEl,
        clickable: true,
        bulletClass: 'schar-fc__dot',
        bulletActiveClass: 'schar-fc__dot--active'
      } : false,
      breakpoints: {
        681: {
          slidesPerView: cfg.tablet,
          spaceBetween: cfg.gap
        },
        835: {
          slidesPerView: cfg.desktop,
          spaceBetween: cfg.gap
        }
      },
      on: {
        init: function(s) { toggleNav(s); },
        resize: function(s) { toggleNav(s); },
        breakpoint: function(s) { toggleNav(s); }
      }
    });

    function toggleNav(s) {
      var perView = s.params.slidesPerView;
      var enough = cfg.total > perView;
      if (prevBtn) prevBtn.style.display = enough ? '' : 'none';
      if (nextBtn) nextBtn.style.display = enough ? '' : 'none';
      if (dotsEl) dotsEl.style.display = enough ? '' : 'none';
    }
  }

  if (document.readyState === 'complete') {
    setTimeout(init, 100);
  } else {
    window.addEventListener('load', function() { setTimeout(init, 100); });
  }
})();
</script>
{%- endif -%}

