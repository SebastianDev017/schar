{% style %}
  @font-face {
    font-family: 'Times ExtraBold';
    src: url('https://cdn.shopify.com/s/files/1/0991/5082/3710/files/Times-ExtraBold.otf?v=1777160115') format('opentype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} {
    --schar-font-heading: 'Times ExtraBold', 'Playfair Display', serif;
    --schar-font-body: 'Inter', 'Poppins', sans-serif;

    --fc-bg: {{ bg_color }};
    --fc-pt: {{ padding_top }}px;
    --fc-pb: {{ padding_bottom }}px;
    --fc-carousel-mt: {{ carousel_margin_top }}px;
    --fc-gap: {{ slides_gap }}px;
    --fc-arrow-size: {{ arrow_size }}px;
    --fc-cols-desktop: {{ slides_desktop }};
    --fc-cols-tablet: {{ slides_tablet }};
    --fc-cols-mobile: {{ slides_mobile }};

    --fc-h-desktop: {{ heading_size_desktop }}px;
    --fc-h-mobile: {{ heading_size_mobile }}px;
    --fc-h-color: {{ heading_color }};
    --fc-h-lh: {{ heading_line_height }}%;
    --fc-h-mb: {{ heading_margin_bottom }}px;
    --fc-sh-desktop: {{ subtitle_size_desktop }}px;
    --fc-sh-mobile: {{ subtitle_size_mobile }}px;
    --fc-sh-color: {{ subtitle_color }};
    --fc-sh-mb: {{ subtitle_margin_bottom }}px;
    --fc-t-desktop: {{ text_size_desktop }}px;
    --fc-t-mobile: {{ text_size_mobile }}px;
    --fc-t-color: {{ text_color }};
    --fc-t-mt: {{ text_margin_top }}px;

    --fc-arrow-bg: {{ arrow_bg }};
    --fc-arrow-icon: {{ arrow_icon }};
    --fc-arrow-bg-hover: {{ arrow_bg_hover }};
    --fc-dot-color: {{ dot_color }};
    --fc-dot-active: {{ dot_active_color }};

    --fc-btn-bg: {{ btn_bg }};
    --fc-btn-text: {{ btn_text }};
    --fc-btn-bg-hover: {{ btn_bg_hover }};
    --fc-btn-text-hover: {{ btn_text_hover }};
    --fc-btn-radius: {{ btn_radius }}px;
    --fc-btn-height: {{ btn_height }}px;
    --fc-btn-px: {{ btn_padding_x }}px;
    --fc-btn-desktop: {{ btn_size_desktop }}px;
    --fc-btn-mobile: {{ btn_size_mobile }}px;
    --fc-btn-mt: {{ button_margin_top }}px;
  }

  /* BASE */
  .schar-fc {
    background-color: var(--fc-bg) !important;
    padding: var(--fc-pt) 0 var(--fc-pb);
  }

  /* INFO */
  .schar-fc__info {
    max-width: 800px;
    padding: 0 var(--header-desktop-padding, 63px);
    margin: 0 auto;
  }

  .schar-fc__subtitle {
    font-family: var(--schar-font-body);
    font-size: clamp(var(--fc-sh-mobile), calc(var(--fc-sh-mobile) + ({{ subtitle_size_desktop }} - {{ subtitle_size_mobile }}) * ((100vw - 375px) / (1440 - 375))), var(--fc-sh-desktop));
    font-weight: 600; letter-spacing: 0.15em; text-transform: lowercase;
    color: var(--fc-sh-color); margin: 0 0 var(--fc-sh-mb) 0;
  }

  .schar-fc__heading, .schar-fc__heading * {
    font-family: var(--schar-font-heading) !important;
    font-style: normal; font-weight: 400 !important;
    color: var(--fc-h-color);
    font-size: clamp(var(--fc-h-mobile), calc(var(--fc-h-mobile) + ({{ heading_size_desktop }} - {{ heading_size_mobile }}) * ((100vw - 375px) / (1440 - 375))), var(--fc-h-desktop));
    line-height: var(--fc-h-lh); margin: 0 0 var(--fc-h-mb) 0;
  }

  .schar-fc__heading strong, .schar-fc__heading b,
  .schar-fc__heading strong *, .schar-fc__heading b * {
    font-weight: 400 !important; color: var(--fc-sh-color);
  }

  .schar-fc__text, .schar-fc__text * {
    font-family: var(--schar-font-body);
    font-size: clamp(var(--fc-t-mobile), calc(var(--fc-t-mobile) + ({{ text_size_desktop }} - {{ text_size_mobile }}) * ((100vw - 375px) / (1440 - 375))), var(--fc-t-desktop));
    line-height: 1.6; color: var(--fc-t-color);
  }
  .schar-fc__text:not(:first-child) { margin-top: var(--fc-t-mt); }

  /* ======== STAGE (carrusel) ======== */
  .schar-fc__stage {
    position: relative;
    margin-top: var(--fc-carousel-mt);
    padding: 0 calc(var(--fc-arrow-size) + 16px);
    max-width: 1314px;
    margin-left: auto;
    margin-right: auto;
  }

  .schar-fc__carousel-wrap {
    overflow: hidden;
    width: 100%;
  }

  /* Asegurar que Swiper renderice correctamente */
  .schar-fc__carousel-wrap .swiper {
    width: 100%;
    overflow: hidden;
  }

  .schar-fc__carousel-wrap .swiper-wrapper {
    display: flex;
    width: 100%;
  }

  .schar-fc__carousel-wrap .swiper-slide {
    flex-shrink: 0;
    width: auto;
    height: auto;
  }

  .schar-fc__slide { height: auto; }

  /* FLECHAS */
  .schar-fc__arrow {
    position: absolute;
    top: 40%;
    transform: translateY(-50%);
    z-index: 3;
    display: flex; align-items: center; justify-content: center;
    width: var(--fc-arrow-size); height: var(--fc-arrow-size);
    background-color: var(--fc-arrow-bg);
    border: none; border-radius: 50%;
    color: var(--fc-arrow-icon);
    cursor: pointer; padding: 0;
    transition: background-color 0.3s ease, opacity 0.3s ease;
  }
  .schar-fc__arrow svg {
    width: calc(var(--fc-arrow-size) * 0.25); height: auto;
    pointer-events: none;
  }
  .schar-fc__arrow--prev { left: 0; }
  .schar-fc__arrow--next { right: 0; }
  .schar-fc__arrow:hover { background-color: var(--fc-arrow-bg-hover); }
  .schar-fc__arrow.swiper-button-disabled {
    opacity: 0.25; cursor: default; pointer-events: none;
  }
  .schar-fc__arrow.swiper-button-lock { display: none; }

  /* DOTS */
  .schar-fc__dots {
    display: flex; align-items: center; justify-content: center;
    gap: 8px; margin-top: 28px; flex-wrap: wrap;
  }
  .schar-fc__dot {
    width: 10px; height: 10px; border-radius: 50%;
    background-color: var(--fc-dot-color); opacity: 0.25;
    border: none; cursor: pointer; display: inline-block;
    transition: opacity 0.3s ease, background-color 0.3s ease;
  }
  .schar-fc__dot--active {
    opacity: 1; background-color: var(--fc-dot-active);
  }

  /* ======== GRILLA ESTÁTICA ======== */
  .schar-fc__grid {
    display: grid;
    grid-template-columns: repeat(var(--fc-cols-desktop), 1fr);
    gap: var(--fc-gap);
    margin-top: var(--fc-carousel-mt);
    padding: 0 var(--header-desktop-padding, 63px);
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .schar-fc__grid-item { min-width: 0; }

  /* BOTÓN */
  .schar-fc__btn {
    display: inline-flex; align-items: center; justify-content: center;
    height: var(--fc-btn-height); padding: 0 var(--fc-btn-px);
    background-color: var(--fc-btn-bg); color: var(--fc-btn-text);
    border: none; border-radius: var(--fc-btn-radius);
    font-family: var(--schar-font-body);
    font-size: clamp(var(--fc-btn-mobile), calc(var(--fc-btn-mobile) + ({{ btn_size_desktop }} - {{ btn_size_mobile }}) * ((100vw - 375px) / (1440 - 375))), var(--fc-btn-desktop));
    font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
    text-decoration: none; cursor: pointer;
    transition: background-color 0.3s ease, color 0.3s ease, transform 0.2s ease;
  }
  .schar-fc__btn-wrap { margin-top: var(--fc-btn-mt); }
  .schar-fc__btn:hover {
    background-color: var(--fc-btn-bg-hover); color: var(--fc-btn-text-hover);
    transform: translateY(-1px);
  }
  .schar-fc__btn:active { transform: translateY(0); }

  /* RESPONSIVE */
  @media (max-width: 1439px) {
    .schar-fc__info { padding: 0 var(--header-laptop-padding, 46px); }
    .schar-fc__grid { padding: 0 var(--header-laptop-padding, 46px); }
  }
  @media (max-width: 834px) {
    .schar-fc__info { padding: 0 var(--header-tablet-padding, 46px); }
    .schar-fc__grid {
      padding: 0 var(--header-tablet-padding, 46px);
      grid-template-columns: repeat(var(--fc-cols-tablet), 1fr);
    }
    .schar-fc__stage { padding: 0 calc(var(--fc-arrow-size) + 12px); }
  }
  @media (max-width: 680px) {
    .schar-fc__info { padding: 0 var(--header-mobile-padding, 22px); }
    .schar-fc__grid {
      padding: 0 var(--header-mobile-padding, 22px);
      grid-template-columns: repeat(var(--fc-cols-mobile), 1fr);
    }
    .schar-fc__stage { padding: 0 calc(var(--fc-arrow-size) + 8px); }
    .schar-fc__arrow { --fc-arrow-size: 32px; }
    .schar-fc__dots { margin-top: 20px; }
  }
  @media (hover: hover) {
    .schar-fc__btn:hover { background-color: var(--fc-btn-bg-hover); color: var(--fc-btn-text-hover); }
    .schar-fc__arrow:hover { background-color: var(--fc-arrow-bg-hover); }
  }

  /* COMING SOON */
  .schar-fc__coming-soon {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: var(--fc-carousel-mt);
    padding: 60px var(--header-desktop-padding, 63px);
    max-width: 1314px;
    margin-left: auto;
    margin-right: auto;
  }

  .schar-fc__coming-soon-text {
    font-family: var(--schar-font-heading);
    font-size: clamp(28px, calc(28px + (48 - 28) * ((100vw - 375px) / (1440 - 375))), 48px);
    font-weight: 400;
    color: var(--fc-h-color);
    opacity: 0.4;
    text-align: center;
    margin: 0;
    letter-spacing: 0.02em;
  }

  @media (max-width: 680px) {
    .schar-fc__coming-soon {
      padding: 40px var(--header-mobile-padding, 22px);
    }
  }

  /* PLACEHOLDERS */
  .schar-fc__ph-card { display: flex; flex-direction: column; align-items: center; width: 100%; }
  .schar-fc__ph-img { width: 100%; }
  .schar-fc__ph-img svg { width: 100%; height: auto; display: block; }
  .schar-fc__ph-info { width: 100%; padding: 16px 8px 0; text-align: center; }
  .schar-fc__ph-type { font-family: var(--schar-font-body); font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: lowercase; color: var(--fc-sh-color); margin: 0 0 4px 0; }
  .schar-fc__ph-name { font-family: var(--schar-font-heading); font-size: 18px; font-weight: 400; color: var(--fc-h-color); margin: 0 0 8px 0; line-height: 1.3; }
  .schar-fc__ph-price { font-family: var(--schar-font-body); font-size: 15px; font-weight: 600; color: var(--fc-t-color); margin: 0; }
{% endstyle %}
