{%- comment -%} Buybar + Bottom Sheet – wiring {%- endcomment -%}
<script>
(function(){
  var root = document.getElementById('schar-product-{{ section.id }}');
  if (!root) return;

  var buybar = root.querySelector('[data-schar-buybar]');
  var sheet  = root.querySelector('[data-schar-sheet]');
  if (!buybar) return;

  /* Variantes JSON (las saca del script del form principal) */
  var variantsScript = root.querySelector('variant-radios script[type="application/json"]');
  var variants = [];
  try { variants = variantsScript ? JSON.parse(variantsScript.textContent) : []; } catch(e) {}

  var hasOnlyDefault = window.productHasOnlyDefaultVariant === true || window.productHasOnlyDefaultVariant === 'true';

  /* Selección actual del sheet (arranca con la variante seleccionada del form) */
  var selectedOpts = {};
  var initialId = parseInt(root.querySelector('#selectedVariant') && JSON.parse(root.querySelector('#selectedVariant').textContent).id, 10);
  var initialVar = variants.find(function(v){ return v.id === initialId; }) || variants[0];
  if (initialVar) {
    selectedOpts['option1'] = initialVar.option1;
    selectedOpts['option2'] = initialVar.option2;
    selectedOpts['option3'] = initialVar.option3;
  }

  /* Detectar qué option# corresponde a cada nombre de opción */
  var optionNames = {{ product.options | json }};
  function nameToKey(name){
    var i = optionNames.indexOf(name);
    return i === -1 ? null : 'option' + (i + 1);
  }

  /* ─── Mostrar/ocultar la buybar al scroll y según viewport ─── */
  var purchaseBlock = root.querySelector('.schar-product__item--purchase');

  function updateBuybarVisibility(){
    var isMobile = window.matchMedia('(max-width: 834px)').matches;
    if (!isMobile) { buybar.classList.remove('is-visible'); buybar.setAttribute('aria-hidden', 'true'); return; }
    /* Ocultar solo si el botón principal "Añadir al carrito" está visible en pantalla */
    var hideForPurchase = false;
    if (purchaseBlock) {
      var rect = purchaseBlock.getBoundingClientRect();
      if (rect.top < window.innerHeight - 80 && rect.bottom > 60) hideForPurchase = true;
    }
    var show = !hideForPurchase;
    buybar.classList.toggle('is-visible', show);
    buybar.setAttribute('aria-hidden', show ? 'false' : 'true');
  }

  window.addEventListener('scroll', updateBuybarVisibility, { passive: true });
  window.addEventListener('resize', updateBuybarVisibility);
  updateBuybarVisibility();

  /* ─── Botón carrito de la buybar → click en el ATC normal ─── */
  var cartBtn = buybar.querySelector('[data-schar-buybar-cart]');
  if (cartBtn) {
    cartBtn.addEventListener('click', function(){
      var atc = root.querySelector('#add-to-cart-button, .product-form__submit');
      if (atc) atc.click();
    });
  }

  /* ─── Helper: encontrar variante match ─── */
  function findVariant(){
    return variants.find(function(v){
      return (selectedOpts.option1 == null || v.option1 === selectedOpts.option1)
          && (selectedOpts.option2 == null || v.option2 === selectedOpts.option2)
          && (selectedOpts.option3 == null || v.option3 === selectedOpts.option3);
    });
  }

  /* ─── Ir al checkout directo ─── */
  function goCheckout(variantId, qty){
    if (!variantId) return;
    var q = parseInt(qty, 10) || 1;
    window.location.href = '/cart/' + variantId + ':' + q + '?return_to=/checkout';
  }

  /* ─── Botón "Comprar ya" de la buybar ─── */
  var buyBtn = buybar.querySelector('[data-schar-buybar-buy]');
  if (buyBtn) {
    buyBtn.addEventListener('click', function(){
      if (buyBtn.disabled) return;

      /* Producto simple → directo al checkout */
      if (hasOnlyDefault) {
        var v = variants[0];
        if (v && v.available) goCheckout(v.id, getQty());
        return;
      }

      /* Producto con variantes → abrir el sheet */
      openSheet();
    });
  }

  function getQty(){
    var qtyInput = root.querySelector('#quantity');
    var q = qtyInput ? parseInt(qtyInput.value, 10) : 1;
    return (isNaN(q) || q < 1) ? 1 : q;
  }

  /* ─── BOTTOM SHEET ─── */
  if (!sheet) return;

  var sheetQty = 1;
  var sheetQtyEl = sheet.querySelector('[data-schar-sheet-qty-value]');
  var sheetPriceEl = sheet.querySelector('[data-schar-sheet-price]');
  var sheetCta = sheet.querySelector('[data-schar-sheet-checkout]');

  function openSheet(){
    /* Sincronizar selección actual del form principal */
    syncFromForm();
    updateSheetUI();
    sheet.classList.add('is-open');
    sheet.setAttribute('aria-hidden', 'false');
    document.documentElement.classList.add('schar-sheet-open');
  }

  function closeSheet(){
    sheet.classList.remove('is-open');
    sheet.setAttribute('aria-hidden', 'true');
    document.documentElement.classList.remove('schar-sheet-open');
  }

  sheet.querySelectorAll('[data-schar-sheet-close]').forEach(function(el){
    el.addEventListener('click', closeSheet);
  });
  document.addEventListener('keydown', function(e){
    if (e.key === 'Escape' && sheet.classList.contains('is-open')) closeSheet();
  });

  /* Sincronizar pills desde el form principal */
  function syncFromForm(){
    var checked = root.querySelectorAll('variant-radios input[type="radio"]:checked');
    checked.forEach(function(input){
      var optName = input.name;
      var key = nameToKey(optName);
      if (key) selectedOpts[key] = input.value;
    });
    sheetQty = getQty();
    /* Actualizar pills */
    sheet.querySelectorAll('[data-schar-sheet-option]').forEach(function(group){
      var optName = group.getAttribute('data-schar-sheet-option');
      var key = nameToKey(optName);
      var current = key ? selectedOpts[key] : null;
      group.querySelectorAll('.schar-sheet__pill').forEach(function(p){
        p.classList.toggle('is-active', p.getAttribute('data-value') === current);
      });
    });
  }

  /* Click en pills del sheet → cambia selección */
  sheet.querySelectorAll('.schar-sheet__pill').forEach(function(pill){
    pill.addEventListener('click', function(){
      var group = pill.closest('[data-schar-sheet-option]');
      var optName = group.getAttribute('data-schar-sheet-option');
      var key = nameToKey(optName);
      if (key) selectedOpts[key] = pill.getAttribute('data-value');
      group.querySelectorAll('.schar-sheet__pill').forEach(function(p){ p.classList.remove('is-active'); });
      pill.classList.add('is-active');
      updateSheetUI();
    });
  });

  /* Cantidad del sheet */
  sheet.querySelectorAll('[data-schar-sheet-qty]').forEach(function(btn){
    btn.addEventListener('click', function(){
      sheetQty = Math.max(1, sheetQty + parseInt(btn.getAttribute('data-schar-sheet-qty'), 10));
      if (sheetQtyEl) sheetQtyEl.textContent = sheetQty;
    });
  });

  /* Format money simple */
  function formatMoney(cents){
    if (window.Shopify && Shopify.formatMoney) {
      return Shopify.formatMoney(cents, window.Shopify.money_format || '${{amount}}');
    }
    return '$' + (cents / 100).toFixed(2);
  }

  function updateSheetUI(){
    var v = findVariant();
    if (sheetPriceEl && v) sheetPriceEl.textContent = formatMoney(v.price);
    if (sheetCta) {
      if (!v || !v.available) {
        sheetCta.disabled = true;
        sheetCta.querySelector('span').textContent = 'Agotado';
      } else {
        sheetCta.disabled = false;
        sheetCta.querySelector('span').textContent = 'Ir al checkout';
      }
    }
  }

  /* Botón final del sheet → checkout */
  if (sheetCta) {
    sheetCta.addEventListener('click', function(){
      if (sheetCta.disabled) return;
      var v = findVariant();
      if (v && v.available) goCheckout(v.id, sheetQty);
    });
  }
})();
</script>

{%- comment -%} Galería – wiring {%- endcomment -%}
<script>
(function(){
  var root = document.getElementById('schar-product-{{ section.id }}');
  if (!root) return;
  var gallery = root.querySelector('[data-schar-gallery]');
  if (!gallery) return;

  var slidesWrap = gallery.querySelector('[data-schar-slides]');
  var slides = gallery.querySelectorAll('[data-schar-slide]');
  var thumbs = gallery.querySelectorAll('[data-schar-thumb]');
  var thumbsTrack = gallery.querySelector('[data-schar-thumbs-track]');
  var arrows = gallery.querySelectorAll('[data-schar-arrow]');
  var scrollBtns = gallery.querySelectorAll('[data-schar-scroll]');
  var current = gallery.querySelector('[data-schar-current]');
  var total = slides.length;
  if (!total) return;

  var idx = 0;
  var isAnimating = false;

  function setActive(i){
    if (i < 0) i = total - 1;
    if (i >= total) i = 0;
    if (i === idx) return;
    isAnimating = true;
    idx = i;

    slides.forEach(function(s, k){
      s.classList.toggle('is-active', k === idx);
      // Pausar videos al cambiar
      var v = s.querySelector('video');
      if (v && k !== idx) { try { v.pause(); } catch(e){} }
    });
    thumbs.forEach(function(t, k){ t.classList.toggle('is-active', k === idx); });

    if (current) current.textContent = (idx + 1);
    scrollThumbIntoView(idx);

    setTimeout(function(){ isAnimating = false; }, 350);
  }

  function scrollThumbIntoView(i){
    if (!thumbsTrack) return;
    var th = thumbs[i];
    if (!th) return;
    var trackRect = thumbsTrack.getBoundingClientRect();
    var thRect = th.getBoundingClientRect();
    var isVertical = trackRect.height > trackRect.width;
    if (isVertical){
      if (thRect.top < trackRect.top || thRect.bottom > trackRect.bottom){
        thumbsTrack.scrollTo({ top: th.offsetTop - thumbsTrack.clientHeight/2 + th.offsetHeight/2, behavior: 'smooth' });
      }
    } else {
      if (thRect.left < trackRect.left || thRect.right > trackRect.right){
        thumbsTrack.scrollTo({ left: th.offsetLeft - thumbsTrack.clientWidth/2 + th.offsetWidth/2, behavior: 'smooth' });
      }
    }
  }

  // Thumbnails → cambiar slide
  thumbs.forEach(function(t, i){
    t.addEventListener('click', function(e){
      e.preventDefault();
      e.stopPropagation();
      setActive(i);
    });
  });

  // Flechas principales
  arrows.forEach(function(a){
    a.addEventListener('click', function(e){
      e.preventDefault();
      e.stopPropagation();
      setActive(idx + parseInt(a.dataset.scharArrow, 10));
    });
  });

  // Scroll de miniaturas
  scrollBtns.forEach(function(b){
    b.addEventListener('click', function(e){
      e.preventDefault();
      if (!thumbsTrack) return;
      var dir = parseInt(b.dataset.scharScroll, 10);
      var isVertical = thumbsTrack.clientHeight > thumbsTrack.clientWidth;
      var amount = (isVertical ? thumbsTrack.clientHeight : thumbsTrack.clientWidth) * 0.7;
      thumbsTrack.scrollBy({ top: isVertical ? dir * amount : 0, left: isVertical ? 0 : dir * amount, behavior: 'smooth' });
    });
  });

  // Teclado: ← → cuando la galería tiene foco visual
  document.addEventListener('keydown', function(e){
    if (!gallery.matches(':hover')) return;
    if (e.key === 'ArrowLeft')  { setActive(idx - 1); }
    if (e.key === 'ArrowRight') { setActive(idx + 1); }
  });

  // Swipe en mobile
  var touchStartX = 0, touchStartY = 0;
  slidesWrap.addEventListener('touchstart', function(e){
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });
  slidesWrap.addEventListener('touchend', function(e){
    var dx = e.changedTouches[0].clientX - touchStartX;
    var dy = e.changedTouches[0].clientY - touchStartY;
    if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)){
      setActive(idx + (dx < 0 ? 1 : -1));
    }
  }, { passive: true });
})();
</script>

{%- comment -%} Botón "Comprar ya" del form principal – directo al checkout {%- endcomment -%}
<script>
(function(){
  var root = document.getElementById('schar-product-{{ section.id }}');
  if (!root) return;
  var buyNow = root.querySelector('[data-schar-buynow]');
  var atc = root.querySelector('#add-to-cart-button');
  if (!buyNow) return;

  function getCheckoutUrl(){
    var form = root.querySelector('product-form form');
    if (!form) return null;
    var idInput = form.querySelector('input[name="id"]');
    var qtyInput = root.querySelector('#quantity');
    if (!idInput || !idInput.value) return null;
    var qty = qtyInput ? (parseInt(qtyInput.value, 10) || 1) : 1;
    return '/cart/' + idInput.value + ':' + qty + '?return_to=/checkout';
  }

  buyNow.addEventListener('click', function(){
    if (buyNow.disabled) return;
    var url = getCheckoutUrl();
    if (url) window.location.href = url;
  });

  // Sincronizar disabled del Buy Now con el ATC (en carga y cuando cambia variante)
  if (atc) {
    var sync = function(){
      var isDisabled = atc.disabled || atc.hasAttribute('disabled');
      buyNow.disabled = isDisabled;
      if (isDisabled) {
        buyNow.setAttribute('disabled', '');
      } else {
        buyNow.removeAttribute('disabled');
      }
    };
    sync();
    // Re-sincronizar tras la carga completa y un pequeño delay (por si el tema actualiza el ATC async)
    window.addEventListener('load', sync);
    setTimeout(sync, 300);
    setTimeout(sync, 1000);
    var observer = new MutationObserver(sync);
    observer.observe(atc, { attributes: true, attributeFilter: ['disabled', 'class'] });
  }
})();
</script>

{%- comment -%} Selector de cantidad – wiring {%- endcomment -%}
<script>
(function(){
  var root = document.getElementById('schar-product-{{ section.id }}');
  if (!root) return;
  var stepper = root.querySelector('[data-schar-qty]');
  if (!stepper) return;
  var input = stepper.querySelector('.schar-qty__input');
  var minus = stepper.querySelector('.schar-qty__btn--minus');
  var plus  = stepper.querySelector('.schar-qty__btn--plus');
  if (!input) return;

  function getVal(){ var v = parseInt(input.value, 10); return (isNaN(v) || v < 1) ? 1 : v; }
  function setVal(v){
    if (v < 1) v = 1;
    input.value = v;
    input.dispatchEvent(new Event('change', { bubbles: true }));
  }
  if (minus) minus.addEventListener('click', function(){ setVal(getVal() - 1); });
  if (plus)  plus.addEventListener('click', function(){ setVal(getVal() + 1); });
  input.addEventListener('blur', function(){ setVal(getVal()); });
})();
</script>

{% style %}
  /* =============================================
     PRODUCTO – Dr. Schär · Layout de bloques
     ============================================= */
  #shopify-section-{{ section.id }} {
    --schar-dark: #2C1A0E;
    --schar-red: #C41E3A;
    --schar-beige: #E8DDD0;
    --schar-beige-light: #F5F0EB;
    --schar-border: #D5CBC0;
    --schar-yellow: #F5C842;
    --schar-teal: #2ABCB4;
    --schar-muted: #8A7A6C;
    --schar-font-heading: 'Times ExtraBold', 'Playfair Display', serif;
    --schar-font-body: 'Cabin', 'Inter', sans-serif;
    width: 100%;
    max-width: 100vw;
    overflow-x: clip;
  }

  /* ⚠ Defensa total contra overflow horizontal heredado */
  #shopify-section-{{ section.id }} .schar-product,
  #shopify-section-{{ section.id }} .schar-product__list,
  #shopify-section-{{ section.id }} .schar-product__item,
  #shopify-section-{{ section.id }} .schar-product__item--gallery,
  #shopify-section-{{ section.id }} .schar-gallery,
  #shopify-section-{{ section.id }} .schar-gallery__stage,
  #shopify-section-{{ section.id }} .schar-gallery__slides,
  #shopify-section-{{ section.id }} .schar-gallery__slide,
  #shopify-section-{{ section.id }} .schar-gallery__media,
  #shopify-section-{{ section.id }} .schar-gallery__zoom-wrap {
    max-width: 100% !important;
    min-width: 0 !important;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .schar-gallery__img,
  #shopify-section-{{ section.id }} .schar-gallery__img.main-product-image,
  #shopify-section-{{ section.id }} .schar-gallery__media img {
    width: 100% !important;
    max-width: 100% !important;
    height: 100% !important;
    display: block;
    object-fit: contain;
    object-position: center;
  }

  /* Miniaturas: nunca rompen el ancho */
  #shopify-section-{{ section.id }} .schar-gallery__thumbs {
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .schar-gallery__thumbs-track {
    max-width: 100%;
    min-width: 0;
  }

  .schar-product {
    background-color: var(--schar-beige);
    width: 100%;
    max-width: 100%;
    overflow-x: clip;
  }

  /* Forzar que los contenedores heredados del tema Schär no causen overflow horizontal */
  .schar-product *,
  .schar-product *::before,
  .schar-product *::after {
    box-sizing: border-box;
  }
  .main-product-section.main-product-section {
    overflow-x: clip;
    max-width: 100vw;
  }

  /* Neutralizar wrappers heredados del tema Schär que causan overflow horizontal */
  #shopify-section-{{ section.id }} .main-product,
  #shopify-section-{{ section.id }} .main-product-content,
  #shopify-section-{{ section.id }} .main-product-right,
  #shopify-section-{{ section.id }} .main-product-info {
    display: block !important;
    grid-template-columns: none !important;
    width: 100% !important;
    max-width: 100% !important;
    min-width: 0 !important;
    padding: 0 !important;
    margin: 0 !important;
    position: static !important;
    top: auto !important;
  }

  /* Mobile: una columna, bloques en orden */
  .schar-product__list {
    display: block;
    max-width: 620px;
    width: 100%;
    margin: 0 auto;
    padding: 24px var(--header-mobile-padding, 22px) 48px;
    box-sizing: border-box;
    min-width: 0;
  }

  .schar-product__item {
    margin-bottom: 18px;
    max-width: 100%;
    min-width: 0;
  }
  .schar-product__item:last-child { margin-bottom: 0; }

  /* ── Etiqueta de colección (pill) ── */
  .schar-pill {
    display: inline-flex;
    align-items: center;
    padding: 7px 16px;
    background-color: var(--schar-beige-light);
    border: 1px solid var(--schar-border);
    border-radius: 50px;
    font-family: var(--schar-font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--schar-dark);
    text-decoration: none;
    transition: color 0.2s ease, background-color 0.2s ease;
  }
  a.schar-pill:hover {
    color: var(--schar-red);
    background-color: #FFFFFF;
  }

  /* ── Título ── */
  .schar-product__title {
    margin: 0;
    font-family: var(--schar-font-body) !important;
    font-size: clamp(26px, calc(26px + (40 - 26) * ((100vw - 375px) / (1440 - 375))), 40px) !important;
    font-weight: 700 !important;
    line-height: 1.15 !important;
    text-transform: uppercase;
    color: var(--schar-dark) !important;
  }

  /* ── Peso ── */
  .schar-product__weight {
    margin: 0;
    font-family: var(--schar-font-body);
    font-size: 17px;
    font-weight: 700;
    color: var(--schar-dark);
  }

  /* =============================================
     PRECIO – Estados normales, oferta y agotado
     ============================================= */
  .schar-product__item--price .main-product-price {
    margin: 0;
  }

  /* DL container como flex row */
  .schar-product__item--price .price {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 10px;
    margin: 0;
    padding: 0;
  }

  /* dd y dt internos: solo el dd se ve */
  .schar-product__item--price .price dt { display: none; }
  .schar-product__item--price .price dd { margin: 0; }
  .schar-product__item--price .price .price__regular,
  .schar-product__item--price .price .price__sale {
    display: inline-flex;
    align-items: baseline;
    margin: 0;
  }

  /* Estilo base de todos los precios */
  .schar-product__item--price .price-item {
    font-family: var(--schar-font-body);
    font-size: clamp(22px, calc(22px + (28 - 22) * ((100vw - 375px) / (1440 - 375))), 28px);
    font-weight: 700;
    color: var(--schar-dark);
    line-height: 1.2;
  }
  .schar-product__item--price .price-item del,
  .schar-product__item--price .price-item s {
    text-decoration: none;
  }

  /* =====  ESTADO: precio normal (sin oferta, disponible)  ===== */
  /* Solo se muestra .price__regular con el precio normal */
  .schar-product__item--price .price:not(.price--on-sale):not(.price--sold-out) .price__sale { display: none; }

  /* =====  ESTADO: en oferta (con disponibilidad)  ===== */
  /* Precio tachado (compare_at) en .price__regular */
  /* Precio de oferta en rojo en .price__sale */
  .schar-product__item--price .price--on-sale .price-item-regular del {
    display: inline-block;
    font-size: 0.7em;
    font-weight: 500;
    color: var(--schar-dark);
    opacity: 0.55;
    text-decoration: line-through;
    text-decoration-thickness: 1.5px;
  }
  .schar-product__item--price .price--on-sale .price-item-sale {
    color: var(--schar-red) !important;
    font-weight: 700;
  }

  /* =====  ESTADO: agotado (sin oferta)  ===== */
  /* Ocultar el sale (que es el mismo precio repetido) cuando no hay oferta real */
  .schar-product__item--price .price--sold-out:not(.price--on-sale) .price__sale { display: none; }
  /* El regular se ve tachado en gris café (con contraste suficiente) */
  .schar-product__item--price .price--sold-out .price-item-regular,
  .schar-product__item--price .price--sold-out .price-item-regular del {
    color: #8A7A6C !important;
    font-weight: 600;
  }
  .schar-product__item--price .price--sold-out .price-item-regular del {
    text-decoration: line-through;
    text-decoration-thickness: 1.5px;
  }
  /* Etiqueta "Agotado" junto al precio */
  .schar-product__item--price .price--sold-out::after {
    content: 'Agotado';
    display: inline-flex;
    align-items: center;
    margin-left: 4px;
    padding: 4px 12px;
    background-color: #F5F0EB;
    border: 1px solid var(--schar-border);
    border-radius: 50px;
    font-family: var(--schar-font-body);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #8A7A6C;
    line-height: 1;
    align-self: center;
  }

  /* =====  ESTADO: agotado + oferta  ===== */
  /* Mostrar ambos pero el sale en gris también, no en rojo */
  .schar-product__item--price .price--sold-out.price--on-sale .price-item-sale,
  .schar-product__item--price .price--sold-out.price--on-sale .price-item-sale * {
    color: #8A7A6C !important;
    text-decoration: line-through;
    text-decoration-thickness: 1.5px;
  }
  .schar-product__item--price .price--sold-out.price--on-sale .price-item-regular del {
    color: #8A7A6C !important;
  }

  /* ── Descripción ── */
  .schar-product__desc-heading {
    margin: 0 0 8px 0;
    font-family: var(--schar-font-body);
    font-size: 18px;
    font-weight: 700;
    color: var(--schar-dark);
  }
  .schar-product__desc,
  .schar-product__desc * {
    font-family: var(--schar-font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--schar-dark);
  }
  .schar-product__desc a { color: var(--schar-red); }

  /* ── Texto libre ── */
  .schar-product__free-text,
  .schar-product__free-text * {
    font-family: var(--schar-font-body);
    color: var(--schar-dark);
  }

  /* ── Galería ── */
  .schar-product__item--gallery { margin-bottom: 18px; min-width: 0; max-width: 100%; overflow: hidden; }

  /* =============================================
     GALERÍA PREMIUM – Dr. Schär
     ============================================= */
  .schar-gallery {
    --gap: 14px;
    --thumb-size: 78px;
    --thumb-radius: 12px;
    --stage-radius: 16px;
    --border: var(--schar-border);
    --accent: var(--schar-dark);
    --hover: var(--schar-red);
    position: relative;
    display: grid;
    gap: var(--gap);
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
  }

  /* Mobile: thumbnails debajo en horizontal */
  .schar-gallery {
    grid-template-areas:
      "stage"
      "thumbs";
    grid-template-columns: 1fr;
  }

  /* ── STAGE (imagen grande) ── */
  .schar-gallery__stage {
    grid-area: stage;
    position: relative;
    background-color: var(--schar-beige-light);
    border-radius: var(--stage-radius);
    overflow: hidden;
    aspect-ratio: 1 / 1;
    width: 100%;
    max-width: 100%;
    min-width: 0;
  }

  .schar-gallery__slides {
    position: relative;
    width: 100%;
    max-width: 100%;
    height: 100%;
    min-width: 0;
    overflow: hidden;
  }

  .schar-gallery__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    max-width: 100%;
    opacity: 0;
    visibility: hidden;
    transform: scale(1.02);
    transition: opacity 0.45s cubic-bezier(0.2, 0.8, 0.2, 1),
                transform 0.55s cubic-bezier(0.2, 0.8, 0.2, 1),
                visibility 0s linear 0.55s;
    will-change: opacity, transform;
  }
  .schar-gallery__slide.is-active {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
    transition: opacity 0.45s cubic-bezier(0.2, 0.8, 0.2, 1),
                transform 0.55s cubic-bezier(0.2, 0.8, 0.2, 1),
                visibility 0s linear 0s;
    z-index: 2;
  }

  .schar-gallery__media {
    width: 100%;
    height: 100%;
    cursor: pointer;
  }

  .schar-gallery__zoom-wrap {
    width: 100%;
    height: 100%;
    overflow: hidden;
    position: relative;
  }

  .schar-gallery__img,
  .schar-gallery__video {
    width: 100% !important;
    height: 100% !important;
    object-fit: contain;
    object-position: center;
  }

  /* ── Flechas en stage ── */
  .schar-gallery__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: none;
    border-radius: 50%;
    color: var(--accent);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.25s ease, background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
    box-shadow: 0 4px 12px rgba(44, 26, 14, 0.15);
  }
  .schar-gallery__arrow--prev { left: 14px; }
  .schar-gallery__arrow--next { right: 14px; }
  .schar-gallery__stage:hover .schar-gallery__arrow { opacity: 1; }
  .schar-gallery__arrow:hover {
    background-color: var(--hover);
    color: #FFFFFF;
    transform: translateY(-50%) scale(1.05);
  }

  /* En mobile las flechas siempre visibles */
  @media (max-width: 834px) {
    .schar-gallery__arrow { opacity: 0.85; width: 36px; height: 36px; }
  }

  /* ── Contador ── */
  .schar-gallery__counter {
    position: absolute;
    bottom: 14px;
    left: 14px;
    z-index: 5;
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    background-color: rgba(44, 26, 14, 0.75);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 50px;
    font-family: var(--schar-font-body);
    font-size: 12px;
    font-weight: 600;
    color: #FFFFFF;
    letter-spacing: 0.04em;
    pointer-events: none;
  }
  .schar-gallery__counter span { font-weight: 700; }

  /* ── Botón expandir (lightbox) ── */
  .schar-gallery__expand {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background-color: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: none;
    border-radius: 50%;
    color: var(--accent);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.25s ease, background-color 0.2s ease, color 0.2s ease;
    box-shadow: 0 4px 12px rgba(44, 26, 14, 0.12);
  }
  .schar-gallery__stage:hover .schar-gallery__expand { opacity: 1; }
  .schar-gallery__expand:hover { background-color: var(--hover); color: #FFFFFF; }

  /* ── MINIATURAS ── */
  .schar-gallery__thumbs {
    grid-area: thumbs;
    position: relative;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .schar-gallery__thumbs-track {
    flex: 1;
    display: flex;
    gap: 8px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 2px;
  }
  .schar-gallery__thumbs-track::-webkit-scrollbar { display: none; }

  .schar-gallery__thumb {
    position: relative;
    flex-shrink: 0;
    width: var(--thumb-size);
    height: var(--thumb-size);
    padding: 0;
    background-color: var(--schar-beige-light);
    border: 2px solid transparent;
    border-radius: var(--thumb-radius);
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .schar-gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transition: transform 0.3s ease;
  }
  .schar-gallery__thumb:hover {
    border-color: var(--schar-border);
    transform: translateY(-1px);
  }
  .schar-gallery__thumb:hover img { transform: scale(1.05); }
  .schar-gallery__thumb.is-active {
    border-color: var(--accent);
    box-shadow: 0 4px 14px rgba(44, 26, 14, 0.18);
  }
  .schar-gallery__thumb.is-active::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--thumb-radius);
    box-shadow: inset 0 0 0 1px var(--accent);
    pointer-events: none;
  }

  /* Indicador play en thumbs de video */
  .schar-gallery__thumb-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background-color: rgba(255, 255, 255, 0.92);
    border-radius: 50%;
    color: var(--accent);
    pointer-events: none;
  }
  .schar-gallery__thumb-play svg { margin-left: 2px; }

  /* ── Botones de scroll de thumbs (solo desktop, ocultos en mobile) ── */
  .schar-gallery__scroll {
    display: none;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    padding: 0;
    background: transparent;
    border: 1.5px solid var(--schar-border);
    border-radius: 50%;
    color: var(--accent);
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .schar-gallery__scroll:hover {
    background-color: var(--accent);
    color: #FFFFFF;
    border-color: var(--accent);
  }

  /* =============================================
     DESKTOP ≥ 835px – Miniaturas verticales a la izquierda
     ============================================= */
  @media (min-width: 835px) {
    .schar-gallery {
      grid-template-areas: "thumbs stage";
      grid-template-columns: 86px 1fr;
      gap: 16px;
    }

    .schar-gallery__thumbs {
      flex-direction: column;
      align-self: start;
      max-height: 600px;
    }

    .schar-gallery__thumbs-track {
      flex-direction: column;
      overflow-x: clip;
      overflow-y: auto;
      max-height: 100%;
    }

    .schar-gallery__scroll {
      display: flex;
    }

    .schar-gallery__stage {
      aspect-ratio: 1 / 1;
    }
  }
  /* ── Galería override sobre estilos viejos del tema ── */
  .schar-product .main-product-carousel { display: none; }

  /* ── Fondos transparentes en imagen y miniaturas (neutraliza el fondo heredado del tema) ── */
  #shopify-section-{{ section.id }} .schar-gallery__stage,
  #shopify-section-{{ section.id }} .schar-gallery__slides,
  #shopify-section-{{ section.id }} .schar-gallery__slide,
  #shopify-section-{{ section.id }} .schar-gallery__media,
  #shopify-section-{{ section.id }} .schar-gallery__zoom-wrap,
  #shopify-section-{{ section.id }} .schar-gallery__img,
  #shopify-section-{{ section.id }} .schar-gallery__thumb,
  #shopify-section-{{ section.id }} .schar-gallery__thumb img,
  #shopify-section-{{ section.id }} .main-product-media-item,
  #shopify-section-{{ section.id }} .main-product-image,
  #shopify-section-{{ section.id }} .main-product-media {
    background: transparent !important;
    background-color: transparent !important;
  }

  /* =============================================
     FORM CARD – Schär clean
     ============================================= */
  .schar-product .main-product-form {
    background-color: #FFFFFF;
    border-radius: 18px;
    border: 1px solid rgba(44, 26, 14, 0.08);
    overflow: hidden;
    box-shadow: 0 1px 0 rgba(44, 26, 14, 0.02);
    margin-top: 8px;
  }

  /* ── Sección de variantes ── */
  .schar-form-section { padding: 0; }

  .schar-product .product-form-fieldset,
  .schar-form-fieldset {
    padding: 15px 20px !important;
    border: 0 !important;
    border-bottom: 1px solid rgba(44, 26, 14, 0.08) !important;
    margin: 0 !important;
  }
  .schar-product .product-form-fieldset:last-of-type,
  .schar-form-fieldset:last-of-type {
    border-bottom: 0 !important;
  }
  .schar-product .product-form-fieldset::before,
  .schar-form-fieldset::before { display: none !important; }

  /* ── Legend (label de sección) ── */
  .schar-product .product-form-legend,
  .schar-form-legend,
  .schar-qty-legend {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 9px 0;
    padding: 0;
    font-family: var(--schar-font-body);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--schar-dark);
  }
  .schar-product .product-form-legend::before,
  .schar-form-legend::before,
  .schar-qty-legend::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    background-color: var(--schar-red);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Variantes (pills) ── */
  .schar-product .product-variants-grid,
  .schar-variants-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0;
  }
  .schar-product .product-variant {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    padding: 7px 16px;
    background-color: #F5F0EB;
    border: 1.5px solid transparent;
    border-radius: 50px;
    font-family: var(--schar-font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--schar-dark);
    cursor: pointer;
    transition: background-color 0.18s ease, border-color 0.18s ease, color 0.18s ease, transform 0.15s ease, box-shadow 0.2s ease;
    white-space: nowrap;
  }
  .schar-product .product-variant:hover {
    background-color: #FFFFFF;
    border-color: var(--schar-dark);
    color: var(--schar-dark);
    transform: translateY(-1px);
  }
  .schar-product .product-form-radio:checked + .product-variant {
    background-color: var(--schar-dark);
    border-color: var(--schar-dark);
    color: #FFFFFF;
    font-weight: 600;
    box-shadow: 0 3px 10px rgba(44, 26, 14, 0.18);
  }
  .schar-product .product-form-radio:checked + .product-variant:hover {
    background-color: var(--schar-red);
    border-color: var(--schar-red);
    transform: translateY(-1px);
  }

  /* ── Cantidad (pill integrado + label) ── */
  .schar-qty-wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 13px 20px;
    border-top: 1px solid rgba(44, 26, 14, 0.08);
    flex-wrap: wrap;
  }
  .schar-form-section + .schar-qty-wrap,
  .schar-qty-wrap:first-child {
    border-top: 0;
  }
  .schar-qty-legend { margin: 0; }

  .schar-qty {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    background-color: #F5F0EB;
    border: 1px solid rgba(44, 26, 14, 0.08);
    border-radius: 50px;
    padding: 4px;
  }
  .schar-qty__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: #FFFFFF;
    color: var(--schar-dark);
    cursor: pointer;
    box-shadow: 0 1px 3px rgba(44, 26, 14, 0.08);
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.1s ease;
  }
  .schar-qty__btn:hover {
    background-color: var(--schar-dark);
    color: #FFFFFF;
  }
  .schar-qty__btn:active { transform: scale(0.9); }
  .schar-qty__input {
    width: 40px;
    height: 32px;
    padding: 0;
    text-align: center;
    border: none;
    background: transparent;
    font-family: var(--schar-font-body);
    font-size: 15px;
    font-weight: 700;
    line-height: 32px;
    color: var(--schar-dark) !important;
    -webkit-text-fill-color: var(--schar-dark);
    opacity: 1;
    -moz-appearance: textfield;
    appearance: textfield;
  }
  .schar-qty__input:focus {
    outline: none;
    color: var(--schar-dark) !important;
    -webkit-text-fill-color: var(--schar-dark);
  }
  .schar-qty__input::-webkit-outer-spin-button,
  .schar-qty__input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* ── Grupo de CTAs (ATC + Comprar ya) ── */
  .schar-cta-group {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
    border-top: 1px solid rgba(44, 26, 14, 0.08);
  }
  .schar-cta {
    width: 100%;
    height: 50px;
    border: none;
    border-radius: 0;
    font-family: var(--schar-font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: background-color 0.25s ease, color 0.25s ease;
    padding: 0 20px;
  }
  .schar-cta svg { flex-shrink: 0; }

  /* Añadir al carrito (primario, café) */
  .schar-cta--atc {
    background-color: var(--schar-dark);
    color: #FFFFFF;
  }
  .schar-cta--atc:hover:not([disabled]):not(:disabled) {
    background-color: #1a0e07;
  }

  /* Comprar ya (rojo, pegado al fondo de la card) */
  .schar-cta--buy {
    background-color: var(--schar-red);
    color: #FFFFFF;
    border-radius: 0 0 17px 17px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .schar-cta--buy:hover:not([disabled]):not(:disabled) {
    background-color: #a4172e;
  }

  /* Estado deshabilitado — gana sobre los colores de arriba */
  .schar-cta-group .schar-cta:disabled,
  .schar-cta-group .schar-cta[disabled],
  .schar-cta--atc:disabled,
  .schar-cta--atc[disabled],
  .schar-cta--buy:disabled,
  .schar-cta--buy[disabled] {
    background-color: #B8AA9C !important;
    color: #FFFFFF !important;
    cursor: not-allowed !important;
    border-top-color: transparent !important;
    pointer-events: none;
  }

  /* Si solo hay un botón (sin Buy Now), el ATC toma la esquina inferior */
  .schar-cta-group .schar-cta:only-child,
  .schar-cta-group .schar-cta:last-child {
    border-radius: 0 0 17px 17px;
  }

  /* Override agresivo: cubre el .product-form__submit heredado */
  .schar-product .product-form__submit.schar-cta { /* clase combinada */ }

  /* =============================================
     TRUST BADGES – Schär
     ============================================= */
  .schar-trust {
    list-style: none;
    margin: 14px 0 0 0;
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    background-color: #FFFFFF;
    border: 1px solid rgba(44, 26, 14, 0.08);
    border-radius: 16px;
  }
  .schar-trust__item {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .schar-trust__icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    background-color: #F5F0EB;
    border-radius: 50%;
    color: var(--schar-red);
  }
  .schar-trust__text {
    font-family: var(--schar-font-body);
    font-size: 13px;
    line-height: 1.35;
    color: var(--schar-dark);
  }
  .schar-trust__text strong {
    font-weight: 700;
  }

  /* En desktop: badges en fila horizontal con divisores */
  @media (min-width: 480px) {
    .schar-trust {
      flex-direction: row;
      justify-content: space-between;
      gap: 0;
      padding: 18px 8px;
    }
    .schar-trust__item {
      flex: 1;
      flex-direction: column;
      text-align: center;
      gap: 8px;
      padding: 0 12px;
      position: relative;
    }
    .schar-trust__item:not(:last-child)::after {
      content: '';
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 1px;
      height: 60%;
      background-color: rgba(44, 26, 14, 0.1);
    }
    .schar-trust__text {
      font-size: 11.5px;
      max-width: 130px;
    }
  }

  /* ── Acordeones ── */
  .schar-product .product-accordion,
  .schar-product .product-accordion.open .product-accordion-header {
    border-bottom-color: rgba(44,26,14,0.12);
  }
  .schar-product .product-accordion-title {
    font-family: var(--schar-font-body);
    color: var(--schar-dark);
  }
  .schar-product .product-accordion.open .product-accordion-title { font-weight: 700; }
  .schar-product .tabpanel-bullet-icon {
    background-image: none;
    background-color: var(--schar-red);
    border-radius: 50%;
    width: 8px; height: 8px; min-width: 8px;
    margin-top: 7px;
  }

  /* ── Etiqueta descargable ── */
  .schar-product__etiqueta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--schar-font-body);
    font-size: 14px;
    color: var(--schar-dark);
    text-decoration: underline;
  }
  .schar-product__etiqueta:hover { color: var(--schar-red); }

  /* =============================================
     DESKTOP ≥ 835px – 2 columnas
     Galería pinned a la izquierda, resto a la derecha
     ============================================= */
  @media (min-width: 835px) {
    .schar-product__list {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
      column-gap: 60px;
      align-items: start;
      max-width: 1200px;
      padding: 48px var(--header-desktop-padding, 63px) 90px;
    }
    /* Todos los bloques → columna derecha */
    .schar-product__item { grid-column: 2; }
    /* Galería → columna izquierda, ocupa todas las filas */
    .schar-product__item--gallery {
      grid-column: 1;
      grid-row: 1 / 999;
      margin-bottom: 0;
      align-self: start;
      position: sticky;
      top: calc(var(--header-height, 90px) + 16px);
    }
  }

  @media (min-width: 835px) and (max-width: 1439px) {
    .schar-product__list { padding: 40px var(--header-laptop-padding, 46px) 70px; }
  }

  /* Hover */
  @media (hover: hover) {
    .schar-qty__btn:hover { background-color: var(--schar-dark); color: #FFFFFF; }
    .schar-product .product-form-button .button:hover,
    .schar-product .product-form__submit:hover { background-color: var(--schar-red) !important; }
  }

  /* =============================================
     BUYBAR MOBILE – barra fija "Comprar ya"
     ============================================= */
  .schar-buybar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 999;
    display: none;
    align-items: center;
    gap: 8px;
    padding: 12px 14px calc(12px + env(safe-area-inset-bottom));
    background-color: #FFFFFF;
    border-top: 1px solid rgba(44, 26, 14, 0.1);
    box-shadow: 0 -8px 24px rgba(44, 26, 14, 0.08);
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: transform;
  }
  .schar-buybar.is-visible { transform: translateY(0); }

  .schar-buybar__cart {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: 1.5px solid var(--schar-dark);
    border-radius: 50%;
    color: var(--schar-dark);
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  .schar-buybar__cart:hover,
  .schar-buybar__cart:active {
    background-color: var(--schar-dark);
    color: #FFFFFF;
  }

  .schar-buybar__btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    height: 44px;
    background-color: var(--schar-dark);
    color: #FFFFFF;
    border: none;
    border-radius: 50px;
    font-family: var(--schar-font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }
  .schar-buybar__btn:hover,
  .schar-buybar__btn:active { background-color: var(--schar-red); }
  .schar-buybar__btn[disabled] {
    background-color: #B8AA9C;
    cursor: not-allowed;
  }

  @media (max-width: 834px) {
    .schar-buybar { display: flex; }
    /* Espacio extra al final para que la buybar no tape el último contenido */
    .schar-product__list { padding-bottom: 100px; }
  }

  /* =============================================
     BOTTOM SHEET – Comprar ya con variantes
     ============================================= */
  .schar-sheet {
    position: fixed;
    inset: 0;
    z-index: 9999;
    visibility: hidden;
    pointer-events: none;
  }
  .schar-sheet.is-open {
    visibility: visible;
    pointer-events: auto;
  }

  .schar-sheet__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(44, 26, 14, 0.5);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .schar-sheet.is-open .schar-sheet__overlay { opacity: 1; }

  .schar-sheet__panel {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: #FFFFFF;
    border-radius: 24px 24px 0 0;
    padding: 8px 18px calc(20px + env(safe-area-inset-bottom));
    box-shadow: 0 -12px 40px rgba(0, 0, 0, 0.2);
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.2, 0.9, 0.2, 1);
    max-height: 85vh;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  .schar-sheet.is-open .schar-sheet__panel { transform: translateY(0); }

  .schar-sheet__handle {
    width: 40px;
    height: 4px;
    background-color: rgba(44, 26, 14, 0.2);
    border-radius: 2px;
    margin: 6px auto 16px;
  }

  .schar-sheet__header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }
  .schar-sheet__thumb {
    width: 56px;
    height: 56px;
    background-color: var(--schar-beige-light);
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .schar-sheet__thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .schar-sheet__info { flex: 1; min-width: 0; }
  .schar-sheet__title {
    margin: 0 0 2px 0;
    font-family: var(--schar-font-body);
    font-size: 14px;
    font-weight: 700;
    color: var(--schar-dark);
    text-transform: uppercase;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .schar-sheet__price {
    margin: 0;
    font-family: var(--schar-font-body);
    font-size: 15px;
    font-weight: 700;
    color: var(--schar-dark);
  }
  .schar-sheet__close {
    width: 32px;
    height: 32px;
    background: transparent;
    border: none;
    color: var(--schar-dark);
    cursor: pointer;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .schar-sheet__legend {
    margin: 0 0 8px 0;
    font-family: var(--schar-font-body);
    font-size: 12px;
    font-weight: 600;
    color: var(--schar-dark);
    letter-spacing: 0.03em;
  }
  .schar-sheet__pills {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }
  .schar-sheet__pill {
    padding: 8px 16px;
    background-color: #FFFFFF;
    border: 1px solid var(--schar-border);
    border-radius: 50px;
    font-family: var(--schar-font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--schar-dark);
    cursor: pointer;
    transition: background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }
  .schar-sheet__pill:hover { border-color: var(--schar-dark); }
  .schar-sheet__pill.is-active {
    background-color: var(--schar-red);
    border-color: var(--schar-red);
    color: #FFFFFF;
  }

  .schar-sheet__qty {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 20px;
  }
  .schar-sheet__qty-btn {
    width: 34px;
    height: 34px;
    border: 1.5px solid var(--schar-dark);
    border-radius: 50%;
    background: transparent;
    color: var(--schar-dark);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  .schar-sheet__qty-btn:hover {
    background-color: var(--schar-dark);
    color: #FFFFFF;
  }
  .schar-sheet__qty-value {
    font-family: var(--schar-font-body);
    font-size: 16px;
    font-weight: 700;
    color: var(--schar-dark);
    min-width: 30px;
    text-align: center;
  }

  .schar-sheet__cta {
    width: 100%;
    height: 48px;
    background-color: var(--schar-dark);
    border: none;
    border-radius: 50px;
    color: #FFFFFF;
    font-family: var(--schar-font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 8px;
    transition: background-color 0.2s ease;
  }
  .schar-sheet__cta:hover { background-color: var(--schar-red); }
  .schar-sheet__cta[disabled] {
    background-color: #B8AA9C;
    cursor: not-allowed;
  }
  .schar-sheet__secure {
    margin: 0;
    font-family: var(--schar-font-body);
    font-size: 11px;
    color: var(--schar-dark);
    opacity: 0.5;
    text-align: center;
  }

  /* Lock scroll de fondo cuando el sheet está abierto */
  html.schar-sheet-open,
  html.schar-sheet-open body {
    overflow: hidden;
  }

  /* Solo mobile */
  @media (min-width: 835px) {
    .schar-sheet { display: none !important; }
  }

  /* =============================================
     RESEÑAS COMPLETAS (Judge.me) – contenedor on-brand
     Overrides scopeados; NO se toca la fuente de .jdgm-star
     ============================================= */
  @font-face {
    font-family: 'Times ExtraBold';
    src: url('https://cdn.shopify.com/s/files/1/0991/5082/3710/files/Times-ExtraBold.otf?v=1777160115') format('opentype');
    font-weight: 800;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} .schar-reviews {
    background-color: var(--schar-beige);
    padding: 56px 0 80px;
    width: 100%;
    max-width: 100vw;
    overflow-x: clip;
  }
  #shopify-section-{{ section.id }} .schar-reviews__inner {
    max-width: 1040px;
    margin: 0 auto;
    padding: 0 var(--header-mobile-padding, 22px);
  }
  #shopify-section-{{ section.id }} .schar-reviews__head {
    text-align: center;
    margin-bottom: 34px;
  }
  #shopify-section-{{ section.id }} .schar-reviews__eyebrow {
    margin: 0 0 8px 0;
    font-family: var(--schar-font-body);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--schar-red);
  }
  #shopify-section-{{ section.id }} .schar-reviews__title {
    margin: 0;
    font-family: var(--schar-font-heading);
    font-size: clamp(26px, calc(26px + (40 - 26) * ((100vw - 375px) / (1440 - 375))), 40px);
    font-weight: 800;
    line-height: 1.12;
    color: var(--schar-dark);
  }

  /* Tipografía/color de textos (NO de las estrellas) */
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-rev-widg__title,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-rev-widg__summary-text,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-histogram__frequency,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-rev__author,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-rev__title,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-rev__body,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-rev__timestamp,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-rev__location,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-write-rev-link,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-all-reviews-rating-wrapper,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-paginate,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-sort-dropdown,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-form label,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-form input,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-form textarea,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-form select,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-form button,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-form p {
    font-family: var(--schar-font-body) !important;
    color: var(--schar-dark);
  }
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-rev-widg__title {
    font-family: var(--schar-font-heading) !important;
    font-weight: 800 !important;
    color: var(--schar-dark) !important;
  }

  /* Estrellas */
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-star.jdgm--on,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-star.jdgm--half {
    color: var(--schar-yellow) !important;
  }
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-star.jdgm--off {
    color: var(--schar-border) !important;
  }
  #shopify-section-{{ section.id }} .schar-reviews[data-stars="red"] .jdgm-star.jdgm--on,
  #shopify-section-{{ section.id }} .schar-reviews[data-stars="red"] .jdgm-star.jdgm--half {
    color: var(--schar-red) !important;
  }

  /* Histograma */
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-histogram__bar {
    background-color: var(--schar-beige-light) !important;
    border-radius: 50px !important;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-histogram__bar-content {
    background-color: var(--schar-red) !important;
    border-radius: 50px !important;
  }
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-histogram__row:hover .jdgm-histogram__bar-content {
    background-color: var(--schar-dark) !important;
  }

  /* Botón "Escribir reseña" (píldora de marca) */
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-write-rev-link {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    background-color: var(--schar-dark) !important;
    color: #FFFFFF !important;
    border: none !important;
    border-radius: 50px !important;
    padding: 12px 26px !important;
    font-size: 13px !important;
    font-weight: 600 !important;
    letter-spacing: 0.08em !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
    transition: background-color 0.2s ease !important;
  }
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-write-rev-link:hover {
    background-color: var(--schar-red) !important;
  }

  /* Cada reseña como tarjeta */
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-rev {
    background-color: #FFFFFF !important;
    border: 1px solid rgba(44, 26, 14, 0.08) !important;
    border-radius: 14px !important;
    padding: 20px 22px !important;
    margin-bottom: 16px !important;
  }
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-rev__author { font-weight: 700 !important; }
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-rev__body {
    line-height: 1.6 !important;
    color: var(--schar-dark) !important;
  }
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-rev__timestamp,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-rev__location {
    color: var(--schar-muted) !important;
  }
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-rev__buyer-badge-wrapper,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-rev__buyer-badge {
    color: var(--schar-teal) !important;
  }

  /* Paginación */
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-paginate__page {
    border: 1px solid var(--schar-border) !important;
    border-radius: 50px !important;
    color: var(--schar-dark) !important;
    background-color: #FFFFFF !important;
    transition: background-color 0.2s ease, color 0.2s ease !important;
  }
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-paginate__page:hover {
    background-color: var(--schar-dark) !important;
    color: #FFFFFF !important;
    border-color: var(--schar-dark) !important;
  }
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-paginate__page.jdgm-curt-page,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-paginate__page--active {
    background-color: var(--schar-red) !important;
    border-color: var(--schar-red) !important;
    color: #FFFFFF !important;
  }

  /* Dropdown de orden */
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-sort-dropdown,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-sort-dropdown-wrapper select {
    border: 1px solid var(--schar-border) !important;
    border-radius: 50px !important;
    color: var(--schar-dark) !important;
    background-color: #FFFFFF !important;
  }

  /* Formulario de reseña */
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-form__input,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-form textarea,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-form input[type="text"],
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-form input[type="email"] {
    border: 1px solid var(--schar-border) !important;
    border-radius: 12px !important;
    background-color: #FFFFFF !important;
    color: var(--schar-dark) !important;
  }
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-form__input:focus,
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-form textarea:focus {
    border-color: var(--schar-dark) !important;
    outline: none !important;
  }
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-submit-rev {
    background-color: var(--schar-dark) !important;
    color: #FFFFFF !important;
    border: none !important;
    border-radius: 50px !important;
    padding: 12px 28px !important;
    font-family: var(--schar-font-body) !important;
    font-size: 13px !important;
    font-weight: 600 !important;
    letter-spacing: 0.08em !important;
    text-transform: uppercase !important;
    transition: background-color 0.2s ease !important;
  }
  #shopify-section-{{ section.id }} .schar-reviews .jdgm-submit-rev:hover {
    background-color: var(--schar-red) !important;
  }

  @media (min-width: 835px) {
    #shopify-section-{{ section.id }} .schar-reviews { padding: 72px 0 90px; }
    #shopify-section-{{ section.id }} .schar-reviews__inner { padding: 0 var(--header-desktop-padding, 63px); }
  }
{% endstyle %}

