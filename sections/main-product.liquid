{%- comment -%}
  ============================================================
  PRODUCTO – Dr. Schär México  ·  Sección con BLOQUES
  Cada bloque es reordenable / opcional desde el editor.
  Bloques: collection_pill · title · gallery · weight · price
           reviews · description · accordions · purchase · etiqueta · text
  ⚠ Class names, IDs, data-attrs y JSON scripts del form intactos
    para no romper ReCharge / Klaviyo / Rebuy / Judge.me / theme JS
  ============================================================
{%- endcomment -%}
{%- comment -%}theme-check-disable RemoteAsset, UnknownFilter{%- endcomment -%}

{{- 'css-main-product.css' | asset_url | stylesheet_tag -}}

{%- liquid
  assign metafields = product.metafields.custom
  assign selected_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id
  assign has_only_default_variant = product.has_only_default_variant

  assign subscription_variant_price = false
  for variant in product.variants
    assign subscription = variant.metafields.custom.suscripcion.value | handleize
    if subscription == "si"
      assign subscription_variant_price = variant.price
      break
    endif
  endfor
-%}

<div class="schar-product" id="schar-product-{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="main-product">
  <div class="schar-product__list">

    {%- for block in section.blocks -%}
      {%- case block.type -%}

      {%- comment -%} ════════ ETIQUETA DE COLECCIÓN ════════ {%- endcomment -%}
      {%- when 'collection_pill' -%}
        {%- liquid
          assign pill_collection = block.settings.collection
          if pill_collection == blank and product.collections.size > 0
            assign pill_collection = product.collections.first
          endif
          assign pill_text = pill_collection.title
          if block.settings.custom_text != blank
            assign pill_text = block.settings.custom_text
          endif
        -%}
        {%- if pill_text != blank -%}
          <div class="schar-product__item schar-product__item--pill" {{ block.shopify_attributes }}>
            {%- if pill_collection != blank and block.settings.link == true -%}
              <a class="schar-pill" href="{{ pill_collection.url }}">{{ pill_text }}</a>
            {%- else -%}
              <span class="schar-pill">{{ pill_text }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

      {%- comment -%} ════════ TÍTULO ════════ {%- endcomment -%}
      {%- when 'title' -%}
        <div class="schar-product__item schar-product__item--title" {{ block.shopify_attributes }}>
          <h1 class="schar-product__title main-product-title">{{ product.title }}</h1>
        </div>

      {%- comment -%} ════════ GALERÍA ════════ {%- endcomment -%}
      {%- when 'gallery' -%}
        <div class="schar-product__item schar-product__item--gallery" {{ block.shopify_attributes }}>
          <div class="schar-gallery" data-schar-gallery>

            {%- comment -%} ── MINIATURAS (vertical desktop / horizontal mobile) ── {%- endcomment -%}
            <div class="schar-gallery__thumbs" data-schar-thumbs>
              <button class="schar-gallery__scroll schar-gallery__scroll--up" type="button" aria-label="Anterior" data-schar-scroll="-1">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none"><polyline points="6 15 12 9 18 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
              <div class="schar-gallery__thumbs-track" data-schar-thumbs-track>
                {%- for media in product.media -%}
                  <button class="schar-gallery__thumb {% if forloop.first %}is-active{% endif %}" type="button" data-schar-thumb="{{ forloop.index0 }}" aria-label="Imagen {{ forloop.index }}">
                    {%- if media.media_type == 'video' -%}
                      <span class="schar-gallery__thumb-play">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                      </span>
                      <img src="{{ media.preview_image | image_url: width: 160 }}" alt="" loading="lazy">
                    {%- else -%}
                      <img src="{{ media | image_url: width: 160 }}" alt="{{ media.alt | escape }}" loading="lazy">
                    {%- endif -%}
                  </button>
                {%- endfor -%}
              </div>
              <button class="schar-gallery__scroll schar-gallery__scroll--down" type="button" aria-label="Siguiente" data-schar-scroll="1">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none"><polyline points="6 9 12 15 18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>

            {%- comment -%} ── STAGE PRINCIPAL ── {%- endcomment -%}
            <div class="schar-gallery__stage">
              <div class="schar-gallery__slides" data-schar-slides>
                {% for media in product.media %}
                  {%- liquid
                    assign media_type = media.media_type
                    assign media_id = media.id
                    assign fetch_priority = "low"
                    assign loading_attr = "lazy"
                    if forloop.first
                      assign fetch_priority = "high"
                      assign loading_attr = "eager"
                    endif
                  -%}
                  <div class="schar-gallery__slide main-product-media-slide swiper-slide {% if forloop.first %}is-active{% endif %}" data-schar-slide="{{ forloop.index0 }}" data-media-id="{{ media_id }}" data-index="{{ forloop.index0 }}">
                    <div class="schar-gallery__media main-product-media-item product-media-type-{{ media_type }} js-popup-trigger" data-media-id="{{ media_id }}" data-index="{{ forloop.index0 }}">
                      {%- if media_type == 'image' -%}
                        <div class="schar-gallery__zoom-wrap" data-schar-zoom>
                          {{- media | image_url: width: 1200 | image_tag: class: "schar-gallery__img main-product-image main-product-media no-touch", alt: media.alt, height: nil, srcset: nil, fetchpriority: fetch_priority, loading: loading_attr, data-media-id: media.id -}}
                        </div>
                      {%- endif -%}
                      {%- if media_type == 'video' -%}
                        {{- media | video_tag: class: "schar-gallery__video main-product-video main-product-media", id: media_id, image_size: '683x', preload: "none", loop: true, muted: true, controls: true, disablepictureinpicture: true, playsinline: true, controlsList: "nofullscreen nodownload noremoteplayback noplaybackrate", data-media-id: media.id -}}
                      {%- endif -%}
                    </div>
                  </div>
                {% endfor %}
              </div>

              {%- comment -%} Flechas en desktop {%- endcomment -%}
              {%- if product.media.size > 1 -%}
                <button class="schar-gallery__arrow schar-gallery__arrow--prev" type="button" aria-label="Anterior" data-schar-arrow="-1">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none"><polyline points="15 18 9 12 15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <button class="schar-gallery__arrow schar-gallery__arrow--next" type="button" aria-label="Siguiente" data-schar-arrow="1">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none"><polyline points="9 18 15 12 9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>

                <div class="schar-gallery__counter" data-schar-counter>
                  <span data-schar-current>1</span> / {{ product.media.size }}
                </div>
              {%- endif -%}

              {%- comment -%} Hint zoom (solo si hay imagen) {%- endcomment -%}
              <button class="schar-gallery__expand js-popup-trigger" type="button" aria-label="Ampliar">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none"><path d="M3 8V3h5M21 8V3h-5M3 16v5h5M21 16v5h-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>

          </div>

          {%- comment -%} POPUP de media (lightbox completo) {%- endcomment -%}
          <div class="product-popup">
            <div class="product-popup-content">
              <button class="product-popup-close-button js-popup-trigger" type="button" role="button" aria-label="Close">
                {%- render 'icon', icon: "close" -%}
              </button>
              <div class="product-popup-carousel-wrapper">
                <div class="product-popup-carousel swiper" data-slides="{{- product.media | size -}}">
                  <div class="swiper-wrapper">
                    {%- for media in product.media -%}
                      {%- assign type = media.media_type -%}
                      <div class="product-popup-slide swiper-slide type-{{- type -}}" data-media-type="{{- type -}}" data-media-id="{{ media.id }}">
                        {%- if type == 'image' -%}
                          <picture class="product-popup-media-wrapper">
                            <img class="product-popup-media product-popup-image" data-src="{{- media | image_url: width: 1400 -}}" alt="{{- media.alt -}}">
                          </picture>
                        {%- endif -%}
                        {%- if type == 'video' -%}
                          <div class="product-popup-media-wrapper">
                            <video class="product-popup-media product-popup-video" preload="none" poster="{{- media.preview_image | image_url: height: 500 -}}" controlsList="nofullscreen nodownload noremoteplayback noplaybackrate" loop muted playsinline disablepictureinpicture controls webkit-playsinline x5-playsinline>
                              {% for source in media.sources %}
                                <source src="{{ source.url }}" type="video/{{ source.format }}">
                              {% endfor %}
                            </video>
                          </div>
                        {%- endif -%}
                      </div>
                    {%- endfor -%}
                  </div>
                </div>
                <button class="product-popup-button swiper-button prev" type="button" role="button" aria-label="Previous">
                  {%- render "icon", icon: "arrow-prev" -%}
                </button>
                <button class="product-popup-button swiper-button next" type="button" role="button" aria-label="Next">
                  {%- render "icon", icon: "arrow-next" -%}
                </button>
              </div>
            </div>
          </div>
        </div>
      <!-- Start of Judge.me code --> 
  <div style='{{ jm_style }}' class='jdgm-widget jdgm-preview-badge' data-id='{{ product.id }}' data-auto-install='false'> 
 {{ product.metafields.judgeme.badge }} 
 </div> 
<!-- End of Judge.me code -->

      {%- comment -%} ════════ PESO ════════ {%- endcomment -%}
      {%- when 'weight' -%}
        {%- liquid
          assign card_weight = metafields.peso
          if card_weight == blank and selected_variant.weight > 0
            assign card_weight = selected_variant.weight | weight_with_unit
          endif
        -%}
        {%- if card_weight != blank -%}
          <div class="schar-product__item schar-product__item--weight" {{ block.shopify_attributes }}>
            <p class="schar-product__weight">{{ card_weight }}</p>
          </div>
        {%- endif -%}

      {%- comment -%} ════════ PRECIO ════════ {%- endcomment -%}
      {%- when 'price' -%}
        {%- unless product.template_suffix == "regalo" -%}
          <div class="schar-product__item schar-product__item--price" {{ block.shopify_attributes }}>
            <div class="main-product-price" id="price-{{ section.id }}">
              {%- render "price", target: selected_variant -%}
            </div>
          </div>
        {%- endunless -%}

      {%- comment -%} ════════ RESEÑAS ════════ {%- endcomment -%}

      {%- when 'reviews' -%}
        <div class="schar-product__item schar-product__item--reviews" {{ block.shopify_attributes }}>
          <div class="main-product-reviews">
            <div class="main-product-reviews-inner">
              {%- render 'judgeme_widgets', widget_type: 'judgeme_preview_badge', jm_style: '', concierge_install: false, product: product -%}
            </div>
          </div>
        </div>

      {%- comment -%} ════════ DESCRIPCIÓN ════════ {%- endcomment -%}
      {%- when 'description' -%}
        {%- liquid
          assign desc_text = product.description
          if block.settings.source == 'metafield'
            assign desc_text = metafields.descripcion_corta
          endif
        -%}
        {%- if desc_text != blank -%}
          <div class="schar-product__item schar-product__item--desc" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="schar-product__desc-heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            <div class="schar-product__desc page-text">{{ desc_text }}</div>
          </div>
        {%- endif -%}

      {%- comment -%} ════════ ACORDEONES (PESTAÑAS) ════════ {%- endcomment -%}
      {%- when 'accordions' -%}
        {%- liquid
          assign tab_1_title = metafields.pestana_1_titulo
          assign tab_1_text = metafields.pestana_1_texto
          assign tab_2_title = metafields.pestana_2_titulo
          assign tab_2_text = metafields.pestana_2_texto
          assign tab_3_title = metafields.pestana_3_titulo
          assign tab_3_text = metafields.pestana_3_texto
          assign has_tab_1 = false
          assign has_tab_2 = false
          assign has_tab_3 = false
          if tab_1_title != blank and tab_1_text != blank
            assign has_tab_1 = true
          endif
          if tab_2_title != blank and tab_2_text != blank
            assign has_tab_2 = true
          endif
          if tab_3_title != blank and tab_3_text != blank
            assign has_tab_3 = true
          endif
        -%}
        {%- if has_tab_1 or has_tab_2 or has_tab_3 -%}
          <div class="schar-product__item schar-product__item--accordions" {{ block.shopify_attributes }}>
            <div class="product-accordions">
              {%- if has_tab_1 -%}
                <div class="product-accordion open faq-item">
                  <button class="product-accordion-header color-green" role="tab" type="button">
                    <p class="product-accordion-title faq-item-title" data-title="{{- tab_1_title -}}">{{- tab_1_title -}}</p>
                    <span class="product-accordion-icon">{%- render 'icon', icon: 'minus' -%}</span>
                  </button>
                  <div class="product-accordion-content-wrapper">
                    <div class="product-accordion-content page-text tabpanel-1">
                      {{- tab_1_text | prepend: "<li class='tabpanel-bullet'><span class='tabpanel-bullet-icon'></span><p class='tabpanel-bullet-text'>" | newline_to_br | replace: "<br />", "</p></li><li class='tabpanel-bullet'><span class='tabpanel-bullet-icon'></span><p class='tabpanel-bullet-text'>" -}}
                    </div>
                  </div>
                </div>
              {%- endif -%}
              {%- if has_tab_2 -%}
                <div class="product-accordion faq-item">
                  <button class="product-accordion-header color-green" role="tab" type="button">
                    <p class="product-accordion-title faq-item-title" data-title="{{- tab_2_title -}}">{{- tab_2_title -}}</p>
                    <span class="product-accordion-icon">{%- render 'icon', icon: 'minus' -%}</span>
                  </button>
                  <div class="product-accordion-content-wrapper">
                    <div class="product-accordion-content page-text">{{- tab_2_text | metafield_tag -}}</div>
                  </div>
                </div>
              {%- endif -%}
              {%- if has_tab_3 -%}
                <div class="product-accordion faq-item">
                  <button class="product-accordion-header color-green" role="tab" type="button">
                    <p class="product-accordion-title faq-item-title" data-title="{{- tab_3_title -}}">{{- tab_3_title -}}</p>
                    <span class="product-accordion-icon">{%- render 'icon', icon: 'minus' -%}</span>
                  </button>
                  <div class="product-accordion-content-wrapper">
                    <div class="product-accordion-content page-text">{{- tab_3_text | metafield_tag -}}</div>
                  </div>
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

      {%- comment -%} ════════ COMPRA (variantes + cantidad + carrito + comprar ya) ════════ {%- endcomment -%}
      {%- when 'purchase' -%}
        <div class="schar-product__item schar-product__item--purchase" {{ block.shopify_attributes }}>
          <div class="main-product-form">

            <noscript>
              <div class="product-form__input{% if product.has_only_default_variant %} hidden{% endif %}">
                <label class="form__label" for="Variants-{{ section.id }}">{{ "products.product.product_variants" | t }}</label>
                <div class="select">
                  <select class="select__select" data-productid="{{ product.id }}" form="product-form" id="Variants-{{ section.id }}" name="id">
                    {%- for variant in product.variants -%}
                      <option {%- if variant == selected_variant -%}selected="selected"{%- endif -%} {%- if variant.available == false -%}disabled{% endif %} value="{{ variant.id }}">
                        {{ variant.title }}
                        {%- if variant.available == false -%} - {{ "products.product.sold_out" | t }}{%- endif -%}
                        - {{ variant.price | money | strip_html }}
                      </option>
                    {%- endfor -%}
                  </select>
                </div>
              </div>
            </noscript>

            <product-form>
              {%- form "product", product, data-productid: product.id, id: product_form_id, class: "main-product-form form", novalidate: "novalidate", data-type: "add-to-cart-form" -%}
                <input data-productid="{{ product.id }}" name="id" type="hidden" value="{{ selected_variant.id }}">

                {%- comment -%} ── Variantes ── {%- endcomment -%}
                {%- unless product.has_only_default_variant -%}
                  <div class="schar-form-section">
                    <variant-radios class="no-js-hidden" data-section="{{ section.id }}" data-url="{{ product.url }}">
                      {%- for option in product.options_with_values -%}
                        {%- assign option_name = option.name | handleize -%}
                        <fieldset class="js product-form-fieldset schar-form-fieldset">
                          <p class="product-form-legend schar-form-legend">{{- option.name -}}</p>
                          <div class="product-variants-grid schar-variants-grid {{ option_name }} color-green">
                            {%- for value in option.values -%}
                              <input class="product-form-radio" type="radio" id="{{- section.id -}}-{{- option.name -}}-{{- forloop.index0 -}}" name="{{ option.name }}" data-product-option value="{{- value | escape -}}" form="product-form-{{ section.id }}" {%- if option.selected_value == value -%}checked{% endif -%}>
                              <label class="product-variant {{ option_name -}}" data-title="{{- value -}}" for="{{ section.id }}-{{ option.name }}-{{ forloop.index0 }}">
                                {{- value -}}
                              </label>
                            {%- endfor -%}
                          </div>
                        </fieldset>
                      {%- endfor -%}
                      <script type="application/json">
                        [
                        {%- for variant in product.variants -%}
                          {
                          "id": {{- variant.id -}},
                          "title": {{- variant.title | json -}},
                          "option1": {{- variant.option1 | json -}},
                          "option2": {{- variant.option2 | json -}},
                          "option3": {{- variant.option3 | json -}},
                          "sku": {{- variant.sku | json -}},
                          "requires_shipping": {{- variant.requires_shipping -}},
                          "taxable": {{- variant.taxable -}},
                          "featured_image": {{- variant.featured_image | json -}},
                          "available": {{- variant.available -}},
                          "name": {{- variant.name | json -}},
                          "options": {{- variant.options | json -}},
                          "price": {{- variant.price -}},
                          "compare_at_price": {{- variant.compare_at_price | json -}},
                          "inventory_management": "{{- variant.inventory_management -}}",
                          "featured_media": {{- variant.featured_media | json -}},
                          "inventory_policy": {{- variant.inventory_policy | json -}},
                          "inventory_quantity": {{- variant.inventory_quantity -}}
                          }
                          {%- unless forloop.last -%},{%- endunless -%}
                        {%- endfor -%}
                        ]
                      </script>
                    </variant-radios>
                  </div>
                {%- endunless -%}

                {%- unless template.suffix == "regalo" -%}
                  {%- comment -%} ── Cantidad ── {%- endcomment -%}
                  <div class="schar-qty-wrap">
                    <p class="schar-form-legend schar-qty-legend">Cantidad</p>
                    <div class="schar-qty" data-schar-qty>
                      <button class="schar-qty__btn schar-qty__btn--minus" type="button" aria-label="Disminuir">
                        <svg viewBox="0 0 24 24" width="15" height="15" fill="none"><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                      </button>
                      <input class="schar-qty__input" id="quantity" name="quantity" type="number" inputmode="numeric" pattern="[0-9]*" min="1" value="1" autocomplete="off">
                      <button class="schar-qty__btn schar-qty__btn--plus" type="button" aria-label="Aumentar">
                        <svg viewBox="0 0 24 24" width="15" height="15" fill="none"><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
                      </button>
                    </div>
                  </div>

                  {%- comment -%} ── Botones ── {%- endcomment -%}
                  <div class="schar-cta-group">
                    <button class="schar-cta schar-cta--atc product-form__submit" type="submit" name="add" id="add-to-cart-button" {%- if selected_variant.available == false -%} disabled {%- endif -%}>
                      <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                      </svg>
                      <span>{%- if selected_variant.available -%}Añadir al carrito{%- else -%}Agotado{%- endif -%}</span>
                    </button>
                    <button class="schar-cta schar-cta--buy" type="button" data-schar-buynow {%- if selected_variant.available == false -%} disabled {%- endif -%}>
                      <span>Comprar ya</span>
                    </button>
                  </div>
                {%- else -%}
                  <input autocomplete="off" id="quantity" min="1" name="quantity" pattern="[0-9]*" type="hidden" value="1">
                {%- endunless -%}
              {%- endform -%}
            </product-form>
          </div>

          {%- comment -%} ── Trust badges ── {%- endcomment -%}
          {%- unless template.suffix == "regalo" -%}
            <ul class="schar-trust">
              <li class="schar-trust__item">
                <span class="schar-trust__icon">
                  <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 3h13v13H1z"/><path d="M14 8h4l3 3v5h-7"/><circle cx="5.5" cy="18.5" r="2"/><circle cx="17.5" cy="18.5" r="2"/>
                  </svg>
                </span>
                <span class="schar-trust__text"><strong>Envío gratis</strong> en pedidos de $900 o más</span>
              </li>
              <li class="schar-trust__item">
                <span class="schar-trust__icon">
                  <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/>
                  </svg>
                </span>
                <span class="schar-trust__text"><strong>Pago 100% seguro</strong> y protegido</span>
              </li>
              <li class="schar-trust__item">
                <span class="schar-trust__icon">
                  <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 22c4-1 7-3 9-6M22 2c0 8-4 13-9 15"/><path d="M7 13c-2 0-4-1-4-4 2 0 4 1 4 4zM12 9c-1.5-1.5-2-4-1-6 2 1 3 3.5 2 6zM17 11c0-2 1-4 4-4 0 2-1 4-4 4z"/>
                    <line x1="3" y1="3" x2="21" y2="21"/>
