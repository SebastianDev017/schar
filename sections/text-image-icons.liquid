{% style %}
  /* =============================================
     FONT: Times ExtraBold
     ============================================= */
  @font-face {
    font-family: 'Times ExtraBold';
    src: url('https://cdn.shopify.com/s/files/1/0991/5082/3710/files/Times-ExtraBold.otf?v=1777160115') format('opentype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  /* =============================================
     VARIABLES
     ============================================= */
  #shopify-section-{{ section.id }} {
    --schar-font-heading: 'Times ExtraBold', 'Playfair Display', serif;
    --schar-font-body: 'Inter', 'Poppins', sans-serif;

    --tii-bg: {{ bg_color }};
    --tii-padding-top: {{ padding_top }}px;
    --tii-padding-bottom: {{ padding_bottom }}px;

    --tii-gap: {{ content_gap }}px;
    --tii-image-col: {{ image_col_width }}%;
    --tii-text-max-width: {{ text_max_width }}px;
    --tii-text-only-max-width: {{ text_only_max_width }}px;

    --tii-heading-desktop: {{ heading_size_desktop }}px;
    --tii-heading-mobile: {{ heading_size_mobile }}px;
    --tii-heading-color: {{ heading_color }};
    --tii-heading-lh: {{ heading_line_height }}%;
    --tii-heading-mb: {{ heading_margin_bottom }}px;

    --tii-text-desktop: {{ text_size_desktop }}px;
    --tii-text-mobile: {{ text_size_mobile }}px;
    --tii-text-color: {{ text_color }};
    --tii-text-mt: {{ text_margin_top }}px;

    --tii-btn-bg: {{ btn_bg }};
    --tii-btn-text: {{ btn_text }};
    --tii-btn-bg-hover: {{ btn_bg_hover }};
    --tii-btn-text-hover: {{ btn_text_hover }};
    --tii-btn-radius: {{ btn_radius }}px;
    --tii-btn-height: {{ btn_height }}px;
    --tii-btn-px: {{ btn_padding_x }}px;
    --tii-btn-size-desktop: {{ btn_size_desktop }}px;
    --tii-btn-size-mobile: {{ btn_size_mobile }}px;
    --tii-btn-mt: {{ button_margin_top }}px;
  }

  /* =============================================
     SECTION BASE
     ============================================= */
  .schar-tii {
    background-color: var(--tii-bg);
    padding: var(--tii-padding-top) var(--header-desktop-padding, 63px) var(--tii-padding-bottom);
  }

  /* =============================================
     GRID – CON IMAGEN (2 columnas)
     ============================================= */
  .schar-tii__grid--has-image {
    display: grid;
    grid-template-columns: var(--tii-image-col) 1fr;
    gap: var(--tii-gap);
    align-items: {{ vertical_align }};
    max-width: 1314px;
    margin: 0 auto;
  }

  .schar-tii__grid--has-image.schar-tii__grid--img-right {
    grid-template-columns: 1fr var(--tii-image-col);
  }

  .schar-tii__grid--img-right .schar-tii__image-col {
    order: 2;
  }

  .schar-tii__grid--img-right .schar-tii__text-col {
    order: 1;
  }

  /* Text inner con imagen */
  .schar-tii__grid--has-image .schar-tii__text-inner {
    max-width: var(--tii-text-max-width);
  }

  /* =============================================
     GRID – SIN IMAGEN (texto centrado)
     ============================================= */
  .schar-tii__grid--text-only {
    display: flex;
    justify-content: center;
    max-width: 1314px;
    margin: 0 auto;
  }

  .schar-tii__grid--text-only .schar-tii__text-col {
    width: 100%;
  }

  .schar-tii__grid--text-only .schar-tii__text-inner {
    max-width: var(--tii-text-only-max-width);
    margin-left: auto;
    margin-right: auto;
  }

  /* =============================================
     IMAGE COLUMN
     ============================================= */
  .schar-tii__image-container {
    position: relative;
    width: 100%;
  }

  .schar-tii__image-wrapper {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
  }

  .schar-tii__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  /* =============================================
     ICONS
     ============================================= */
  .schar-tii__icons {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .schar-tii__icon {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: auto;
    transform: translate(-50%, 0);
  }

  .schar-tii__icon-img-wrap {
    width: var(--icon-size, 56px);
    height: var(--icon-size, 56px);
    flex-shrink: 0;
  }

  .schar-tii__icon-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .schar-tii__icon-label {
    margin-top: 6px;
    text-align: center;
    font-family: var(--schar-font-body);
    font-size: var(--icon-label-size, 14px);
    font-weight: 500;
    line-height: 1.3;
    color: var(--icon-text-color);
    max-width: 120px;
  }

  /* =============================================
     TEXT COLUMN
     ============================================= */
  .schar-tii__text-col[style*="center"] .schar-tii__text-inner {
    margin-left: auto;
    margin-right: auto;
  }

  .schar-tii__text-col[style*="right"] .schar-tii__text-inner {
    margin-left: auto;
  }

  /* Heading */
  .schar-tii__heading,
  .schar-tii__heading * {
    font-family: var(--schar-font-heading) !important;
    font-style: normal;
    font-weight: 400 !important;
    color: var(--tii-heading-color);
    font-size: clamp(
      var(--tii-heading-mobile),
      calc(var(--tii-heading-mobile) + ({{ heading_size_desktop }} - {{ heading_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--tii-heading-desktop)
    );
    line-height: var(--tii-heading-lh);
    margin: 0 0 var(--tii-heading-mb) 0;
  }

  .schar-tii__heading strong,
  .schar-tii__heading b {
    font-weight: 400 !important;
  }

  /* Text */
  .schar-tii__text,
  .schar-tii__text * {
    font-family: var(--schar-font-body);
    font-size: clamp(
      var(--tii-text-mobile),
      calc(var(--tii-text-mobile) + ({{ text_size_desktop }} - {{ text_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--tii-text-desktop)
    );
    line-height: 1.6;
    color: var(--tii-text-color);
  }

  .schar-tii__text:not(:first-child) {
    margin-top: var(--tii-text-mt);
  }

  /* Button */
  .schar-tii__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--tii-btn-height);
    padding: 0 var(--tii-btn-px);
    background-color: var(--tii-btn-bg);
    color: var(--tii-btn-text);
    border: none;
    border-radius: var(--tii-btn-radius);
    font-family: var(--schar-font-body);
    font-size: clamp(
      var(--tii-btn-size-mobile),
      calc(var(--tii-btn-size-mobile) + ({{ btn_size_desktop }} - {{ btn_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--tii-btn-size-desktop)
    );
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: lowercase;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.3s ease, color 0.3s ease, transform 0.2s ease;
  }

  .schar-tii__btn-wrap {
    margin-top: var(--tii-btn-mt);
  }

  .schar-tii__btn:hover {
    background-color: var(--tii-btn-bg-hover);
    color: var(--tii-btn-text-hover);
    transform: translateY(-1px);
  }

  .schar-tii__btn:active {
    transform: translateY(0);
  }

  /* =============================================
     RESPONSIVE
     ============================================= */
  @media (max-width: 1439px) {
    .schar-tii {
      padding-left: var(--header-laptop-padding, 46px);
      padding-right: var(--header-laptop-padding, 46px);
    }
  }

  @media (max-width: 834px) {
    .schar-tii {
      padding-left: var(--header-tablet-padding, 46px);
      padding-right: var(--header-tablet-padding, 46px);
    }
  }

  @media (max-width: 680px) {
    .schar-tii {
      padding-left: var(--header-mobile-padding, 22px);
      padding-right: var(--header-mobile-padding, 22px);
    }

    .schar-tii__grid--has-image,
    .schar-tii__grid--has-image.schar-tii__grid--img-right {
      grid-template-columns: 1fr;
    }

    .schar-tii__text-col {
      order: -1 !important;
      text-align: center !important;
    }

    .schar-tii__text-inner {
      margin-left: auto !important;
      margin-right: auto !important;
    }

    .schar-tii__image-col {
      order: 1 !important;
      max-width: 400px;
      margin: 0 auto;
    }

    .schar-tii__icon-label {
      font-size: 11px;
      max-width: 80px;
    }

    .schar-tii__icon-img-wrap {
      width: calc(var(--icon-size, 56px) * 0.7);
      height: calc(var(--icon-size, 56px) * 0.7);
    }
  }

  @media (hover: hover) {
    .schar-tii__btn:hover {
      background-color: var(--tii-btn-bg-hover);
      color: var(--tii-btn-text-hover);
      transform: translateY(-1px);
    }
  }

  /* =============================================
     ICON BLOCK – per-block variables
     ============================================= */
  {%- for block in section.blocks -%}
    #shopify-section-{{ section.id }} [{{ block.shopify_attributes | split: '"' | first | append: '"' }}] {
      --icon-size: {{ block.settings.icon_size | default: 56 }}px;
      --icon-label-size: {{ block.settings.label_size | default: 14 }}px;
    }
  {%- endfor -%}
{% endstyle %}
