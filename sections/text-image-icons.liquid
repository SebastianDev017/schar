{%- comment -%}
  Section 4: Texto + Imagen + Íconos – Dr. Schär México
  ✔ Sin imagen → columna de imagen desaparece del DOM, texto centrado
  ✔ Con imagen → grid 2 columnas con íconos flotantes
  ✔ Funciona como sección de texto enriquecido O imagen-texto
  ✔ Máxima personalización (47+ controles)
{%- endcomment -%}

{%- liquid
  assign image = section.settings.image
  assign title = section.settings.title
  assign text = section.settings.text
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign text_alignment = section.settings.text_alignment | default: 'left'
  assign image_position = section.settings.image_position | default: 'left'
  assign has_button = false
  assign has_image = false

  if button_label != blank and button_link != blank
    assign has_button = true
  endif

  if image != blank
    assign has_image = true
  endif

  comment — Sizes
  endcomment
  assign heading_size_desktop = section.settings.heading_size_desktop | default: 56
  assign heading_size_mobile = section.settings.heading_size_mobile | default: 32
  assign text_size_desktop = section.settings.text_size_desktop | default: 20
  assign text_size_mobile = section.settings.text_size_mobile | default: 15
  assign btn_size_desktop = section.settings.button_size_desktop | default: 13
  assign btn_size_mobile = section.settings.button_size_mobile | default: 12

  comment — Colors
  endcomment
  assign bg_color = section.settings.bg_color | default: '#E8DDD0'
  assign heading_color = section.settings.heading_color | default: '#2C1A0E'
  assign text_color = section.settings.text_color | default: '#2C1A0E'
  assign btn_bg = section.settings.button_bg_color | default: '#2C1A0E'
  assign btn_text = section.settings.button_text_color | default: '#FFFFFF'
  assign btn_bg_hover = section.settings.button_bg_hover | default: '#C41E3A'
  assign btn_text_hover = section.settings.button_text_hover | default: '#FFFFFF'
  assign btn_radius = section.settings.button_border_radius | default: 50
  assign btn_height = section.settings.button_height | default: 48
  assign btn_padding_x = section.settings.button_padding_x | default: 32

  comment — Layout
  endcomment
  assign content_gap = section.settings.content_gap | default: 60
  assign image_col_width = section.settings.image_col_width | default: 45
  assign padding_top = section.settings.padding_top | default: 80
  assign padding_bottom = section.settings.padding_bottom | default: 80
  assign heading_line_height = section.settings.heading_line_height | default: 110
  assign heading_margin_bottom = section.settings.heading_margin_bottom | default: 24
  assign text_margin_top = section.settings.text_margin_top | default: 20
  assign button_margin_top = section.settings.button_margin_top | default: 32
  assign text_max_width = section.settings.text_max_width | default: 600
  assign vertical_align = section.settings.vertical_align | default: 'center'

  comment — Text-only alignment (when no image)
  endcomment
  assign text_only_alignment = section.settings.text_only_alignment | default: 'center'
  assign text_only_max_width = section.settings.text_only_max_width | default: 700
-%}

<section class="schar-tii" data-section-id="{{ section.id }}" data-section-type="text-image-icons">
  <div class="schar-tii__grid{% if has_image %} schar-tii__grid--has-image{% if image_position == 'right' %} schar-tii__grid--img-right{% endif %}{% else %} schar-tii__grid--text-only{% endif %}">

    {%- comment -%} IMAGE COLUMN – solo si hay imagen {%- endcomment -%}
    {%- if has_image -%}
      <div class="schar-tii__image-col" data-aos="fade-up">
        <div class="schar-tii__image-container">

          <div class="schar-tii__image-wrapper">
            <img
              class="schar-tii__image"
              src="{{ image | image_url: width: 1000 }}"
              alt="{{ image.alt | escape | default: title | strip_html | escape }}"
              loading="lazy"
            >
          </div>

          {%- if section.blocks.size > 0 -%}
            <div class="schar-tii__icons">
              {%- for block in section.blocks -%}
                {%- liquid
                  assign icon = block.settings.icon
                  assign icon_text = block.settings.text
                  assign icon_color = block.settings.icon_color | default: '#2C1A0E'
                  assign icon_pos_top = block.settings.position_top | default: 0
                  assign icon_pos_left = block.settings.position_left | default: 50
                -%}
                <div
                  class="schar-tii__icon"
                  style="top: {{ icon_pos_top }}%; left: {{ icon_pos_left }}%; --icon-text-color: {{ icon_color }};"
                  data-aos="fade-up"
                  data-aos-delay="{{ forloop.index | times: 100 }}"
                  {{ block.shopify_attributes }}
                >
                  {%- unless icon == blank -%}
                    <div class="schar-tii__icon-img-wrap">
                      <img
                        src="{{ icon | image_url: width: 200 }}"
                        alt="{{ icon.alt | escape | default: icon_text }}"
                        class="schar-tii__icon-img"
                        loading="lazy"
                      >
                    </div>
                  {%- endunless -%}
                  {%- unless icon_text == blank -%}
                    <p class="schar-tii__icon-label">{{ icon_text }}</p>
                  {%- endunless -%}
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

        </div>
      </div>
    {%- endif -%}

    {%- comment -%} TEXT COLUMN {%- endcomment -%}
    <div
      class="schar-tii__text-col"
      data-aos="fade-up"
      style="text-align: {% if has_image %}{{ text_alignment }}{% else %}{{ text_only_alignment }}{% endif %};"
    >
      <div class="schar-tii__text-inner">

        {%- unless title == blank -%}
          <{{ heading_tag }} class="schar-tii__heading">{{ title }}</{{ heading_tag }}>
        {%- endunless -%}

        {%- unless text == blank -%}
          <div class="schar-tii__text">{{ text }}</div>
        {%- endunless -%}

        {%- if has_button -%}
          <div class="schar-tii__btn-wrap">
            <a
              class="schar-tii__btn"
              href="{{ button_link }}"
              {%- if button_link contains 'http' or button_link contains 'mailto:' or button_link contains 'tel:' %} target="_blank" rel="noopener"{% endif -%}
            >
              {{ button_label }}
            </a>
          </div>
        {%- endif -%}

      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Texto + Imagen + Íconos",
  "tag": "section",
  "class": "schar-tii-section",
  "settings": [
    {
      "type": "header",
      "content": "── IMAGEN ──"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen principal",
      "info": "Si no subes imagen, la sección funciona como bloque de texto centrado."
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Posición de la imagen",
      "default": "left",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "right", "label": "Derecha" }
      ],
      "info": "Solo aplica cuando hay imagen."
    },
    {
      "type": "range",
      "id": "image_col_width",
      "label": "Ancho columna imagen (%)",
      "min": 0,
      "max": 60,
      "step": 5,
      "default": 45,
      "unit": "%",
      "info": "Solo aplica cuando hay imagen."
    },
    {
      "type": "header",
      "content": "── CONTENIDO ──"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Título",
      "default": "<p><strong>¿eres celiaco?</strong></p>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>Quieres saber más acerca de qué es y saber si es que tú eres celiaco...</p>"
    },
    {
