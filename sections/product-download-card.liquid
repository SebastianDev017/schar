        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Texto del botón",
          "default": "Descarga aquí"
        },
        {
          "type": "url",
          "id": "download_link",
          "label": "Enlace de descarga (PDF)"
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Color de fondo del botón",
          "default": "#C41E3A"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Color de texto del botón",
          "default": "#ffffff"
        },
        {
          "type": "header",
          "content": "Lista de Características"
        },
        {
          "type": "textarea",
          "id": "list_items",
          "label": "Items de la lista (separar con ||)",
          "default": "Probiótico: GOS es un prebiótico orgánico||Sin azúcares añadidos: Solo contiene 100% lactosa",
          "info": "Separa cada item con || (doble barra vertical)"
        },
        {
          "type": "color",
          "id": "checkmark_color",
          "label": "Color del checkmark",
          "default": "#C41E3A"
        },
        {
          "type": "color",
          "id": "list_text_color",
          "label": "Color del texto de lista",
          "default": "#333333"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tarjetas de Producto",
      "blocks": [
        {
          "type": "product_card"
        }
      ]
    }
  ]
