      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "button_font_weight",
      "label": "Peso de fuente del botón",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Redondeo del botón",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 25
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Tarjeta de Producto",
      "settings": [
        {
          "type": "header",
