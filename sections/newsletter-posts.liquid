{{- 'css-newsletter-posts.css' | asset_url | stylesheet_tag -}}

{%- liquid 
	assign title = section.settings.title
-%}

<div class="newsletter-posts section" data-section-id="{{- section.id -}}" data-section-type="newsletter">
  <div class="newsletter-posts-container">
    <h1 class="newsletter-posts-title">{{ title }}</h1>

    <div class="newsletter-posts-list">
      {%- for block in section.blocks -%}
        {%- if block.settings.article_text != blank or block.settings.article_img  -%}
          {% render 'newsletter-article-content', article_image: block.settings.article_img, article_text: block.settings.article_text, article_link: block.settings.article_link %}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
	"name": "Tarjetas con imagenes",
	"tag": "section",
	"class": "newsletter-posts-section",
	"settings": [
		{
			"type": "header",
			"content": "Contenido"
		},
		{
			"type": "text",
			"id": "title",
			"label": "Título"
		},
	],
  "blocks": [
    {
      "type": "text",
      "name": "Tarjeta",
      "settings": [
        {
          "type":"header",
          "content":"Contenido tarjeta",
        },
        {
          "type":"image_picker",
          "id":"article_img",
          "label":"Imagen",
        },
        {
          "type": "text",
          "id": "article_text",
          "label": "Texto"
        },
        {
          "type": "url",
          "id": "article_link",
          "label": "Enlace"
        },
      ]
    },
  ],
  "max_blocks": 20,
	"presets": [
		{
			"category": "Homepage",
			"name": "Tarjetas con imagenes"
		}
	]
}
{% endschema %}
