{%- comment -%}
  ============================================================
  COMING SOON – Dr. Schär México
  ✔ Full screen: 100vh × 100vw
  ✔ Imagen de fondo (la sube el cliente)
  ✔ Título en 2 líneas (Times ExtraBold)
  ✔ Formulario Klaviyo embebido por ID
  ============================================================
{%- endcomment -%}

{%- liquid
  assign bg_image = section.settings.bg_image
  assign overlay_opacity = section.settings.overlay_opacity | default: 30
  assign title_line1 = section.settings.title_line1
  assign title_line2 = section.settings.title_line2
  assign klaviyo_id = section.settings.klaviyo_form_id
  assign content_align = section.settings.content_align | default: 'center'
-%}

{%- comment -%} Google Tag Manager — necesario en la página /password {%- endcomment -%}
<!-- Google Tag Manager -->
