  "presets": [
    {
      "name": "Preguntas Frecuentes",
      "category": "Homepage",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "Equipo básico para tu cocina libre de gluten", "answer": "<p>Descubre los utensilios esenciales para preparar alimentos sin gluten de manera segura y deliciosa.</p>" } },
        { "type": "faq_item", "settings": { "question": "¿Puedo preparar la masa libre de gluten con antelación?", "answer": "<p>Sí, muchas masas sin gluten se pueden preparar con anticipación y refrigerar hasta por 24 horas.</p>" } },
        { "type": "faq_item", "settings": { "question": "¿Por qué es importante el vapor de agua al hornear?", "answer": "<p>El vapor ayuda a crear una corteza crujiente y permite que el pan se expanda correctamente durante la cocción.</p>" } }
