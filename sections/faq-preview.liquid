{% style %}
  @font-face {
    font-family: 'Times ExtraBold';
    src: url('https://cdn.shopify.com/s/files/1/0991/5082/3710/files/Times-ExtraBold.otf?v=1777160115') format('opentype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} {
    --faq-font-heading: 'Times ExtraBold', 'Playfair Display', serif;
    --faq-font-body: 'Inter', 'Poppins', sans-serif;
    --faq-bg: {{ bg_color }};
    --faq-pt: {{ padding_top }}px;
    --faq-pb: {{ padding_bottom }}px;
    --faq-gap: {{ content_gap }}px;
    --faq-left-w: {{ left_col_width }}%;

    --faq-h-desktop: {{ heading_size_desktop }}px;
    --faq-h-mobile: {{ heading_size_mobile }}px;
    --faq-h-color: {{ heading_color }};
    --faq-h-lh: {{ heading_line_height }}%;

    --faq-q-desktop: {{ question_size_desktop }}px;
    --faq-q-mobile: {{ question_size_mobile }}px;
    --faq-q-color: {{ question_color }};
    --faq-a-desktop: {{ answer_size_desktop }}px;
    --faq-a-mobile: {{ answer_size_mobile }}px;
    --faq-a-color: {{ answer_color }};
    --faq-chevron-color: {{ chevron_color }};
    --faq-divider: {{ divider_color }};

    --faq-btn-bg: {{ btn_bg }};
    --faq-btn-text: {{ btn_text }};
    --faq-btn-bg-hover: {{ btn_bg_hover }};
    --faq-btn-text-hover: {{ btn_text_hover }};
    --faq-btn-radius: {{ btn_radius }}px;
    --faq-btn-height: {{ btn_height }}px;
    --faq-btn-px: {{ btn_padding_x }}px;
    --faq-btn-desktop: {{ btn_size_desktop }}px;
    --faq-btn-mobile: {{ btn_size_mobile }}px;
    --faq-btn-mt: {{ btn_margin_top }}px;
  }

  /* =============================================
     BASE
     ============================================= */
  .schar-faq {
    background-color: var(--faq-bg);
    padding: var(--faq-pt) var(--header-mobile-padding, 22px) var(--faq-pb);
  }

  .schar-faq__inner {
    max-width: 1314px;
    margin: 0 auto;
  }

  /* =============================================
     HEADING – Times ExtraBold
     ============================================= */
  .schar-faq__heading,
  .schar-faq__heading * {
    font-family: var(--faq-font-heading) !important;
    font-style: normal;
    font-weight: 400 !important;
    color: var(--faq-h-color);
    font-size: clamp(
      var(--faq-h-mobile),
      calc(var(--faq-h-mobile) + ({{ heading_size_desktop }} - {{ heading_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--faq-h-desktop)
    );
    line-height: var(--faq-h-lh);
    margin: 0;
  }

  .schar-faq__heading strong,
  .schar-faq__heading strong *,
  .schar-faq__heading b,
  .schar-faq__heading b * {
    font-weight: 400 !important;
    color: #C41E3A;
  }

  /* =============================================
     ACCORDION
     ============================================= */
  .schar-faq__item {
    border-bottom: 1px solid var(--faq-divider);
  }

  .schar-faq__item:first-child {
    border-top: 1px solid var(--faq-divider);
  }

  .schar-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 0;
    cursor: pointer;
    list-style: none;
    -webkit-tap-highlight-color: transparent;
  }

  .schar-faq__question::-webkit-details-marker {
    display: none;
  }

  .schar-faq__question-text {
    font-family: var(--faq-font-body);
    font-size: clamp(
      var(--faq-q-mobile),
      calc(var(--faq-q-mobile) + ({{ question_size_desktop }} - {{ question_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--faq-q-desktop)
    );
    font-weight: 500;
    color: var(--faq-q-color);
    line-height: 1.4;
    flex: 1;
  }

  .schar-faq__chevron {
    flex-shrink: 0;
    color: var(--faq-chevron-color);
    transition: transform 0.3s ease;
  }

  /* Chevron rota cuando está abierto */
  .schar-faq__item[open] .schar-faq__chevron {
    transform: rotate(90deg);
  }

  .schar-faq__answer {
    padding: 0 0 20px 0;
    overflow: hidden;
  }

  .schar-faq__answer,
  .schar-faq__answer * {
    font-family: var(--faq-font-body);
    font-size: clamp(
      var(--faq-a-mobile),
      calc(var(--faq-a-mobile) + ({{ answer_size_desktop }} - {{ answer_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--faq-a-desktop)
    );
    font-weight: 400;
    color: var(--faq-a-color);
    line-height: 1.6;
  }

  .schar-faq__answer p {
    margin: 0;
  }

  .schar-faq__answer p + p {
    margin-top: 12px;
  }

  /* =============================================
     BOTÓN
     ============================================= */
  .schar-faq__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: var(--faq-btn-height);
    padding: 0 var(--faq-btn-px);
    background-color: var(--faq-btn-bg);
    color: var(--faq-btn-text);
    border: none;
    border-radius: var(--faq-btn-radius);
    font-family: var(--faq-font-body);
    font-size: clamp(
      var(--faq-btn-mobile),
      calc(var(--faq-btn-mobile) + ({{ btn_size_desktop }} - {{ btn_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--faq-btn-desktop)
    );
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    text-align: center;
    cursor: pointer;
    transition: background-color 0.3s ease, color 0.3s ease, transform 0.2s ease;
  }

  .schar-faq__btn:hover {
    background-color: var(--faq-btn-bg-hover);
    color: var(--faq-btn-text-hover);
    transform: translateY(-1px);
  }

  .schar-faq__btn:active {
    transform: translateY(0);
  }

  .schar-faq__btn-wrap {
    margin-top: var(--faq-btn-mt);
  }

  /* Desktop: ocultar botón mobile, mostrar desktop */
  .schar-faq__btn-wrap--desktop {
    display: none;
  }

  .schar-faq__btn-wrap--mobile {
    display: block;
  }

  /* =============================================
     MOBILE-FIRST (default: 1 columna)
     ============================================= */
  .schar-faq__left {
    margin-bottom: 32px;
    text-align: center;
  }

  /* =============================================
     DESKTOP: 2 columnas
     ============================================= */
  @media (min-width: 835px) {
    .schar-faq {
      padding-left: var(--header-desktop-padding, 63px);
      padding-right: var(--header-desktop-padding, 63px);
    }

    .schar-faq__inner {
      display: grid;
      grid-template-columns: var(--faq-left-w) 1fr;
      gap: var(--faq-gap);
      align-items: start;
    }

    .schar-faq__left {
      position: sticky;
      top: 120px;
      margin-bottom: 0;
      text-align: left;
    }

    /* Desktop: mostrar botón en columna izquierda */
    .schar-faq__btn-wrap--desktop {
      display: block;
    }

    /* Desktop: ocultar botón debajo de accordions */
    .schar-faq__btn-wrap--mobile {
      display: none;
    }

    .schar-faq__btn {
      width: auto;
    }
  }

  @media (min-width: 681px) and (max-width: 834px) {
    .schar-faq {
      padding-left: var(--header-tablet-padding, 46px);
      padding-right: var(--header-tablet-padding, 46px);
    }
  }

  @media (hover: hover) {
    .schar-faq__btn:hover {
      background-color: var(--faq-btn-bg-hover);
      color: var(--faq-btn-text-hover);
    }
    .schar-faq__question:hover .schar-faq__question-text {
      color: #C41E3A;
    }
  }
{% endstyle %}
