{%- comment -%}
  Section 8: Preguntas Frecuentes – Dr. Schär México
  ✔ Desktop: 2 columnas (título+botón | accordions)
  ✔ Mobile: 1 columna apilada (título → accordions → botón)
  ✔ Desplegables nativos <details>/<summary>
  ✔ Máxima personalización (40+ controles)
{%- endcomment -%}

{%- liquid
  assign heading = section.settings.heading
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
  assign has_button = false
  if button_label != blank and button_link != blank
    assign has_button = true
  endif

  assign heading_size_desktop = section.settings.heading_size_desktop | default: 56
  assign heading_size_mobile = section.settings.heading_size_mobile | default: 36
  assign heading_color = section.settings.heading_color | default: '#2C1A0E'
  assign heading_line_height = section.settings.heading_line_height | default: 110

  assign question_size_desktop = section.settings.question_size_desktop | default: 18
  assign question_size_mobile = section.settings.question_size_mobile | default: 16
  assign question_color = section.settings.question_color | default: '#2C1A0E'
  assign answer_size_desktop = section.settings.answer_size_desktop | default: 16
  assign answer_size_mobile = section.settings.answer_size_mobile | default: 14
  assign answer_color = section.settings.answer_color | default: '#2C1A0E'
  assign chevron_color = section.settings.chevron_color | default: '#2C1A0E'
  assign divider_color = section.settings.divider_color | default: '#D5CBC0'

  assign bg_color = section.settings.bg_color | default: '#F5F0EB'
  assign padding_top = section.settings.padding_top | default: 80
  assign padding_bottom = section.settings.padding_bottom | default: 80
  assign content_gap = section.settings.content_gap | default: 60
  assign left_col_width = section.settings.left_col_width | default: 40

  assign btn_bg = section.settings.button_bg_color | default: '#C41E3A'
  assign btn_text = section.settings.button_text_color | default: '#FFFFFF'
  assign btn_bg_hover = section.settings.button_bg_hover | default: '#2C1A0E'
  assign btn_text_hover = section.settings.button_text_hover | default: '#FFFFFF'
  assign btn_radius = section.settings.button_border_radius | default: 50
  assign btn_height = section.settings.button_height | default: 52
  assign btn_padding_x = section.settings.button_padding_x | default: 36
  assign btn_size_desktop = section.settings.button_size_desktop | default: 15
  assign btn_size_mobile = section.settings.button_size_mobile | default: 14
  assign btn_margin_top = section.settings.button_margin_top | default: 32
-%}

<section class="schar-faq" data-section-id="{{ section.id }}">
  <div class="schar-faq__inner">

    {%- comment -%} LEFT: Heading + Button (desktop) {%- endcomment -%}
    <div class="schar-faq__left">
      {%- unless heading == blank -%}
        <{{ heading_tag }} class="schar-faq__heading" data-aos="fade-up">{{ heading }}</{{ heading_tag }}>
      {%- endunless -%}

      {%- if has_button -%}
        <div class="schar-faq__btn-wrap schar-faq__btn-wrap--desktop" data-aos="fade-up">
          <a class="schar-faq__btn" href="{{ button_link }}" {%- if button_link contains 'http' %} target="_blank" rel="noopener"{% endif -%}>
            {{ button_label }}
          </a>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} RIGHT: Accordion {%- endcomment -%}
    <div class="schar-faq__right" data-aos="fade-up">
      {%- for block in section.blocks -%}
        {%- liquid
          assign question = block.settings.question
          assign answer = block.settings.answer
        -%}

        <details class="schar-faq__item" {{ block.shopify_attributes }}>
          <summary class="schar-faq__question">
            <span class="schar-faq__question-text">{{ question }}</span>
            <svg class="schar-faq__chevron" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </summary>
          <div class="schar-faq__answer">
            {{ answer }}
          </div>
        </details>

      {%- endfor -%}
    </div>

    {%- comment -%} BUTTON mobile (debajo de los accordions) {%- endcomment -%}
    {%- if has_button -%}
      <div class="schar-faq__btn-wrap schar-faq__btn-wrap--mobile" data-aos="fade-up">
        <a class="schar-faq__btn" href="{{ button_link }}" {%- if button_link contains 'http' %} target="_blank" rel="noopener"{% endif -%}>
          {{ button_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Preguntas Frecuentes",
  "tag": "section",
  "class": "schar-faq-section",
  "settings": [
    {
      "type": "header",
      "content": "── CONTENIDO ──"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Título",
      "default": "<p>preguntas<br><strong>frecuentes</strong></p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón",
      "default": "Ver todas las preguntas frecuentes"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón"
    },
    {
      "type": "header",
      "content": "── LAYOUT ──"
    },
    {
      "type": "range",
      "id": "left_col_width",
      "label": "Ancho columna título (%)",
      "min": 30,
      "max": 50,
      "step": 5,
      "default": 40,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Espacio entre columnas (px)",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "── FONDO Y ESPACIADO ──"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#F5F0EB"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior (px)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "── TÍTULO ──"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Etiqueta HTML",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ]
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Tamaño desktop (px)",
      "min": 24,
      "max": 120,
      "step": 2,
      "default": 56,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Tamaño mobile (px)",
      "min": 20,
      "max": 72,
      "step": 2,
      "default": 36,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "label": "Line-height (%)",
      "min": 80,
      "max": 160,
      "step": 5,
      "default": 110,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#2C1A0E"
    },
    {
      "type": "header",
      "content": "── PREGUNTAS ──"
    },
    {
      "type": "range",
      "id": "question_size_desktop",
      "label": "Tamaño pregunta desktop (px)",
