{%- comment -%}
  Section 3: Banner Promocional – Dr. Schär México
  Diseñado para "envío gratis" y banners similares
  ✔ Máxima personalización desde admin (35+ controles)
  ✔ Posición 9 puntos, heading tag, tipografías editables
  ✔ Imagen de fondo desktop + mobile
  ✔ Times ExtraBold headings, Inter body
{%- endcomment -%}

{%- liquid
  assign block = section.blocks[0]
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign content_position = section.settings.content_position | default: 'center-center'
  assign text_alignment = section.settings.text_alignment | default: 'center'

  assign position_parts = content_position | split: '-'
  assign pos_vertical = position_parts[0]
  assign pos_horizontal = position_parts[1]

  assign button_exists = false
  if button_label != blank and button_link != blank
    assign button_exists = true
  endif

  comment
    Tamaños
  endcomment
  assign heading_size_desktop = section.settings.heading_size_desktop | default: 64
  assign heading_size_mobile = section.settings.heading_size_mobile | default: 36
  assign subheading_size_desktop = section.settings.subheading_size_desktop | default: 20
  assign subheading_size_mobile = section.settings.subheading_size_mobile | default: 14
  assign btn_size_desktop = section.settings.button_size_desktop | default: 13
  assign btn_size_mobile = section.settings.button_size_mobile | default: 12

  comment
    Colores
  endcomment
  assign heading_color = section.settings.heading_color | default: '#FFFFFF'
  assign subheading_color = section.settings.subheading_color | default: '#FFFFFF'
  assign overlay_color = section.settings.overlay_color | default: '#2C1A0E'
  assign overlay_opacity = section.settings.overlay_opacity | default: 30
  assign overlay_opacity_decimal = overlay_opacity | divided_by: 100.0

  comment
    Botón
  endcomment
  assign btn_bg = section.settings.button_bg_color | default: '#E8DDD0'
  assign btn_text = section.settings.button_text_color | default: '#2C1A0E'
  assign btn_bg_hover = section.settings.button_bg_hover | default: '#2C1A0E'
  assign btn_text_hover = section.settings.button_text_hover | default: '#FFFFFF'
  assign btn_radius = section.settings.button_border_radius | default: 50
  assign btn_height = section.settings.button_height | default: 48
  assign btn_padding_x = section.settings.button_padding_x | default: 32

  comment
    Layout
  endcomment
  assign content_max_width = section.settings.content_max_width | default: 600
  assign section_height_desktop = section.settings.section_height_desktop | default: 450
  assign section_height_mobile = section.settings.section_height_mobile | default: 350
  assign padding_top = section.settings.padding_top | default: 40
  assign padding_bottom = section.settings.padding_bottom | default: 40

  comment
    Spacing
  endcomment
  assign heading_line_height = section.settings.heading_line_height | default: 100
  assign heading_margin_bottom = section.settings.heading_margin_bottom | default: 8
  assign subheading_margin_bottom = section.settings.subheading_margin_bottom | default: 24
  assign button_margin_top = section.settings.button_margin_top | default: 24

  comment
    Subheading position
  endcomment
  assign subheading_position = section.settings.subheading_position | default: 'below'
-%}

<section class="schar-promo-banner" data-section-id="{{ section.id }}">

  {%- comment -%} Background image {%- endcomment -%}
  <div class="schar-promo-banner__bg">
    <div class="schar-promo-banner__overlay"></div>
    <picture>
      {%- if section.settings.mobile_image != blank -%}
        <source media="(max-width: 680px)" srcset="{{ section.settings.mobile_image | image_url }}">
      {%- endif -%}
      {%- if section.settings.desktop_image != blank -%}
        <img
          src="{{ section.settings.desktop_image | image_url }}"
          alt="{{ heading | strip_html | escape | default: 'Banner promocional' }}"
          loading="lazy"
        >
      {%- endif -%}
    </picture>
  </div>

  {%- comment -%} Content {%- endcomment -%}
  <div
    class="schar-promo-banner__content schar-pos-v--{{ pos_vertical }} schar-pos-h--{{ pos_horizontal }}"
    style="text-align: {{ text_alignment }};"
  >
    <div class="schar-promo-banner__inner">

      {%- if subheading_position == 'above' -%}
        {%- unless subheading == blank -%}
          <p class="schar-promo-banner__subheading">{{ subheading }}</p>
        {%- endunless -%}
      {%- endif -%}

      {%- unless heading == blank -%}
        <{{ heading_tag }} class="schar-promo-banner__heading">{{ heading }}</{{ heading_tag }}>
      {%- endunless -%}

      {%- if subheading_position == 'below' -%}
        {%- unless subheading == blank -%}
          <p class="schar-promo-banner__subheading">{{ subheading }}</p>
        {%- endunless -%}
      {%- endif -%}

      {%- if button_exists -%}
        <div class="schar-promo-banner__btn-wrap">
          <a
            class="schar-promo-banner__btn"
            href="{{ button_link }}"
            {%- if button_link contains 'http' or button_link contains 'mailto:' %} target="_blank" rel="noopener"{% endif -%}
          >
            {{ button_label }}
          </a>
        </div>
      {%- endif -%}

    </div>
  </div>

</section>

{% schema %}
{
  "name": "Banner Promocional",
  "tag": "section",
  "class": "schar-promo-section",
  "settings": [
    {
      "type": "header",
      "content": "── IMÁGENES ──"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Imagen escritorio"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Imagen móvil"
    },
    {
      "type": "header",
      "content": "── CONTENIDO ──"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Título",
      "default": "<p><strong>envío gratis</strong></p>"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Por tiempo limitado"
    },
    {
      "type": "select",
      "id": "subheading_position",
      "label": "Posición del subtítulo",
      "default": "below",
      "options": [
        { "value": "above", "label": "Arriba del título" },
        { "value": "below", "label": "Abajo del título" }
      ]
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón",
      "default": "Conoce Schär"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón"
    },
    {
      "type": "header",
      "content": "── LAYOUT ──"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Posición del contenido",
      "default": "center-center",
      "options": [
        { "value": "top-left", "label": "Arriba – Izquierda" },
        { "value": "top-center", "label": "Arriba – Centro" },
        { "value": "top-right", "label": "Arriba – Derecha" },
        { "value": "center-left", "label": "Centro – Izquierda" },
        { "value": "center-center", "label": "Centro – Centro" },
        { "value": "center-right", "label": "Centro – Derecha" },
        { "value": "bottom-left", "label": "Abajo – Izquierda" },
        { "value": "bottom-center", "label": "Abajo – Centro" },
        { "value": "bottom-right", "label": "Abajo – Derecha" }
      ]
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alineación del texto",
      "default": "center",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Derecha" }
      ]
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Ancho máximo contenido (px)",
      "min": 280,
      "max": 900,
      "step": 10,
      "default": 600,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "── SECCIÓN ──"
    },
    {
      "type": "range",
      "id": "section_height_desktop",
      "label": "Altura desktop (px)",
      "min": 200,
      "max": 800,
      "step": 10,
      "default": 450,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_height_mobile",
      "label": "Altura mobile (px)",
      "min": 200,
      "max": 600,
      "step": 10,
      "default": 350,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superior (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferior (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "── OVERLAY ──"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Color del overlay",
      "default": "#2C1A0E"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacidad del overlay (%)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "── TÍTULO ──"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Etiqueta HTML (SEO)",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ]
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Tamaño título desktop (px)",
      "min": 24,
      "max": 120,
      "step": 2,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Tamaño título mobile (px)",
      "min": 20,
      "max": 72,
      "step": 2,
      "default": 36,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "label": "Line-height título (%)",
      "min": 80,
      "max": 160,
      "step": 5,
      "default": 100,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color del título",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "label": "Margen inferior título (px)",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "── SUBTÍTULO ──"
    },
    {
      "type": "range",
      "id": "subheading_size_desktop",
      "label": "Tamaño subtítulo desktop (px)",
      "min": 10,
      "max": 36,
      "step": 1,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subheading_size_mobile",
      "label": "Tamaño subtítulo mobile (px)",
      "min": 10,
      "max": 28,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Color del subtítulo",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "subheading_margin_bottom",
      "label": "Margen inferior subtítulo (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "── BOTÓN ──"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Color de fondo",
      "default": "#E8DDD0"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Color de texto",
      "default": "#2C1A0E"
    },
    {
      "type": "color",
      "id": "button_bg_hover",
      "label": "Fondo hover",
      "default": "#2C1A0E"
    },
    {
      "type": "color",
      "id": "button_text_hover",
      "label": "Texto hover",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius (px)",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "button_height",
      "label": "Altura del botón (px)",
      "min": 32,
      "max": 72,
      "step": 2,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "button_padding_x",
      "label": "Padding horizontal (px)",
      "min": 12,
      "max": 60,
      "step": 2,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "button_size_desktop",
      "label": "Tamaño texto desktop (px)",
      "min": 10,
      "max": 22,
      "step": 1,
      "default": 13,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "button_size_mobile",
      "label": "Tamaño texto mobile (px)",
      "min": 9,
      "max": 18,
      "step": 1,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "button_margin_top",
      "label": "Margen superior botón (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 24,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Banner Promocional",
      "category": "Homepage"
    }
  ]
