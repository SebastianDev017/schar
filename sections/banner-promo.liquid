{% endschema %}

{% style %}
  /* =============================================
     FONT: Times ExtraBold
     ============================================= */
  @font-face {
    font-family: 'Times ExtraBold';
    src: url('https://cdn.shopify.com/s/files/1/0991/5082/3710/files/Times-ExtraBold.otf?v=1777160115') format('opentype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  /* =============================================
     VARIABLES – desde schema
     ============================================= */
  #shopify-section-{{ section.id }} {
    --schar-font-heading: 'Times ExtraBold', 'Playfair Display', serif;
    --schar-font-body: 'Inter', 'Poppins', sans-serif;
    --schar-white: #FFFFFF;
    --schar-dark: #2C1A0E;

    /* Heading */
    --heading-size-desktop: {{ heading_size_desktop }}px;
    --heading-size-mobile: {{ heading_size_mobile }}px;
    --heading-color: {{ heading_color }};
    --heading-line-height: {{ heading_line_height }}%;
    --heading-margin-bottom: {{ heading_margin_bottom }}px;

    /* Subheading */
    --subheading-size-desktop: {{ subheading_size_desktop }}px;
    --subheading-size-mobile: {{ subheading_size_mobile }}px;
    --subheading-color: {{ subheading_color }};
    --subheading-margin-bottom: {{ subheading_margin_bottom }}px;

    /* Button */
    --btn-bg: {{ btn_bg }};
    --btn-text: {{ btn_text }};
    --btn-bg-hover: {{ btn_bg_hover }};
    --btn-text-hover: {{ btn_text_hover }};
    --btn-radius: {{ btn_radius }}px;
    --btn-height: {{ btn_height }}px;
    --btn-padding-x: {{ btn_padding_x }}px;
    --btn-size-desktop: {{ btn_size_desktop }}px;
    --btn-size-mobile: {{ btn_size_mobile }}px;
    --btn-margin-top: {{ button_margin_top }}px;

    /* Layout */
    --content-max-width: {{ content_max_width }}px;
    --section-height-desktop: {{ section_height_desktop }}px;
    --section-height-mobile: {{ section_height_mobile }}px;
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;

    /* Overlay */
    --overlay-opacity: {{ overlay_opacity_decimal }};
  }

  /* =============================================
     BANNER BASE
     ============================================= */
  .schar-promo-banner {
    position: relative;
    width: 100%;
    height: var(--section-height-desktop);
    overflow: hidden;
  }

  /* Background */
  .schar-promo-banner__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .schar-promo-banner__bg picture,
  .schar-promo-banner__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .schar-promo-banner__overlay {
    position: absolute;
    inset: 0;
    background-color: {{ overlay_color }};
    opacity: var(--overlay-opacity);
    z-index: 1;
  }

  /* =============================================
     POSICIONAMIENTO 9 PUNTOS
     ============================================= */
  .schar-promo-banner__content {
    position: relative;
    z-index: 2;
    display: flex;
    width: 100%;
    height: 100%;
    padding: var(--section-padding-top) var(--header-desktop-padding, 63px) var(--section-padding-bottom);
    box-sizing: border-box;
  }

  .schar-promo-banner__content.schar-pos-v--top    { align-items: flex-start; }
  .schar-promo-banner__content.schar-pos-v--center { align-items: center; }
  .schar-promo-banner__content.schar-pos-v--bottom { align-items: flex-end; }

  .schar-promo-banner__content.schar-pos-h--left   { justify-content: flex-start; }
  .schar-promo-banner__content.schar-pos-h--center { justify-content: center; }
  .schar-promo-banner__content.schar-pos-h--right  { justify-content: flex-end; }

  .schar-promo-banner__inner {
    width: var(--content-max-width);
    max-width: 100%;
  }

  /* =============================================
     HEADING – Times ExtraBold
     ============================================= */
  .schar-promo-banner__heading,
  .schar-promo-banner__heading * {
    font-family: var(--schar-font-heading) !important;
    font-style: normal;
    font-weight: 400 !important;
    color: var(--heading-color);
    font-size: clamp(
      var(--heading-size-mobile),
      calc(var(--heading-size-mobile) + ({{ heading_size_desktop }} - {{ heading_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--heading-size-desktop)
    );
    line-height: var(--heading-line-height);
    margin: 0 0 var(--heading-margin-bottom) 0;
  }

  .schar-promo-banner__heading strong,
  .schar-promo-banner__heading strong *,
  .schar-promo-banner__heading b,
  .schar-promo-banner__heading b * {
    font-weight: 400 !important;
  }

  /* =============================================
     SUBHEADING
     ============================================= */
  .schar-promo-banner__subheading {
    font-family: var(--schar-font-body);
    font-size: clamp(
      var(--subheading-size-mobile),
      calc(var(--subheading-size-mobile) + ({{ subheading_size_desktop }} - {{ subheading_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--subheading-size-desktop)
    );
    font-weight: 400;
    color: var(--subheading-color);
    margin: 0 0 var(--subheading-margin-bottom) 0;
    line-height: 1.4;
  }

  /* =============================================
     BOTÓN
     ============================================= */
  .schar-promo-banner__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--btn-height);
    padding: 0 var(--btn-padding-x);
    background-color: var(--btn-bg);
    color: var(--btn-text);
    border: none;
    border-radius: var(--btn-radius);
    font-family: var(--schar-font-body);
    font-size: clamp(
      var(--btn-size-mobile),
      calc(var(--btn-size-mobile) + ({{ btn_size_desktop }} - {{ btn_size_mobile }}) * ((100vw - 375px) / (1440 - 375))),
      var(--btn-size-desktop)
    );
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.3s ease, color 0.3s ease, transform 0.2s ease;
  }

  .schar-promo-banner__btn-wrap {
    margin-top: var(--btn-margin-top);
  }

  .schar-promo-banner__btn:hover {
    background-color: var(--btn-bg-hover);
    color: var(--btn-text-hover);
    transform: translateY(-1px);
  }

  .schar-promo-banner__btn:active {
    transform: translateY(0);
  }

  /* =============================================
     RESPONSIVE
     ============================================= */
  @media (max-width: 1439px) {
    .schar-promo-banner__content {
      padding-left: var(--header-laptop-padding, 46px);
      padding-right: var(--header-laptop-padding, 46px);
    }
  }

  @media (max-width: 834px) {
    .schar-promo-banner__content {
      padding-left: var(--header-tablet-padding, 46px);
      padding-right: var(--header-tablet-padding, 46px);
    }
  }

  @media (max-width: 680px) {
    .schar-promo-banner {
      height: var(--section-height-mobile);
    }

    .schar-promo-banner__content {
      padding-left: var(--header-mobile-padding, 22px);
      padding-right: var(--header-mobile-padding, 22px);
    }

    .schar-promo-banner__inner {
      width: 100%;
    }
  }

  @media (hover: hover) {
    .schar-promo-banner__btn:hover {
      background-color: var(--btn-bg-hover);
      color: var(--btn-text-hover);
      transform: translateY(-1px);
    }
  }
{% endstyle %}
