{% style %}
  /* =============================================
     FONT: Times ExtraBold
     ============================================= */
  @font-face {
    font-family: 'Times ExtraBold';
    src: url('https://cdn.shopify.com/s/files/1/0991/5082/3710/files/Times-ExtraBold.otf?v=1777160115') format('opentype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  /* =============================================
     VARIABLES – inyectadas desde schema
     ============================================= */
  #shopify-section-{{ section.id }} {
    --schar-font-heading: 'Times ExtraBold', 'Playfair Display', serif;
    --schar-font-body: 'Inter', 'Poppins', sans-serif;

    /* Título */
    --title-size-desktop: {{ title_size_desktop }}px;
    --title-size-mobile: {{ title_size_mobile }}px;
    --title-color: {{ title_color }};
    --title-line-height: {{ title_line_height }}%;
    --title-margin-bottom: {{ title_margin_bottom }}px;

    /* Subtítulo */
    --subtitle-size-desktop: {{ subtitle_size_desktop }}px;
    --subtitle-size-mobile: {{ subtitle_size_mobile }}px;
    --subtitle-color: {{ subtitle_color }};
    --subtitle-margin-bottom: {{ subtitle_margin_bottom }}px;

    /* Párrafo */
    --paragraph-size-desktop: {{ paragraph_size_desktop }}px;
    --paragraph-size-mobile: {{ paragraph_size_mobile }}px;
    --paragraph-color: {{ paragraph_color }};
    --paragraph-margin-top: {{ paragraph_margin_top }}px;

    /* Botón */
    --btn-bg: {{ btn_bg }};
    --btn-text: {{ btn_text }};
    --btn-bg-hover: {{ btn_bg_hover }};
    --btn-text-hover: {{ btn_text_hover }};
    --btn-radius: {{ btn_radius }}px;
    --btn-height: {{ btn_height }}px;
    --btn-padding-x: {{ btn_padding_x }}px;
    --btn-size-desktop: {{ button_size_desktop }}px;
    --btn-size-mobile: {{ button_size_mobile }}px;
    --btn-margin-top: {{ button_margin_top }}px;

    /* Layout */
    --content-max-width: {{ content_max_width }}px;
    --section-height-desktop: {{ section_height_desktop }}vh;
    --section-height-mobile: {{ section_height_mobile }}vh;
    --section-max-height: {{ section_max_height }}px;
    --cover-padding-top: {{ padding_top }}px;
    --cover-padding-bottom: {{ padding_bottom }}px;
  }

  /* =============================================
     BASE
     ============================================= */
  .cover-wrapper {
    position: relative;
    z-index: 10;
  }

  .cover {
    position: relative;
  }

  .cover-background--image {
    position: relative;
    width: 100%;
    height: var(--section-height-desktop);
    max-height: var(--section-max-height);
    overflow: hidden;
  }

  .cover-background--image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .cover-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
    z-index: -1;
  }

  .cover-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .cover-content {
    position: relative;
    z-index: 2;
    display: block;
  }

  /* =============================================
     POSICIONAMIENTO 9 PUNTOS
     ============================================= */
  .cover-info {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    padding: var(--cover-padding-top) var(--header-desktop-padding, 63px) var(--cover-padding-bottom);
    overflow: hidden;
    z-index: 2;
    box-sizing: border-box;
  }

  .cover-info.schar-pos-v--top    { align-items: flex-start; }
  .cover-info.schar-pos-v--center { align-items: center; }
  .cover-info.schar-pos-v--bottom { align-items: flex-end; }

  .cover-info.schar-pos-h--left   { justify-content: flex-start; }
  .cover-info.schar-pos-h--center { justify-content: center; }
  .cover-info.schar-pos-h--right  { justify-content: flex-end; }

  .cover-info-inner {
    width: var(--content-max-width);
    max-width: 100%;
  }

  .schar-pos-h--center .cover-info-inner { text-align: center; }
  .schar-pos-h--right .cover-info-inner  { text-align: right; }

  /* =============================================
     SUBTÍTULO
     ============================================= */
  .schar-cover-subtitle {
    font-family: var(--schar-font-body);
    font-size: clamp(var(--subtitle-size-mobile), calc(var(--subtitle-size-mobile) + ({{ subtitle_size_desktop }} - {{ subtitle_size_mobile }}) * ((100vw - 375px) / (1440 - 375))), var(--subtitle-size-desktop));
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: lowercase;
    color: var(--subtitle-color);
    margin-bottom: var(--subtitle-margin-bottom);
  }

  /* =============================================
     TÍTULO – Times ExtraBold
     ============================================= */
  .schar-cover-title,
  .schar-cover-title * {
    font-family: var(--schar-font-heading) !important;
    font-style: normal;
    font-weight: 400 !important;
    color: var(--title-color);
    font-size: clamp(var(--title-size-mobile), calc(var(--title-size-mobile) + ({{ title_size_desktop }} - {{ title_size_mobile }}) * ((100vw - 375px) / (1440 - 375))), var(--title-size-desktop));
    line-height: var(--title-line-height);
    margin: 0 0 var(--title-margin-bottom) 0;
  }

  .schar-cover-title strong,
  .schar-cover-title strong *,
  .schar-cover-title b,
  .schar-cover-title b * {
    font-weight: 400 !important;
    font-style: normal;
  }

  .cover-subtitle + .cover-title-container {
    margin-top: 0;
  }

  /* =============================================
     PÁRRAFO
     ============================================= */
  .schar-cover-text {
    margin-top: var(--paragraph-margin-top);
    font-family: var(--schar-font-body);
    font-size: clamp(var(--paragraph-size-mobile), calc(var(--paragraph-size-mobile) + ({{ paragraph_size_desktop }} - {{ paragraph_size_mobile }}) * ((100vw - 375px) / (1440 - 375))), var(--paragraph-size-desktop));
    line-height: 1.6;
    color: var(--paragraph-color);
  }

  /* =============================================
     BOTÓN
     ============================================= */
  .schar-cover-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--btn-height);
    padding: 0 var(--btn-padding-x);
    background-color: var(--btn-bg);
    color: var(--btn-text);
    border: none;
    border-radius: var(--btn-radius);
    font-family: var(--schar-font-body);
    font-size: clamp(var(--btn-size-mobile), calc(var(--btn-size-mobile) + ({{ button_size_desktop }} - {{ button_size_mobile }}) * ((100vw - 375px) / (1440 - 375))), var(--btn-size-desktop));
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: lowercase;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.3s ease, color 0.3s ease, transform 0.2s ease;
  }

  .schar-cover-btn:hover {
    background-color: var(--btn-bg-hover);
    color: var(--btn-text-hover);
    transform: translateY(-1px);
  }

  .schar-cover-btn:active {
    transform: translateY(0);
  }

  .cover-button-container:not(:first-child) {
    margin-top: var(--btn-margin-top);
  }

  /* =============================================
     TEXTO INFERIOR + FLOAT ASSET
     ============================================= */
  .schar-cover-bottom {
    position: absolute;
    bottom: 32px;
    left: 0;
    width: 100%;
    z-index: 2;
    text-align: center;
    font-family: var(--schar-font-body);
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
  }

  .cover-section.with-float-asset .cover-asset { opacity: 1; }
  .cover-section.with-float-asset + .shopify-section .section:before {
    content: "";
    display: none;
    width: 100%;
    height: 111px;
    background: var(--background-color);
  }

  .cover-asset {
    position: absolute;
    bottom: 0;
    left: 0;
    z-index: 3;
    opacity: 0;
    width: 100%;
  }

  .cover-asset-image-wrapper {
    position: absolute;
    right: var(--header-desktop-padding, 63px);
    bottom: -58px;
    width: clamp(248px, calc(248px + (321 - 248) * ((100vw - 1024px) / (1440 - 1024))), 321px);
    height: clamp(326px, calc(326px + (422 - 326) * ((100vw - 1024px) / (1440 - 1024))), 422px);
  }

  .cover-asset-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: bottom;
  }

  /* =============================================
     RESPONSIVE
     ============================================= */
  @media (max-width: 1439px) {
    .cover-info {
      padding-left: var(--header-laptop-padding, 46px);
      padding-right: var(--header-laptop-padding, 46px);
    }
    .cover-asset-image-wrapper {
      right: var(--header-laptop-padding, 46px);
    }
  }

  @media (max-width: 834px) {
    .cover-info {
      padding-left: var(--header-tablet-padding, 46px);
      padding-right: var(--header-tablet-padding, 46px);
    }
    .cover-info-inner {
      width: min(var(--content-max-width), 380px);
    }
    .cover-asset-image-wrapper {
      bottom: -35px;
      width: clamp(147px, calc(147px + (192 - 147) * ((100vw - 680px) / (834 - 680))), 192px);
      height: clamp(193px, calc(193px + (252 - 193) * ((100vw - 680px) / (834 - 680))), 252px);
    }
  }

  @media (max-width: 680px) {
    .cover-background--image {
      height: var(--section-height-mobile);
      max-height: calc(var(--section-max-height) - 150px);
    }

    .cover-info {
      padding-left: var(--header-mobile-padding, 22px);
      padding-right: var(--header-mobile-padding, 22px);
    }

    .cover-info-inner {
      width: 100%;
    }

    .cover-asset-image-wrapper {
      right: 50%;
      bottom: -132px;
      transform: translateX(50%);
    }

    .schar-cover-bottom {
      bottom: 20px;
      font-size: 13px;
    }

    .cover-section.with-float-asset + .shopify-section .section:before {
      display: block;
    }
  }

  @media (hover: hover) {
    .schar-cover-btn:hover {
      background-color: var(--btn-bg-hover);
      color: var(--btn-text-hover);
      transform: translateY(-1px);
    }
  }
{% endstyle %}
