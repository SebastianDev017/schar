{%- comment -%}
  Section 2: Hero Full-Width – Dr. Schär México
  MÁXIMA PERSONALIZACIÓN desde el admin de Shopify
  ✔ Tipografías: tamaño mobile + desktop para título, subtítulo, párrafo
  ✔ Colores: título, subtítulo, párrafo, overlay, botón (bg, texto, hover)
  ✔ Layout: posición 9 puntos, alineación texto, ancho del contenido
  ✔ Sección: altura desktop/mobile, overlay opacidad
  ✔ Botón: colores, border-radius, tamaño, spacing
  ✔ Heading tag: H1–H6
  ✔ Font: Times ExtraBold desde CDN
{%- endcomment -%}

{{- 'css-cover.css' | asset_url | stylesheet_tag -}}
<script src="{{- 'js-cover.js' | asset_url -}}" defer></script>

{%- liquid
  assign block = section.blocks[0]
  assign block_type = block.type
  assign title = block.settings.title
  assign subtitle = block.settings.subtitle
  assign button_label = block.settings.button_label
  assign button_link = block.settings.button_link
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign content_position = section.settings.content_position | default: 'center-left'
  assign text_alignment = section.settings.text_alignment | default: 'left'

  assign position_parts = content_position | split: '-'
  assign pos_vertical = position_parts[0]
  assign pos_horizontal = position_parts[1]

  assign button_exists = false
  if button_label != blank and button_link != blank
    assign button_exists = true
  endif

  comment
    Tamaños de fuente
  endcomment
  assign title_size_desktop = section.settings.title_size_desktop | default: 72
  assign title_size_mobile = section.settings.title_size_mobile | default: 36
  assign subtitle_size_desktop = section.settings.subtitle_size_desktop | default: 13
  assign subtitle_size_mobile = section.settings.subtitle_size_mobile | default: 11
  assign paragraph_size_desktop = section.settings.paragraph_size_desktop | default: 18
  assign paragraph_size_mobile = section.settings.paragraph_size_mobile | default: 14
  assign button_size_desktop = section.settings.button_size_desktop | default: 13
  assign button_size_mobile = section.settings.button_size_mobile | default: 12

  comment
    Colores
  endcomment
  assign title_color = section.settings.title_color | default: '#FFFFFF'
  assign subtitle_color = section.settings.subtitle_color | default: '#F5C842'
  assign paragraph_color = section.settings.paragraph_color | default: '#FFFFFFE6'
  assign overlay_color = section.settings.overlay_color | default: '#2C1A0E'
  assign overlay_opacity = section.settings.overlay_opacity | default: 50
  assign overlay_opacity_decimal = overlay_opacity | divided_by: 100.0

  comment
    Botón
  endcomment
  assign btn_bg = section.settings.button_bg_color | default: '#E8DDD0'
  assign btn_text = section.settings.button_text_color | default: '#2C1A0E'
  assign btn_bg_hover = section.settings.button_bg_hover | default: '#2C1A0E'
  assign btn_text_hover = section.settings.button_text_hover | default: '#FFFFFF'
  assign btn_radius = section.settings.button_border_radius | default: 50
  assign btn_height = section.settings.button_height | default: 48
  assign btn_padding_x = section.settings.button_padding_x | default: 32

  comment
    Layout
  endcomment
  assign content_max_width = section.settings.content_max_width | default: 540
  assign section_height_desktop = section.settings.section_height_desktop | default: 100
  assign section_height_mobile = section.settings.section_height_mobile | default: 85
  assign section_max_height = section.settings.section_max_height | default: 800
  assign padding_top = section.settings.padding_top | default: 60
  assign padding_bottom = section.settings.padding_bottom | default: 60

  comment
    Spacing
  endcomment
  assign subtitle_margin_bottom = section.settings.subtitle_margin_bottom | default: 12
  assign title_margin_bottom = section.settings.title_margin_bottom | default: 0
  assign paragraph_margin_top = section.settings.paragraph_margin_top | default: 16
  assign button_margin_top = section.settings.button_margin_top | default: 32

  comment
    Title line height
  endcomment
  assign title_line_height = section.settings.title_line_height | default: 105
-%}

{%- capture open_tag -%}
  {%- if button_label == blank and button_link != blank -%}
    <a class="cover-content" href="{{ button_link }}">
  {%- else -%}
    <div class="cover-content">
  {%- endif -%}
{%- endcapture -%}

{%- capture close_tag -%}
  {%- if button_label == blank and button_link != blank -%}
    </a>
  {%- else -%}
    </div>
  {%- endif -%}
{%- endcapture -%}

<div class="cover-wrapper">
  <div
    class="cover block-type-{{ block_type }}"
    data-section-id="{{ section.id }}"
    data-section-type="cover"
  >
    {{ open_tag }}

      {%- unless section.settings.float_asset == blank -%}
        <div class="cover-asset no-touch">
          <div class="cover-asset-image-wrapper">
            <img class="cover-asset-image" src="{{ section.settings.float_asset | image_url }}" alt="{{ section.settings.float_asset.alt | escape }}" fetchpriority="high" data-aos="fade-up" data-aos-delay="300">
          </div>
        </div>
      {%- endunless -%}

      {%- case block_type -%}
        {%- when 'image' -%}
          <div class="cover-background cover-background--image">
            <div class="cover-overlay" style="background: rgba({{ overlay_color | remove: '#' | slice: 0, 2 | prepend: '0x' | plus: 0 }}, {{ overlay_color | remove: '#' | slice: 2, 2 | prepend: '0x' | plus: 0 }}, {{ overlay_color | remove: '#' | slice: 4, 2 | prepend: '0x' | plus: 0 }}, {{ overlay_opacity_decimal }});"></div>
            <picture>
              {%- if block.settings.mobile_image != blank -%}
                <source media="(max-width: 680px)" srcset="{{ block.settings.mobile_image | image_url }}">
              {%- endif -%}
              {%- if block.settings.desktop_image != blank -%}
                <img src="{{ block.settings.desktop_image | image_url }}" alt="{{ title | strip_html | escape | default: 'Portada' }}" fetchpriority="high">
              {%- endif -%}
            </picture>
          </div>

        {%- when 'video' -%}
          <div class="cover-background cover-background--image">
            <div class="cover-overlay" style="background: rgba({{ overlay_color | remove: '#' | slice: 0, 2 | prepend: '0x' | plus: 0 }}, {{ overlay_color | remove: '#' | slice: 2, 2 | prepend: '0x' | plus: 0 }}, {{ overlay_color | remove: '#' | slice: 4, 2 | prepend: '0x' | plus: 0 }}, {{ overlay_opacity_decimal }});"></div>
            {%- if block.settings.video_desktop != blank -%}
              {{ block.settings.video_desktop | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, class: 'cover-video', preload: 'auto' }}
            {%- endif -%}
          </div>
      {%- endcase -%}

      <article
        class="cover-info schar-pos-v--{{ pos_vertical }} schar-pos-h--{{ pos_horizontal }}"
        style="text-align: {{ text_alignment }};"
        data-aos="fade-up"
      >
        <div class="cover-info-inner">

          {%- unless subtitle == blank -%}
            <p class="schar-cover-subtitle">{{ subtitle }}</p>
          {%- endunless -%}

          {%- unless title == blank -%}
            <header class="cover-title-container">
              <{{ heading_tag }} class="schar-cover-title">{{ title }}</{{ heading_tag }}>
            </header>
          {%- endunless -%}

          {%- unless block.settings.text_paragraph == blank -%}
            <p class="schar-cover-text">{{ block.settings.text_paragraph }}</p>
          {%- endunless -%}

          {%- if button_exists -%}
            <div class="cover-button-container">
              <a
                class="schar-cover-btn"
                href="{{ button_link }}"
                {%- if button_link contains 'http' or button_link contains 'mailto:' %} target="_blank" rel="noopener"{% endif -%}
              >
                {{ button_label }}
              </a>
            </div>
          {%- endif -%}

        </div>
      </article>

      {%- unless section.settings.bottom_paragraph == blank -%}
        <p class="schar-cover-bottom">{{ section.settings.bottom_paragraph }}</p>
      {%- endunless -%}

    {{ close_tag }}
  </div>
</div>

