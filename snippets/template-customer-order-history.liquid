{%- comment -%}theme-check-disable{%- endcomment -%}
{% paginate customer.orders by 20 %}
  {% if customer.orders.size != 0 %}
    <span class="customer-swipe page-text">{{ 'customer.swipe' | t }}{% render 'icon', icon: 'accounts-swipe-arrow' %}</span>
    <div class="table-container">
      <div class="table-wrapper">
        <table class="customer-table table">
          <thead>
            <tr class="page-text">
              <th style="width: 90px">{{ 'customer.orders.order_number' | t }}</th>
              <th style="width: 140px">{{ 'customer.orders.date' | t }}</th>
              <th style="width: 147px">{{ 'customer.orders.payment_status' | t }}</th>
              <th style="width: 174px">{{ 'customer.orders.fulfillment_status' | t }}</th>
              <th style="width: 105px">{{ 'customer.orders.total' | t }}</th>
            </tr>
          </thead>
          <tbody>
            {% for order in customer.orders %}
              <tr>
                <td data-label="{{ 'customer.orders.order_number' | t }}">
                  <a class="button secondary-button order-button" href="{{ order.customer_url }}">{{ order.name }}</a>
                </td>
                <td class="page-text" data-label="{{ 'customer.orders.date' | t }}">{{ order.created_at | time_tag: format: 'date' }}</td>
                <td class="page-text" data-label="{{ 'customer.orders.payment_status' | t }}">{{ order.financial_status_label }}</td>
                <td class="page-text" data-label="{{ 'customer.orders.fulfillment_status' | t }}">{{ order.fulfillment_status_label }}</td>
                <td class="page-text" data-label="{{ 'customer.orders.total' | t }}">{{ order.total_price | money | replace: ' ', '' }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>

    {% if paginate.pages > 1 %}
      {% include 'pagination-custom' %}
    {% endif %}

    <div class="customer-logout-container">
      <a class="button" href="{{ routes.account_logout_url }}" id="customer_logout_link">{{ 'customer.log_out' | t }}</a>
    </div>

  {% else %}
    <div class="empty-orders-text-wrapper">
      <div class="empty-orders-text page-text page-text-fit text-center">{{ 'customer.orders.none' | t }}</div>
    </div>

    <div class="customer-logout-container">
      <a class="button" href="{{ routes.account_logout_url }}" id="customer_logout_link">{{ 'customer.log_out' | t }}</a>
    </div>
  {% endif %}
{% endpaginate %}
