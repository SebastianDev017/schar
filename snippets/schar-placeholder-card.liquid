{%- comment -%}
  Placeholder card para carrusel sin colección
  Uso: {% render 'schar-placeholder-card', index: i %}
{%- endcomment -%}

<div class="schar-fc__ph-card">
  <div class="schar-fc__ph-img">
    <svg viewBox="0 0 200 280" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="200" height="280" rx="8" fill="#D5CBC0"/>
      <rect x="50" y="60" width="100" height="100" rx="50" fill="#C4B8AB"/>
      <rect x="40" y="180" width="120" height="12" rx="6" fill="#C4B8AB"/>
      <rect x="60" y="200" width="80" height="10" rx="5" fill="#C4B8AB"/>
      <rect x="55" y="230" width="90" height="14" rx="7" fill="#B8AA9C"/>
    </svg>
  </div>
  <div class="schar-fc__ph-info">
    {%- case index -%}
      {%- when 1 -%}
        <p class="schar-fc__ph-type">Pan y Crujientes</p>
        <p class="schar-fc__ph-name">Mix B Bread</p>
        <p class="schar-fc__ph-price">$189.00 MXN</p>
      {%- when 2 -%}
        <p class="schar-fc__ph-type">Cereales</p>
        <p class="schar-fc__ph-name">Fruit Müsli</p>
        <p class="schar-fc__ph-price">$159.00 MXN</p>
      {%- when 3 -%}
        <p class="schar-fc__ph-type">Snacks</p>
        <p class="schar-fc__ph-name">Saltí Crackers</p>
        <p class="schar-fc__ph-price">$129.00 MXN</p>
      {%- when 4 -%}
        <p class="schar-fc__ph-type">Harinas</p>
        <p class="schar-fc__ph-name">Mix C Cake</p>
        <p class="schar-fc__ph-price">$175.00 MXN</p>
      {%- when 5 -%}
        <p class="schar-fc__ph-type">Pasta</p>
        <p class="schar-fc__ph-name">Fusilli</p>
        <p class="schar-fc__ph-price">$99.00 MXN</p>
      {%- when 6 -%}
        <p class="schar-fc__ph-type">Galletas</p>
        <p class="schar-fc__ph-name">Wafers Cacao</p>
        <p class="schar-fc__ph-price">$119.00 MXN</p>
      {%- else -%}
        <p class="schar-fc__ph-type">Categoría</p>
        <p class="schar-fc__ph-name">Producto {{ index }}</p>
        <p class="schar-fc__ph-price">$149.00 MXN</p>
    {%- endcase -%}
  </div>
</div>
