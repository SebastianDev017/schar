{%- comment -%}theme-check-disable{%- endcomment -%}
<div class="customer-order-wrapper">
  <div class="customer-information">
    <div class="customer-status-information">
      <h2 class="page-text customer-subtitle">{{ 'customer.order.title' | t: name: order.name }}</h2>
      {% assign order_date = order.created_at | date: '%d %B %A' %}
      <p class="page-text">{{ 'customer.order.date' | t }}{{ order.created_at | time_tag: format: 'date' }}</p>
      {% if order.cancelled %}
        {% assign cancelled_at = order.cancelled_at | date: "%B %d, %Y %I:%M%p" %}
        <!-- <p>{{ 'customer.order.cancelled' | t: date: cancelled_at }}</p> -->
        <p class="page-text">{{ 'customer.order.cancelled_reason' | t: reason: order.cancel_reason }}</p>
    {% endif %}
    </div>
  
    <span class="customer-swipe page-text">{{ 'customer.swipe' | t }}{% render 'icon', icon: 'accounts-swipe-arrow' %}</span>
    <div class="table-container">
      <div class="table-wrapper">
        <table class="customer-table table table-full-width page-text">
          <thead>
            <tr>
              <th>{{ 'customer.order.product' | t }}</th>
              <th>{{ 'customer.order.sku' | t }}</th>
              <th>{{ 'customer.order.price' | t }}</th>
              <th style="width: 90px;">{{ 'customer.order.quantity' | t }}</th>
              <th style="width: 150px;">{{ 'customer.order.total' | t }}</th>
            </tr>
          </thead>
          <tbody>
            {% for line_item in order.line_items %}
            <tr id="{{ line_item.id }}">
              <td>
                <a class="customer-order-product-link" href="{{ line_item.product.url }}">{{ line_item.title }}</a>
  
                {% if line_item.fulfillment %}
                  <div class="note">
                    {% assign created_at = line_item.fulfillment.created_at | time_tag: format: 'date' %}
                    {{ 'customer.order.fulfilled_at' | t }} {{ created_at }}
                    <br>
                    {% if line_item.fulfillment.tracking_number %}
                      <a class="customer-order-product-link" href="{{ line_item.fulfillment.tracking_url }}" target="_blank">{{ line_item.fulfillment.tracking_company }} #{{ line_item.fulfillment.tracking_number}}</a>
                    {% endif %}
                  </div>
                {% endif %}
              </td>
              <td>{{ line_item.sku }}</td>
              <td>{{ line_item.price | money | replace: ' ', '' }}</td>
              <td class="">{{ line_item.quantity }}</td>
              <td class="">{{ line_item.quantity | times: line_item.price | money | replace: ' ', '' }}</td>
            </tr>
            {% endfor %}
          </tbody>
          <tfoot>
            <tr>
              <td colspan="4">{{ 'customer.order.subtotal' | t }}</td>
              <td class="">{{ order.subtotal_price | money | replace: ' ', '' }}</td>
            </tr>
  
            {% for discount in order.discounts %}
              <tr class="order_summary discount">
                <td colspan="4">{{ discount.code }} {{ 'customer.order.discount' | t }}</td>
                <td class="">{{ discount.savings | money | replace: ' ', '' }}</td>
              </tr>
            {% endfor %}
  
            {% for shipping_method in order.shipping_methods %}
            <tr>
              <td colspan="4">{{ 'customer.order.shipping' | t }} ({{ shipping_method.title }})</td>
              <td class="">{{ shipping_method.price | money | replace: ' ', '' }}</td>
            </tr>
            {% endfor %}
  
            {% for tax_line in order.tax_lines %}
              <tr>
                <td colspan="4">{{ 'customer.order.tax' | t }} ({{ tax_line.title }} {{ tax_line.rate | times: 100 }}%)</td>
                <td class="">{{ tax_line.price | money | replace: ' ', '' }}</td>
              </tr>
            {% endfor %}
  
            <tr>
              <td colspan="4"><strong>{{ 'customer.order.total' | t }}</strong></td>
              <td><strong>{{ order.total_price | money | replace: ' ', '' }} {{ order.currency }}</strong></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

  </div>

  <div class="customer-order-information">
    <div>
      <div class="customer-payment-header">
        <h4 class="page-text customer-subtitle">{{ 'customer.order.billing_address' | t }}</h4>
        <p class="page-text"><span>{{ 'customer.order.payment_status' | t }}:</span> {{ order.financial_status_label }}</p>
      </div>
      <p class="page-text">
        {%- if order.billing_address.name != blank -%}
          {{ order.billing_address.name }}<br>
        {%- endif -%}
        {%- if order.billing_address.company != blank -%}
          {{ order.billing_address.company }}<br>
        {%- endif -%}
        {%- if order.billing_address.street != blank -%}
          {{ order.billing_address.street }}<br>
        {%- endif -%}
        {%- if order.billing_address.city != blank -%}
          {{ order.billing_address.city }}<br>
        {%- endif -%}
        {%- if order.billing_address.province != blank -%}
          {{ order.billing_address.province }}<br>
        {%- endif -%}
        {%- if order.billing_address.zip != blank -%}
          {{ order.billing_address.zip | upcase }}<br>
        {%- endif -%}
        {%- if order.billing_address.country != blank -%}
          {{ order.billing_address.country }}<br>
        {%- endif -%}
        {%- if order.billing_address.phone != blank -%}
          {{ order.billing_address.phone }}
        {%- endif -%}
      </p>
    </div>

    <div>
      <div class="customer-payment-header">
        <h4 class="page-text customer-subtitle">{{ 'customer.order.shipping_address' | t }}</h4>
        <p class="page-text"><span>{{ 'customer.order.fulfillment_status' | t }}:</span> {{ order.fulfillment_status_label }}</p>
      </div>
      <p class="page-text">
        {%- if order.billing_address.name != blank -%}
          {{ order.billing_address.name }}<br>
        {%- endif -%}
        {% if order.shipping_address.company != blank %}
          {{ order.shipping_address.company }}<br>
        {% endif %}
        {%- if order.shipping_address.street != blank -%}
          {{ order.shipping_address.street }}<br>
        {%- endif -%}
        {%- if order.shipping_address.city != blank -%}
          {{ order.shipping_address.city }}<br>
        {%- endif -%}
        {% if order.shipping_address.province != blank %}
          {{ order.shipping_address.province }}<br>
        {% endif %}
        {%- if order.shipping_address.zip  != blank -%}
          {{ order.shipping_address.zip | upcase }}
        {%- endif -%}
        {%- if order.shipping_address.country != blank -%}
          {{ order.shipping_address.country }}<br>
        {%- endif -%}
        {%- if order.shipping_address.phone != blank -%}
          {{ order.shipping_address.phone }}
        {%- endif -%}
      </p>
    </div>
  </div>
</div>

<div class="customer-logout-container buttons-column center">
  <a class="customer-back-button customer-secondary-button" href="{{- routes.account_url -}}">{{ 'customer.orders.back_to_orders' | t }}</a>
  <a class="button" href="{{- routes.account_logout_url -}}" id="customer_logout_link">{{ 'customer.log_out' | t }}</a>
</div>
