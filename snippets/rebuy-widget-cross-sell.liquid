<div data-rebuy-id="88459" data-rebuy-shopify-product-ids="{{ product.id }}"></div>

{% capture widget_template %}
  <script id="rebuy-widget-88459" type="text/template">
    <div class="rebuy-widget cross-sell-widget" v-bind:class="['widget-type-' + config.type.replace('_','-'), 'widget-display-' + config.display_type, products.length > 0 ? 'is-visible' : 'is-hidden', 'widget-layout-' + currentLayout()]" v-bind:id="'rebuy-widget-' + id" v-cloak v-on:click="stopPropagation($event)">
  
      <div class="rebuy-widget-container" v-bind:class="['widget-display-' + config.display_type, visible ? 'is-visible' : 'is-hidden' ]" v-cloak v-on:click.self="hide()">
  
        <div class="rebuy-widget-content">
          <div class="rebuy-modal-close" v-on:click="hide()">
            <i class="fas fa-times"></i>
          </div>
  
          <div class="rebuy-timer" v-if="hasTimer()">
            <h5 class="rebuy-timer-title" v-if="config.language.timer_title">
              <span v-html="config.language.timer_title"></span>
              <span class="rebuy-timer-minutes" v-html="config.timer.duration_minutes"></span>:<span class="rebuy-timer-seconds" v-html="config.timer.duration_seconds"></span>
            </h5>
          </div>
  
          <h4 class="super-title" v-html="config.language.super_title" v-if="config.language.super_title != ''"></h4>
  
          <h3 class="primary-title" v-html="config.language.title" v-if="config.language.title != ''"></h3>
  
          <div class="description" v-html="config.language.description" v-if="config.language.description != ''"></div>
  
          <div class="rebuy-product-grid" v-bind:class="layoutClasses">
  
            <div class="rebuy-product-block" v-bind:class="[product.handle, 'product-id-' + product.id, cartHasProduct(product) ? 'cart-has-item' : '', productTagClasses(product)]" v-for="(product, product_index) in products">
  
              <div class="rebuy-product-media">
                <a class="rebuy-product-image" v-bind:class="[hasLearnMore() ? 'clickable' : '']" v-bind:href="learnMoreURL(product)" v-bind:style="imageStyles" v-on:click="learnMore(product);">
                  <img v-bind:alt="'View ' + product.title" v-bind:src="itemImage(product, product.selected_variant, '400x400')">
                </a>
              </div>
              <div class="rebuy-product-info">
                <a class="rebuy-product-title" v-bind:alt="'View ' + product.title" v-bind:class="[hasLearnMore() ? 'clickable' : '']" v-bind:href="learnMoreURL(product)" v-html="product.title" v-on:click="learnMore(product);"></a>
                <div class="rebuy-variant-title" v-html="product.selected_variant.title" v-if="showVariantTitle(product)"></div>
                <div class="rebuy-product-review" v-if="hasProductReviews(product)">
                  <span class="rebuy-star-rating">
                    <span class="rebuy-star-rating-background"></span>
                    <span class="rebuy-star-rating-foreground" v-bind:style="{ width: productReviewRatingPercentage(product) }"></span>
                  </span>
                  <span class="rebuy-review-count" v-html="productReviewCount(product)"></span>
                </div>
  
                <div class="rebuy-product-price">
                  <div v-if="variantOnSale(product, product.selected_variant)">
                    <span class="rebuy-money compare-at" v-html="formatMoney(variantCompareAtPrice(product, product.selected_variant))"></span>
                    <span class="rebuy-money sale" v-html="formatMoney(variantPrice(product, product.selected_variant))"></span>
                  </div>
                  <div v-if="!(variantOnSale(product, product.selected_variant))">
                    <span class="rebuy-money" v-html="formatMoney(variantPrice(product, product.selected_variant))"></span>
                  </div>
                </div>
                <div class="rebuy-product-description" v-html="text(product.body_html)" v-if="showProductDescription(product)"></div>
              </div>
              <div class="rebuy-product-options form" v-if="showVariantSelect(product)">
                <select class="select" :class="{ hide : settings.view_options.variant_selector == 'buttons' }" :id="id + '-' + 'select' + '-' + product_index" v-model="product.selected_variant_id" v-on:change="selectVariant(product)">
                  <option v-bind:value="variant.id" v-for="variant in product.variants">[[variant.title]]</option>
                </select>
                <div class="rebuy-color-swatches" v-for="option in product.options" v-if="displayColorSwatches(option)">
                  <div class="rebuy-color-swatch" v-for="(value, value_index) in filterOOSOptions(option, product)">
                    <input class="rebuy-color-input hide" :checked="value_index == 0" :id="id + '-color-' + product_index + '-' + value + '-' + value_index" :name="id + '-color-' + product_index" :value="value" type="radio" v-on:change="selectVariantByColor(product, value, product_index)">
                    <label class="rebuy-color-label" :for="id + '-color-' + product_index + '-' + value + '-' + value_index" :style="{ backgroundColor: value }" :title="value"></label>
                  </div>
                </div>
  
                <div class="mt-10 rebuy-size-swatches" v-for="option in product.options" v-if="displaySizeSwatches(option)">
                  <div class="rebuy-size-swatch" v-for="(value, value_index) in filterOOSOptions(option, product)">
  
                    <input class="rebuy-size-input hide" :checked="value_index == 0" :id="id + '-size-' + product_index + '-' + value" :name="id + '-size-' + product_index" :value="value" type="radio" v-on:change="selectVariantBySize(product, value, product_index)">
                    <label class="rebuy-size-label" :for="id + '-size-' + product_index + '-' + value">{{ value }}</label>
                  </div>
                </div>
              </div>
              <div class="rebuy-product-actions">
  
                <div class="subscription-checkbox" v-if="showSubscriptionOptions(product)">
                  <label class="rebuy-checkbox-label">
                    <input class="checkbox-input rebuy-checkbox" type="checkbox" v-model="product.subscription" v-on:change="toggleSubscription(product)" />
                    <span class="checkbox-label" v-html="upgradeToSubscriptionLabel(product)"></span>
                  </label>
                </div>
  
                <div class="subscription-frequency" v-if="showSubscriptionFrequency(product)">
                  <select class="rebuy-select" v-model="product.subscription_frequency" v-on:change="updateSubscriptionFrequency(product)">
                    <option v-bind:value="frequency" v-for="frequency in product.subscription_frequencies">[[ frequencyLabel(frequency, product.subscription_interval) ]]</option>
                  </select>
                </div>
  
                <div class="product-quantity" v-if="hasQuantityInputEnabled()">
                  <div class="rebuy-select-wrapper">
                    <label class="rebuy-label">Quantity</label>
                    <select class="rebuy-select" v-model="product.quantity">
                      <option v-bind:value="n" v-for="n in maxQuantityInputValue()">{{ n }}</option>
                    </select>
                  </div>
                </div>
  
                <button class="button" type="button" v-bind:alt="'Add ' + product.title + ' to Cart'" v-bind:class="{ working: (product.status != 'ready' && product.status != 'selecting') }" v-bind:disabled="!(variantAvailable(product.selected_variant)) || (product.status != 'ready' && product.status != 'selecting')" v-on:click="addToCart(product)">
                  <span v-html="buttonLabel(product)"></span>
                </button>
              </div>
            </div>
  
          </div>
  
          <div class="rebuy-modal-actions" v-if="showContinueButton()">
            <button class="rebuy-button decline" type="button" v-on:click="hide()">
              <span v-html="continueLabel()"></span>
            </button>
          </div>
  
        </div>
  
      </div>
    </div>
  </script>
{% endcapture %}

{%- liquid
	assign open = "{{"
	assign end = "}}"
	echo widget_template | replace: "[[", open | replace: "]]", end
-%}
