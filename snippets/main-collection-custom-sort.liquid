{%- liquid
  assign sort_by = collection.sort_by | default: collection.default_sort_by
-%}

<div class="collection-custom-sort schar-sort">
  <button class="collection-custom-sort-button schar-sort__button" type="button">
    <svg class="schar-sort__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M3 5h18M6 12h12M10 19h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
    <span class="schar-sort__label">Filtrar</span>
  </button>
  <ul class="collection-custom-sort-options list-menu schar-sort__options">
    {%- for option in collection.sort_options -%}
      {%- liquid
        assign option_name = option.name | escape
        assign selected_class = nil
        if option.value == sort_by
          assign selected_class = "selected"
        endif

        case option.value
          when "manual"
            assign option_label = "Destacados"
          when "best-selling"
            assign option_label = "Más vendidos"
          when "title-ascending"
            assign option_label = "Alfabéticamente, A-Z"
          when "title-descending"
            assign option_label = "Alfabéticamente, Z-A"
          when "price-ascending"
            assign option_label = "Precio, menor a mayor"
          when "price-descending"
            assign option_label = "Precio, mayor a menor"
          when "created-ascending"
            assign option_label = "Fecha, antiguo a nuevo"
          when "created-descending"
            assign option_label = "Fecha, nuevo a antiguo"
          when "created"
            assign option_label = "Fecha"
          when "relevance"
            assign option_label = "Más relevante"
          else
            assign option_label = option_name
        endcase
      -%}
      <li class="collection-custom-sort-option schar-sort__option {{ selected_class }}" data-name="{{- option_name -}}" data-value="{{ option.value | escape }}">
        {{- option_label -}}
      </li>
    {%- endfor -%}
  </ul>
</div>

<style>
  /* =============================================
     FILTRO / SORT – Dr. Schär
     ============================================= */
  .schar-sort {
    position: relative;
  }

  .schar-sort__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: transparent !important;
    border: none !important;
    padding: 8px 4px !important;
    margin: 0;
    cursor: pointer;
    font-family: 'Cabin', 'Inter', sans-serif !important;
    font-size: 16px !important;
    font-weight: 500 !important;
    color: #2C1A0E !important;
    letter-spacing: 0.02em;
    text-transform: none !important;
    transition: color 0.2s ease;
    width: auto !important;
    height: auto !important;
    border-radius: 0 !important;
  }

  .schar-sort__button:hover {
    color: #C41E3A !important;
  }

  .schar-sort__icon {
    color: currentColor;
    flex-shrink: 0;
  }

  /* ── Dropdown ── */
  .schar-sort__options {
    background: #FFFFFF;
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(44, 26, 14, 0.12);
    padding: 8px 0;
    border: none;
    /* Ajustar al contenido (el base usa width:calc(100%+20px) que lo corta) */
    width: -webkit-max-content !important;
    width: max-content !important;
    min-width: 200px !important;
    max-width: 90vw;
    /* Centrar bajo el botón */
    right: auto !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
  }

  .schar-sort__option {
    font-family: 'Cabin', 'Inter', sans-serif;
    font-size: 15px;
    color: #2C1A0E;
    padding: 0 18px;
    height: 38px;
    width: 100% !important;
    white-space: nowrap;
  }

  .schar-sort__option.selected {
    color: #C41E3A;
    font-weight: 600;
  }

  .schar-sort__option.disabled {
    color: #B8AA9C;
  }

  @media (hover: hover) {
    .schar-sort__button:hover {
      color: #C41E3A !important;
    }

    .schar-sort__option:hover {
      color: #C41E3A;
    }
  }
</style>
